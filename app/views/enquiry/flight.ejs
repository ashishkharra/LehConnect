<%- include('../shared/partials/header', { admin : admin, title: title}) %>

    <!-- Page Content -->
    <div class="page-wrapper">
        <div class="content container-fluid">
            <!-- Page Header -->
            <div class="page-header">
                <div class="row">
                    <h3 class="page-title">Flight Booking Enquiry</h3>
                </div>
            </div>

            <!-- Flight Enquiries Table -->
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Flight Booking Enquiries</h5>
                            <p class="card-text">Customer enquiries for flight bookings</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover table-center mb-0" id="flightEnquiryTable">
                                    <thead>
                                        <tr>
                                            <th>Enquiry ID</th>
                                            <th>Customer</th>
                                            <th>Trip Type</th>
                                            <th>From</th>
                                            <th>To</th>
                                            <th>Departure Date</th>
                                            <th>Return Date</th>
                                            <th>Passengers</th>
                                            <th>Class</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (flightEnquiries && flightEnquiries.length> 0) { %>
                                            <% flightEnquiries.forEach(enquiry=> { %>
                                                <tr>
                                                    <td>#<%= enquiry.enquiryId %>
                                                    </td>
                                                    <td>
                                                        <h2 class="table-avatar">
                                                            <a href="javascript:void(0);" class="avatar avatar-sm me-2">
                                                                <img class="avatar-img rounded-circle"
                                                                    src="<%= enquiry.customerAvatar || 'assets/img/profiles/avatar-02.jpg' %>"
                                                                    alt="User Image">
                                                            </a>
                                                            <a href="javascript:void(0);">
                                                                <%= enquiry.customerName %>
                                                            </a>
                                                        </h2>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.tripType %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.departureCity %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.arrivalCity %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.departureDate.toLocaleDateString() %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.returnDate ? enquiry.returnDate.toLocaleDateString()
                                                            : 'N/A' %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.totalPassengers %>
                                                    </td>
                                                    <td><span class="badge bg-info">
                                                            <%= enquiry.flightClass %>
                                                        </span></td>
                                                    <td>
                                                        <% if (enquiry.status==='Pending' ) { %>
                                                            <span class="badge bg-warning">Pending</span>
                                                            <% } else if (enquiry.status==='Quoted' ) { %>
                                                                <span class="badge bg-info">Quoted</span>
                                                                <% } else if (enquiry.status==='Booked' ) { %>
                                                                    <span class="badge bg-success">Booked</span>
                                                                    <% } else if (enquiry.status==='Cancelled' ) { %>
                                                                        <span class="badge bg-danger">Cancelled</span>
                                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <div class="actions">
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-success-light me-2"
                                                                onclick="viewFlightEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-eye"></i>
                                                            </a>
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-primary-light me-2"
                                                                onclick="editFlightEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-pencil"></i>
                                                            </a>
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-danger-light"
                                                                onclick="deleteFlightEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="11" class="text-center">
                                                                <div class="empty-state">
                                                                    <i class="ti ti-plane fs-48 text-muted mb-3"></i>
                                                                    <h5>No flight enquiries found</h5>
                                                                    <p>Create your first flight booking enquiry</p>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Flight Enquiry Modal -->
    <div class="modal fade" id="addFlightEnquiry" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Flight Booking Enquiry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="flightEnquiryForm">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Trip Type <span class="text-danger">*</span></label>
                                    <select class="form-select" name="tripType" id="tripType" required
                                        onchange="toggleReturnDate()">
                                        <option value="">Select Trip Type</option>
                                        <option value="One Way">One Way</option>
                                        <option value="Round Trip">Round Trip</option>
                                        <option value="Multi City">Multi City</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Flight Class <span class="text-danger">*</span></label>
                                    <select class="form-select" name="flightClass" required>
                                        <option value="">Select Class</option>
                                        <option value="Economy">Economy</option>
                                        <option value="Premium Economy">Premium Economy</option>
                                        <option value="Business">Business Class</option>
                                        <option value="First Class">First Class</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Departure City <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="departureCity" required
                                        placeholder="City or Airport Code">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Arrival City <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="arrivalCity" required
                                        placeholder="City or Airport Code">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Departure Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="departureDate" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Return Date</label>
                                    <input type="date" class="form-control" name="returnDate" id="returnDate"
                                        placeholder="For round trips">
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Passenger Details</label>
                                    <div class="row g-3">
                                        <div class="col-md-3">
                                            <label class="form-label small">Adults (12+ yrs)</label>
                                            <input type="number" class="form-control" name="adults" min="1" max="9"
                                                value="1" required>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small">Children (2-11 yrs)</label>
                                            <input type="number" class="form-control" name="children" min="0" max="9"
                                                value="0">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small">Infants (Under 2 yrs)</label>
                                            <input type="number" class="form-control" name="infants" min="0" max="4"
                                                value="0">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small">Total</label>
                                            <input type="text" class="form-control bg-light" id="totalPassengers"
                                                readonly value="1">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Preferred Airlines</label>
                                    <input type="text" class="form-control" name="preferredAirlines"
                                        placeholder="e.g., IndiGo, Air India, SpiceJet">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Budget Range (₹)</label>
                                    <input type="text" class="form-control" name="budgetRange"
                                        placeholder="e.g., 5000-15000">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Preferred Departure Time</label>
                                    <select class="form-select" name="preferredTime">
                                        <option value="">Any Time</option>
                                        <option value="Morning">Morning (6AM - 12PM)</option>
                                        <option value="Afternoon">Afternoon (12PM - 6PM)</option>
                                        <option value="Evening">Evening (6PM - 10PM)</option>
                                        <option value="Night">Night (10PM - 6AM)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Flexible Dates</label>
                                    <select class="form-select" name="flexibleDates">
                                        <option value="No">No, fixed dates</option>
                                        <option value="±1 day">±1 day flexible</option>
                                        <option value="±2 days">±2 days flexible</option>
                                        <option value="±3 days">±3 days flexible</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Special Requirements</label>
                                    <textarea class="form-control" name="specialRequirements" rows="3"
                                        placeholder="Wheelchair assistance, special meals, etc..."></textarea>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Contact Information</label>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <input type="text" class="form-control mb-2" name="contactName"
                                                placeholder="Your Name" required>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="tel" class="form-control mb-2" name="contactPhone"
                                                placeholder="Phone Number" required>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="email" class="form-control mb-2" name="contactEmail"
                                                placeholder="Email Address" required>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Passenger Names (if available)</label>
                                    <textarea class="form-control" name="passengerNames" rows="2"
                                        placeholder="List passenger names as per passport"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit Enquiry</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    </div>

    <script>
        function toggleReturnDate() {
            const tripType = document.getElementById('tripType').value;
            const returnDate = document.getElementById('returnDate');

            if (tripType === 'Round Trip') {
                returnDate.required = true;
                returnDate.disabled = false;
            } else {
                returnDate.required = false;
                returnDate.disabled = true;
                returnDate.value = '';
            }
        }

        // Calculate total passengers
        document.querySelectorAll('input[name="adults"], input[name="children"], input[name="infants"]').forEach(input => {
            input.addEventListener('input', calculateTotalPassengers);
        });

        function calculateTotalPassengers() {
            const adults = parseInt(document.querySelector('input[name="adults"]').value) || 0;
            const children = parseInt(document.querySelector('input[name="children"]').value) || 0;
            const infants = parseInt(document.querySelector('input[name="infants"]').value) || 0;
            const total = adults + children + infants;
            document.getElementById('totalPassengers').value = total;
        }

        // Flight enquiry form submission
        document.getElementById('flightEnquiryForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);

            // Add total passengers to data
            data.totalPassengers = document.getElementById('totalPassengers').value;

            fetch('/api/enquiries/flight', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: 'Flight enquiry submitted successfully',
                            timer: 2000
                        });
                        $('#addFlightEnquiry').modal('hide');
                        location.reload();
                    }
                })
                .catch(error => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'Failed to submit enquiry'
                    });
                });
        });

        function viewFlightEnquiry(enquiryId) {
            // Implement view functionality
        }

        function editFlightEnquiry(enquiryId) {
            // Implement edit functionality
        }

        function deleteFlightEnquiry(enquiryId) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/api/enquiries/flight/${enquiryId}`, {
                        method: 'DELETE'
                    })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success) {
                                Swal.fire('Deleted!', 'Enquiry has been deleted.', 'success');
                                location.reload();
                            }
                        });
                }
            });
        }
    </script>
    <%- include('../shared/partials/footer') %>