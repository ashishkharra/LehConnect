<%- include('../shared/partials/header', { admin : admin, title: title}) %>

    <!-- Page Content -->
    <div class="page-wrapper">
        <div class="content container-fluid">
            <!-- Page Header -->
            <div class="page-header">
                <div class="row">
                    <h3 class="page-title">Hotel Booking Enquiry</h3>
                </div>
            </div>

            <!-- Hotel Enquiries Table -->
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Hotel Booking Enquiries</h5>
                            <p class="card-text">Customer enquiries for hotel accommodations</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover table-center mb-0" id="hotelEnquiryTable">
                                    <thead>
                                        <tr>
                                            <th>Enquiry ID</th>
                                            <th>Customer</th>
                                            <th>Hotel Location</th>
                                            <th>Check-in Date</th>
                                            <th>Check-out Date</th>
                                            <th>Rooms</th>
                                            <th>Room Type</th>
                                            <th>Budget Range</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (hotelEnquiries && hotelEnquiries.length> 0) { %>
                                            <% hotelEnquiries.forEach(enquiry=> { %>
                                                <tr>
                                                    <td>#<%= enquiry.enquiryId %>
                                                    </td>
                                                    <td>
                                                        <h2 class="table-avatar">
                                                            <a href="javascript:void(0);" class="avatar avatar-sm me-2">
                                                                <img class="avatar-img rounded-circle"
                                                                    src="<%= enquiry.customerAvatar || 'assets/img/profiles/avatar-02.jpg' %>"
                                                                    alt="User Image">
                                                            </a>
                                                            <a href="javascript:void(0);">
                                                                <%= enquiry.customerName %>
                                                            </a>
                                                        </h2>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.hotelLocation %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.checkInDate.toLocaleDateString() %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.checkOutDate.toLocaleDateString() %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.roomsRequired %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.roomType %>
                                                    </td>
                                                    <td>₹<%= enquiry.budgetRange %>
                                                    </td>
                                                    <td>
                                                        <% if (enquiry.status==='Pending' ) { %>
                                                            <span class="badge bg-warning">Pending</span>
                                                            <% } else if (enquiry.status==='Quoted' ) { %>
                                                                <span class="badge bg-info">Quoted</span>
                                                                <% } else if (enquiry.status==='Confirmed' ) { %>
                                                                    <span class="badge bg-success">Confirmed</span>
                                                                    <% } else if (enquiry.status==='Cancelled' ) { %>
                                                                        <span class="badge bg-danger">Cancelled</span>
                                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <div class="actions">
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-success-light me-2"
                                                                onclick="viewHotelEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-eye"></i>
                                                            </a>
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-primary-light me-2"
                                                                onclick="editHotelEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-pencil"></i>
                                                            </a>
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-danger-light"
                                                                onclick="deleteHotelEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="10" class="text-center">
                                                                <div class="empty-state">
                                                                    <i
                                                                        class="ti ti-building-hotel fs-48 text-muted mb-3"></i>
                                                                    <h5>No hotel enquiries found</h5>
                                                                    <p>Create your first hotel booking enquiry</p>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Hotel Enquiry Modal -->
    <div class="modal fade" id="addHotelEnquiry" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Hotel Booking Enquiry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="hotelEnquiryForm">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Hotel Location/City <span
                                            class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="hotelLocation" required
                                        placeholder="Enter city or specific location">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Area Preference</label>
                                    <input type="text" class="form-control" name="areaPreference"
                                        placeholder="Preferred area/landmark">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Check-in Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="checkInDate" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Check-out Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="checkOutDate" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Rooms Required <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control" name="roomsRequired" min="1" max="10"
                                        value="1" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Room Type <span class="text-danger">*</span></label>
                                    <select class="form-select" name="roomType" required>
                                        <option value="">Select Room Type</option>
                                        <option value="Single">Single Room</option>
                                        <option value="Double">Double Room</option>
                                        <option value="Twin">Twin Room</option>
                                        <option value="Suite">Suite</option>
                                        <option value="Deluxe">Deluxe Room</option>
                                        <option value="Family">Family Room</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Hotel Star Category</label>
                                    <select class="form-select" name="hotelCategory">
                                        <option value="">Any</option>
                                        <option value="1 Star">1 Star</option>
                                        <option value="2 Star">2 Star</option>
                                        <option value="3 Star">3 Star</option>
                                        <option value="4 Star">4 Star</option>
                                        <option value="5 Star">5 Star</option>
                                        <option value="Budget">Budget Hotel</option>
                                        <option value="Homestay">Homestay</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Adults <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control" name="adults" min="1" max="20" value="2"
                                        required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Children</label>
                                    <input type="number" class="form-control" name="children" min="0" max="10"
                                        value="0">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Children Ages</label>
                                    <input type="text" class="form-control" name="childrenAges"
                                        placeholder="e.g., 5, 8">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Budget Range (₹ per night)</label>
                                    <input type="text" class="form-control" name="budgetRange"
                                        placeholder="e.g., 2000-5000">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Meal Plan Preference</label>
                                    <select class="form-select" name="mealPlan">
                                        <option value="Room Only">Room Only</option>
                                        <option value="Breakfast Included">Breakfast Included</option>
                                        <option value="Half Board">Half Board</option>
                                        <option value="Full Board">Full Board</option>
                                        <option value="All Inclusive">All Inclusive</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Special Requirements</label>
                                    <textarea class="form-control" name="specialRequirements" rows="3"
                                        placeholder="Early check-in, extra bed, etc..."></textarea>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Contact Information</label>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <input type="text" class="form-control mb-2" name="contactName"
                                                placeholder="Your Name" required>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="tel" class="form-control mb-2" name="contactPhone"
                                                placeholder="Phone Number" required>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="email" class="form-control mb-2" name="contactEmail"
                                                placeholder="Email Address">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit Enquiry</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    </div>

    <script>
        // Hotel enquiry form submission
        document.getElementById('hotelEnquiryForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);

            // Submit to server
            fetch('/api/enquiries/hotel', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: 'Hotel enquiry submitted successfully',
                            timer: 2000
                        });
                        $('#addHotelEnquiry').modal('hide');
                        location.reload();
                    }
                })
                .catch(error => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'Failed to submit enquiry'
                    });
                });
        });

        function viewHotelEnquiry(enquiryId) {
            // Implement view functionality
        }

        function editHotelEnquiry(enquiryId) {
            // Implement edit functionality
        }

        function deleteHotelEnquiry(enquiryId) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/api/enquiries/hotel/${enquiryId}`, {
                        method: 'DELETE'
                    })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success) {
                                Swal.fire('Deleted!', 'Enquiry has been deleted.', 'success');
                                location.reload();
                            }
                        });
                }
            });
        }
    </script>
    <%- include('../shared/partials/footer') %>