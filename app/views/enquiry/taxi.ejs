<%- include('../shared/partials/header', { admin : admin, title: title}) %>

    <!-- Page Content -->
    <div class="page-wrapper">
        <div class="content container-fluid">
            <!-- Page Header -->
            <div class="page-header">
                <div class="row">
                    <h3 class="page-title">Taxi Booking Enquiry</h3>
                </div>
            </div>

            <!-- Taxi Enquiries Table -->
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Taxi Booking Enquiries</h5>
                            <p class="card-text">Customer enquiries for taxi services</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover table-center mb-0" id="taxiEnquiryTable">
                                    <thead>
                                        <tr>
                                            <th>Enquiry ID</th>
                                            <th>Customer</th>
                                            <th>Pickup Location</th>
                                            <th>Destination</th>
                                            <th>Travel Date</th>
                                            <th>Vehicle Type</th>
                                            <th>Status</th>
                                            <th>Created Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (taxiEnquiries && taxiEnquiries.length> 0) { %>
                                            <% taxiEnquiries.forEach(enquiry=> { %>
                                                <tr>
                                                    <td>#<%= enquiry.enquiryId %>
                                                    </td>
                                                    <td>
                                                        <h2 class="table-avatar">
                                                            <a href="javascript:void(0);" class="avatar avatar-sm me-2">
                                                                <img class="avatar-img rounded-circle"
                                                                    src="<%= enquiry.customerAvatar || 'assets/img/profiles/avatar-02.jpg' %>"
                                                                    alt="User Image">
                                                            </a>
                                                            <a href="javascript:void(0);">
                                                                <%= enquiry.customerName %>
                                                            </a>
                                                        </h2>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.pickupLocation %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.destination %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.travelDate.toLocaleDateString() %>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-primary-light">
                                                            <%= enquiry.vehicleType %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <% if (enquiry.status==='Pending' ) { %>
                                                            <span class="badge bg-warning">Pending</span>
                                                            <% } else if (enquiry.status==='Accepted' ) { %>
                                                                <span class="badge bg-success">Accepted</span>
                                                                <% } else if (enquiry.status==='In Progress' ) { %>
                                                                    <span class="badge bg-info">In Progress</span>
                                                                    <% } else if (enquiry.status==='Completed' ) { %>
                                                                        <span class="badge bg-success">Completed</span>
                                                                        <% } else if (enquiry.status==='Cancelled' ) {
                                                                            %>
                                                                            <span
                                                                                class="badge bg-danger">Cancelled</span>
                                                                            <% } %>
                                                    </td>
                                                    <td>
                                                        <%= enquiry.createdDate.toLocaleDateString() %>
                                                    </td>
                                                    <td>
                                                        <div class="actions">
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-success-light me-2"
                                                                data-bs-toggle="tooltip" title="View Details"
                                                                onclick="viewTaxiEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-eye"></i>
                                                            </a>
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-primary-light me-2"
                                                                data-bs-toggle="tooltip" title="Edit"
                                                                onclick="editTaxiEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-pencil"></i>
                                                            </a>
                                                            <a href="javascript:void(0);"
                                                                class="btn btn-sm bg-danger-light"
                                                                data-bs-toggle="tooltip" title="Delete"
                                                                onclick="deleteTaxiEnquiry('<%= enquiry.enquiryId %>')">
                                                                <i class="ti ti-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="9" class="text-center">
                                                                <div class="empty-state">
                                                                    <i class="ti ti-car fs-48 text-muted mb-3"></i>
                                                                    <h5>No taxi enquiries found</h5>
                                                                    <p>Create your first taxi booking enquiry</p>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Taxi Enquiry Modal -->
    <div class="modal fade" id="addTaxiEnquiry" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Taxi Booking Enquiry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="taxiEnquiryForm">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Pickup Location <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="pickupLocation" required
                                        placeholder="Enter pickup address">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Destination <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="destination" required
                                        placeholder="Enter destination address">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Travel Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="travelDate" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Travel Time <span class="text-danger">*</span></label>
                                    <input type="time" class="form-control" name="travelTime" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Vehicle Type <span class="text-danger">*</span></label>
                                    <select class="form-select" name="vehicleType" required>
                                        <option value="">Select Vehicle Type</option>
                                        <option value="Hatchback">Hatchback</option>
                                        <option value="Sedan">Sedan</option>
                                        <option value="SUV">SUV</option>
                                        <option value="MUV">MUV</option>
                                        <option value="Luxury">Luxury Car</option>
                                        <option value="Tempo Traveller">Tempo Traveller</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Number of Passengers</label>
                                    <input type="number" class="form-control" name="passengers" min="1" max="20"
                                        value="1">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Trip Type</label>
                                    <select class="form-select" name="tripType">
                                        <option value="One Way">One Way</option>
                                        <option value="Round Trip">Round Trip</option>
                                        <option value="Multiple Stops">Multiple Stops</option>
                                        <option value="Full Day Rental">Full Day Rental</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Budget Range (₹)</label>
                                    <input type="text" class="form-control" name="budget" placeholder="e.g., 1000-2000">
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Additional Requirements</label>
                                    <textarea class="form-control" name="additionalRequirements" rows="3"
                                        placeholder="Any special requirements..."></textarea>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Contact Information</label>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <input type="text" class="form-control mb-2" name="contactName"
                                                placeholder="Your Name">
                                        </div>
                                        <div class="col-md-4">
                                            <input type="tel" class="form-control mb-2" name="contactPhone"
                                                placeholder="Phone Number">
                                        </div>
                                        <div class="col-md-4">
                                            <input type="email" class="form-control mb-2" name="contactEmail"
                                                placeholder="Email Address">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit Enquiry</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- View Taxi Enquiry Modal -->
    <div class="modal fade" id="viewTaxiEnquiryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Taxi Enquiry Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="enquiryDetails">
                    <!-- Details will be loaded here -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
    </div>

    <script>
        // Form submission
        document.getElementById('taxiEnquiryForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);

            // Submit to server
            fetch('/api/enquiries/taxi', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: 'Taxi enquiry submitted successfully',
                            timer: 2000
                        });
                        $('#addTaxiEnquiry').modal('hide');
                        location.reload();
                    }
                })
                .catch(error => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'Failed to submit enquiry'
                    });
                });
        });

        function viewTaxiEnquiry(enquiryId) {
            fetch(`/api/enquiries/taxi/${enquiryId}`)
                .then(response => response.json())
                .then(data => {
                    const details = `
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Pickup Location:</h6>
                                <p>${data.pickupLocation}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Destination:</h6>
                                <p>${data.destination}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Travel Date & Time:</h6>
                                <p>${data.travelDate} at ${data.travelTime}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Vehicle Type:</h6>
                                <p>${data.vehicleType}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Passengers:</h6>
                                <p>${data.passengers}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Trip Type:</h6>
                                <p>${data.tripType}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Budget:</h6>
                                <p>₹${data.budget}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Status:</h6>
                                <span class="badge bg-${getStatusColor(data.status)}">${data.status}</span>
                            </div>
                            <div class="col-12">
                                <h6>Additional Requirements:</h6>
                                <p>${data.additionalRequirements || 'None'}</p>
                            </div>
                            <div class="col-12 mt-3">
                                <h6>Contact Information:</h6>
                                <div class="d-flex gap-3">
                                    <span><i class="ti ti-user me-2"></i>${data.contactName}</span>
                                    <span><i class="ti ti-phone me-2"></i>${data.contactPhone}</span>
                                    <span><i class="ti ti-mail me-2"></i>${data.contactEmail}</span>
                                </div>
                            </div>
                        </div>
                    `;
                    document.getElementById('enquiryDetails').innerHTML = details;
                    $('#viewTaxiEnquiryModal').modal('show');
                });
        }

        function getStatusColor(status) {
            switch (status) {
                case 'Pending': return 'warning';
                case 'Accepted': return 'success';
                case 'In Progress': return 'info';
                case 'Completed': return 'success';
                case 'Cancelled': return 'danger';
                default: return 'secondary';
            }
        }

        function editTaxiEnquiry(enquiryId) {
            // Implement edit functionality
            Swal.fire({
                title: 'Edit Enquiry',
                text: 'Edit functionality will be implemented soon',
                icon: 'info'
            });
        }

        function deleteTaxiEnquiry(enquiryId) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/api/enquiries/taxi/${enquiryId}`, {
                        method: 'DELETE'
                    })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success) {
                                Swal.fire(
                                    'Deleted!',
                                    'Enquiry has been deleted.',
                                    'success'
                                );
                                location.reload();
                            }
                        });
                }
            });
        }
    </script>
    <%- include('../shared/partials/footer') %>