<%- include('../shared/partials/header', { admin : admin, title: title}) %>
        <!-- Page Content -->
        <div class="page-wrapper">
            <div class="content container-fluid">
                <!-- Page Header -->
                <div class="page-header">
                    <div class="row align-items-center">
                        <div class="col-sm-6">
                            <h3 class="page-title">Report Management</h3>
                        </div>
                        <div class="col-sm-6 text-end">
                            <div class="btn-group">
                                <button class="btn btn-primary" onclick="generateCustomReport()">
                                    <i class="ti ti-plus me-2"></i>Create Custom Report
                                </button>
                                <button class="btn btn-success" onclick="scheduleReport()">
                                    <i class="ti ti-clock me-2"></i>Schedule Report
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Date Range Picker -->
                <div class="date-range-picker">
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Report Period</label>
                                <select class="form-select" id="reportPeriod" onchange="changeReportPeriod()">
                                    <option value="today">Today</option>
                                    <option value="yesterday">Yesterday</option>
                                    <option value="week">This Week</option>
                                    <option value="last_week">Last Week</option>
                                    <option value="month" selected>This Month</option>
                                    <option value="last_month">Last Month</option>
                                    <option value="quarter">This Quarter</option>
                                    <option value="year">This Year</option>
                                    <option value="custom">Custom Range</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4" id="customDateRange" style="display: none;">
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">From Date</label>
                                        <input type="date" class="form-control" id="fromDate">
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">To Date</label>
                                        <input type="date" class="form-control" id="toDate">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="mb-3">
                                <label class="form-label">Compare With</label>
                                <select class="form-select" id="comparePeriod" onchange="toggleComparison()">
                                    <option value="">No Comparison</option>
                                    <option value="previous_period">Previous Period</option>
                                    <option value="same_period_last_year">Same Period Last Year</option>
                                    <option value="custom_comparison">Custom Period</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex gap-2" style="margin-top: 28px;">
                                <button class="btn btn-primary w-50" onclick="applyDateFilter()">
                                    <i class="ti ti-filter me-2"></i>Apply
                                </button>
                                <button class="btn btn-secondary w-50" onclick="resetFilters()">
                                    <i class="ti ti-refresh me-2"></i>Reset
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Key Performance Indicators -->
                <div class="row">
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="kpi-card">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Total Revenue</h6>
                                    <h3 class="mb-0">₹<%= kpis.revenue ? kpis.revenue.toLocaleString('en-IN') : 0 %></h3>
                                </div>
                                <div class="text-end">
                                    <span class="trend-indicator <%= kpis.revenueTrend > 0 ? 'bg-success' : 'bg-danger' %>">
                                        <i class="ti ti-arrow-<%= kpis.revenueTrend > 0 ? 'up' : 'down' %> me-1"></i>
                                        <%= Math.abs(kpis.revenueTrend) %>%
                                    </span>
                                    <p class="text-muted mb-0">vs Last Month</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="kpi-card">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Total Bookings</h6>
                                    <h3 class="mb-0"><%= kpis.bookings ? kpis.bookings.toLocaleString('en-IN') : 0 %></h3>
                                </div>
                                <div class="text-end">
                                    <span class="trend-indicator <%= kpis.bookingsTrend > 0 ? 'bg-success' : 'bg-danger' %>">
                                        <i class="ti ti-arrow-<%= kpis.bookingsTrend > 0 ? 'up' : 'down' %> me-1"></i>
                                        <%= Math.abs(kpis.bookingsTrend) %>%
                                    </span>
                                    <p class="text-muted mb-0">vs Last Month</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="kpi-card">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">New Customers</h6>
                                    <h3 class="mb-0"><%= kpis.newCustomers ? kpis.newCustomers.toLocaleString('en-IN') : 0 %></h3>
                                </div>
                                <div class="text-end">
                                    <span class="trend-indicator <%= kpis.customersTrend > 0 ? 'bg-success' : 'bg-danger' %>">
                                        <i class="ti ti-arrow-<%= kpis.customersTrend > 0 ? 'up' : 'down' %> me-1"></i>
                                        <%= Math.abs(kpis.customersTrend) %>%
                                    </span>
                                    <p class="text-muted mb-0">vs Last Month</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="kpi-card">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Avg. Booking Value</h6>
                                    <h3 class="mb-0">₹<%= kpis.avgBookingValue ? kpis.avgBookingValue.toLocaleString('en-IN') : 0 %></h3>
                                </div>
                                <div class="text-end">
                                    <span class="trend-indicator <%= kpis.avgValueTrend > 0 ? 'bg-success' : 'bg-danger' %>">
                                        <i class="ti ti-arrow-<%= kpis.avgValueTrend > 0 ? 'up' : 'down' %> me-1"></i>
                                        <%= Math.abs(kpis.avgValueTrend) %>%
                                    </span>
                                    <p class="text-muted mb-0">vs Last Month</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Report Navigation Tabs -->
                <div class="report-tabs">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#financial-reports">
                                <i class="ti ti-currency-rupee me-2"></i>Financial
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#booking-reports">
                                <i class="ti ti-calendar me-2"></i>Booking
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#customer-reports">
                                <i class="ti ti-users me-2"></i>Customer
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#vendor-reports">
                                <i class="ti ti-building-store me-2"></i>Vendor
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#referral-reports">
                                <i class="ti ti-share me-2"></i>Referral
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#operational-reports">
                                <i class="ti ti-chart-bar me-2"></i>Operational
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#custom-reports">
                                <i class="ti ti-settings me-2"></i>Custom
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="tab-content">
                    <!-- Financial Reports Tab -->
                    <div class="tab-pane fade show active" id="financial-reports">
                        <div class="row">
                            <div class="col-lg-8">
                                <!-- Revenue Chart -->
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Revenue Overview</h5>
                                        <div class="card-action">
                                            <select class="form-select form-select-sm" style="width: auto;" 
                                                    onchange="updateRevenueChart(this.value)">
                                                <option value="daily">Daily</option>
                                                <option value="weekly">Weekly</option>
                                                <option value="monthly" selected>Monthly</option>
                                                <option value="quarterly">Quarterly</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div class="chart-container">
                                            <canvas id="revenueChart"></canvas>
                                        </div>
                                    </div>
                                </div>

                                <!-- Income vs Expense -->
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5 class="card-title">Income Breakdown</h5>
                                            </div>
                                            <div class="card-body">
                                                <div class="chart-container">
                                                    <canvas id="incomePieChart"></canvas>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5 class="card-title">Expense Breakdown</h5>
                                            </div>
                                            <div class="card-body">
                                                <div class="chart-container">
                                                    <canvas id="expensePieChart"></canvas>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <!-- Financial Summary -->
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Financial Summary</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="summary-widget" style="background: linear-gradient(135deg, #28a745, #20c997);">
                                            <h4>₹<%= financialSummary.totalIncome ? financialSummary.totalIncome.toLocaleString('en-IN') : 0 %></h4>
                                            <p class="mb-0">Total Income</p>
                                        </div>
                                        <div class="summary-widget" style="background: linear-gradient(135deg, #dc3545, #fd7e14);">
                                            <h4>₹<%= financialSummary.totalExpense ? financialSummary.totalExpense.toLocaleString('en-IN') : 0 %></h4>
                                            <p class="mb-0">Total Expense</p>
                                        </div>
                                        <div class="summary-widget" style="background: linear-gradient(135deg, #007bff, #6610f2);">
                                            <h4>₹<%= financialSummary.netProfit ? financialSummary.netProfit.toLocaleString('en-IN') : 0 %></h4>
                                            <p class="mb-0">Net Profit</p>
                                        </div>
                                        <div class="summary-widget" style="background: linear-gradient(135deg, #6c757d, #343a40);">
                                            <h4><%= financialSummary.profitMargin ? financialSummary.profitMargin + '%' : '0%' %></h4>
                                            <p class="mb-0">Profit Margin</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Top Revenue Sources -->
                                <div class="card mt-4">
                                    <div class="card-header">
                                        <h5 class="card-title">Top Revenue Sources</h5>
                                    </div>
                                    <div class="card-body">
                                        <% if (topRevenueSources && topRevenueSources.length > 0) { %>
                                            <% topRevenueSources.forEach((source, index) => { %>
                                                <div class="d-flex align-items-center mb-3">
                                                    <div class="flex-shrink-0">
                                                        <span class="badge bg-primary me-2">#<%= index + 1 %></span>
                                                    </div>
                                                    <div class="flex-grow-1">
                                                        <h6 class="mb-1"><%= source.category %></h6>
                                                        <div class="progress" style="height: 5px;">
                                                            <div class="progress-bar" role="progressbar" 
                                                                 style="width: <%= source.percentage %>%;"></div>
                                                        </div>
                                                    </div>
                                                    <div class="flex-shrink-0 text-end">
                                                        <h6 class="mb-1">₹<%= source.amount %></h6>
                                                        <small class="text-muted"><%= source.percentage %>%</small>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p class="text-muted text-center">No data available</p>
                                        <% } %>
                                    </div>
                                </div>

                                <!-- Download Options -->
                                <div class="card mt-4">
                                    <div class="card-header">
                                        <h5 class="card-title">Export Financial Reports</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="download-options">
                                            <a href="/admin/reports/financial/export/excel" class="download-btn" 
                                               style="background: #28a745;">
                                                <i class="ti ti-file-spreadsheet"></i> Excel
                                            </a>
                                            <a href="/admin/reports/financial/export/pdf" class="download-btn" 
                                               style="background: #dc3545;">
                                                <i class="ti ti-file-invoice"></i> PDF
                                            </a>
                                            <a href="/admin/reports/financial/export/csv" class="download-btn" 
                                               style="background: #17a2b8;">
                                                <i class="ti ti-file-text"></i> CSV
                                            </a>
                                            <a href="/admin/reports/financial/export/json" class="download-btn" 
                                               style="background: #6c757d;">
                                                <i class="ti ti-code"></i> JSON
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Financial Tables -->
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Monthly Financial Performance</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover comparison-table">
                                                <thead>
                                                    <tr>
                                                        <th>Month</th>
                                                        <th>Revenue</th>
                                                        <th>Expenses</th>
                                                        <th>Profit</th>
                                                        <th>Margin</th>
                                                        <th>Growth</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (monthlyPerformance && monthlyPerformance.length > 0) { %>
                                                        <% monthlyPerformance.forEach(month => { %>
                                                            <tr>
                                                                <td><%= month.month %></td>
                                                                <td class="fw-bold">₹<%= month.revenue %></td>
                                                                <td class="text-danger">₹<%= month.expenses %></td>
                                                                <td class="<%= month.profit > 0 ? 'text-success' : 'text-danger' %> fw-bold">
                                                                    ₹<%= month.profit %>
                                                                </td>
                                                                <td>
                                                                    <span class="badge bg-<%= month.margin > 20 ? 'success' : month.margin > 10 ? 'warning' : 'danger' %>">
                                                                        <%= month.margin %>%
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <span class="badge bg-<%= month.growth > 0 ? 'success' : 'danger' %>">
                                                                        <i class="ti ti-arrow-<%= month.growth > 0 ? 'up' : 'down' %>"></i>
                                                                        <%= Math.abs(month.growth) %>%
                                                                    </span>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="6" class="text-center">No data available</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Payment Method Analysis</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>Payment Method</th>
                                                        <th>Transaction Count</th>
                                                        <th>Total Amount</th>
                                                        <th>Avg. Transaction</th>
                                                        <th>Success Rate</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (paymentMethodAnalysis && paymentMethodAnalysis.length > 0) { %>
                                                        <% paymentMethodAnalysis.forEach(method => { %>
                                                            <tr>
                                                                <td>
                                                                    <i class="ti <%= getMethodIcon(method.method) %> me-2"></i>
                                                                    <%= getMethodName(method.method) %>
                                                                </td>
                                                                <td><%= method.count %></td>
                                                                <td class="fw-bold">₹<%= method.amount %></td>
                                                                <td>₹<%= method.avgTransaction %></td>
                                                                <td>
                                                                    <span class="badge bg-<%= method.successRate > 95 ? 'success' : method.successRate > 90 ? 'warning' : 'danger' %>">
                                                                        <%= method.successRate %>%
                                                                    </span>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="5" class="text-center">No data available</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Booking Reports Tab -->
                    <div class="tab-pane fade" id="booking-reports">
                        <div class="row">
                            <div class="col-lg-8">
                                <!-- Bookings Trend Chart -->
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Booking Trends</h5>
                                        <div class="card-action">
                                            <select class="form-select form-select-sm" style="width: auto;" 
                                                    onchange="updateBookingTrendChart(this.value)">
                                                <option value="daily">Daily</option>
                                                <option value="weekly" selected>Weekly</option>
                                                <option value="monthly">Monthly</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div class="chart-container">
                                            <canvas id="bookingTrendChart"></canvas>
                                        </div>
                                    </div>
                                </div>

                                <!-- Service Type Distribution -->
                                <div class="card mt-4">
                                    <div class="card-header">
                                        <h5 class="card-title">Service Type Distribution</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="chart-container">
                                            <canvas id="serviceDistributionChart"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <!-- Booking Statistics -->
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Booking Statistics</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row text-center">
                                            <div class="col-6 mb-3">
                                                <div class="p-3 border rounded">
                                                    <h4 class="text-primary mb-1"><%= bookingStats.totalBookings || 0 %></h4>
                                                    <p class="small mb-0">Total Bookings</p>
                                                </div>
                                            </div>
                                            <div class="col-6 mb-3">
                                                <div class="p-3 border rounded">
                                                    <h4 class="text-success mb-1"><%= bookingStats.completed || 0 %></h4>
                                                    <p class="small mb-0">Completed</p>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="p-3 border rounded">
                                                    <h4 class="text-warning mb-1"><%= bookingStats.pending || 0 %></h4>
                                                    <p class="small mb-0">Pending</p>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="p-3 border rounded">
                                                    <h4 class="text-danger mb-1"><%= bookingStats.cancelled || 0 %></h4>
                                                    <p class="small mb-0">Cancelled</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mt-3">
                                            <p class="mb-1">Conversion Rate: <strong><%= bookingStats.conversionRate || 0 %>%</strong></p>
                                            <p class="mb-1">Avg. Booking Value: <strong>₹<%= bookingStats.avgValue || 0 %></strong></p>
                                            <p class="mb-0">Avg. Processing Time: <strong><%= bookingStats.avgProcessingTime || 0 %> hours</strong></p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Top Performing Services -->
                                <div class="card mt-4">
                                    <div class="card-header">
                                        <h5 class="card-title">Top Performing Services</h5>
                                    </div>
                                    <div class="card-body">
                                        <% if (topServices && topServices.length > 0) { %>
                                            <% topServices.forEach((service, index) => { %>
                                                <div class="d-flex align-items-center mb-3">
                                                    <div class="flex-shrink-0">
                                                        <span class="badge bg-<%= index === 0 ? 'warning' : index === 1 ? 'secondary' : index === 2 ? 'danger' : 'primary' %> me-2">
                                                            #<%= index + 1 %>
                                                        </span>
                                                    </div>
                                                    <div class="flex-grow-1">
                                                        <h6 class="mb-1"><%= service.name %></h6>
                                                        <div class="progress" style="height: 5px;">
                                                            <div class="progress-bar" role="progressbar" 
                                                                 style="width: <%= service.percentage %>%;"></div>
                                                        </div>
                                                    </div>
                                                    <div class="flex-shrink-0 text-end">
                                                        <h6 class="mb-1">₹<%= service.revenue %></h6>
                                                        <small class="text-muted"><%= service.bookings %> bookings</small>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p class="text-muted text-center">No data available</p>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Booking Details Tables -->
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Booking Status Breakdown</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>Status</th>
                                                        <th>Count</th>
                                                        <th>Percentage</th>
                                                        <th>Revenue</th>
                                                        <th>Avg. Value</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (statusBreakdown && statusBreakdown.length > 0) { %>
                                                        <% statusBreakdown.forEach(status => { %>
                                                            <tr>
                                                                <td>
                                                                    <span class="badge bg-<%= getBookingStatusColor(status.status) %>">
                                                                        <%= status.status %>
                                                                    </span>
                                                                </td>
                                                                <td><%= status.count %></td>
                                                                <td><%= status.percentage %>%</td>
                                                                <td class="fw-bold">₹<%= status.revenue %></td>
                                                                <td>₹<%= status.avgValue %></td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="5" class="text-center">No data available</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Booking Source Analysis</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>Source</th>
                                                        <th>Bookings</th>
