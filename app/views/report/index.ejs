    <script>
        // Initialize charts
        let revenueChart, incomePieChart, expensePieChart, bookingTrendChart, serviceDistributionChart;
        let customerGrowthChart, customerSegmentationChart, vendorPerformanceChart, vendorRatingChart;
        let referralGrowthChart, referralSourceChart, operationalEfficiencyChart, supportTicketChart;

        document.addEventListener('DOMContentLoaded', function() {
            // Revenue Chart
            const revenueCtx = document.getElementById('revenueChart').getContext('2d');
            revenueChart = new Chart(revenueCtx, {
                type: 'line',
                data: {
                    labels: <%= JSON.stringify(revenueChartLabels || []) %>,
                    datasets: [
                        {
                            label: 'Revenue',
                            data: <%= JSON.stringify(revenueChartData || []) %>,
                            borderColor: '#28a745',
                            backgroundColor: 'rgba(40, 167, 69, 0.1)',
                            tension: 0.4,
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '₹' + value.toLocaleString();
                                }
                            }
                        }
                    }
                }
            });

            // Income Pie Chart
            const incomeCtx = document.getElementById('incomePieChart').getContext('2d');
            incomePieChart = new Chart(incomeCtx, {
                type: 'doughnut',
                data: {
                    labels: <%= JSON.stringify(incomeCategories || []) %>,
                    datasets: [{
                        data: <%= JSON.stringify(incomeData || []) %>,
                        backgroundColor: [
                            '#28a745', '#20c997', '#007bff', '#6610f2', '#6f42c1'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

            // Expense Pie Chart
            const expenseCtx = document.getElementById('expensePieChart').getContext('2d');
            expensePieChart = new Chart(expenseCtx, {
                type: 'doughnut',
                data: {
                    labels: <%= JSON.stringify(expenseCategories || []) %>,
                    datasets: [{
                        data: <%= JSON.stringify(expenseData || []) %>,
                        backgroundColor: [
                            '#dc3545', '#fd7e14', '#ffc107', '#17a2b8', '#6c757d'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

            // Initialize other charts similarly...
        });

        // Helper functions
        function getMethodIcon(method) {
            const icons = {
                'upi': 'ti-device-mobile',
                'credit_card': 'ti-credit-card',
                'debit_card': 'ti-credit-card',
                'netbanking': 'ti-building-bank',
                'wallet': 'ti-wallet',
                'cash': 'ti-cash',
                'bank_transfer': 'ti-building-bank'
            };
            return icons[method] || 'ti-currency-rupee';
        }

        function getMethodName(method) {
            const names = {
                'upi': 'UPI',
                'credit_card': 'Credit Card',
                'debit_card': 'Debit Card',
                'netbanking': 'Net Banking',
                'wallet': 'Wallet',
                'cash': 'Cash',
                'bank_transfer': 'Bank Transfer'
            };
            return names[method] || method;
        }

        function getBookingStatusColor(status) {
            switch(status) {
                case 'completed': return 'success';
                case 'confirmed': return 'primary';
                case 'pending': return 'warning';
                case 'cancelled': return 'danger';
                case 'refunded': return 'info';
                default: return 'secondary';
            }
        }

        function getReportColor(type) {
            const colors = {
                'financial': '#28a745',
                'booking': '#007bff',
                'customer': '#6610f2',
                'vendor': '#fd7e14',
                'referral': '#20c997',
                'operational': '#6f42c1'
            };
            return colors[type] || '#6c757d';
        }

        function getReportIcon(type) {
            const icons = {
                'financial': 'ti-currency-rupee',
                'booking': 'ti-calendar',
                'customer': 'ti-users',
                'vendor': 'ti-building-store',
                'referral': 'ti-share',
                'operational': 'ti-chart-bar'
            };
            return icons[type] || 'ti-file-text';
        }

        // Date range functionality
        function changeReportPeriod() {
            const period = document.getElementById('reportPeriod').value;
            const customRange = document.getElementById('customDateRange');
            
            if (period === 'custom') {
                customRange.style.display = 'block';
            } else {
                customRange.style.display = 'none';
            }
        }

        function toggleComparison() {
            const compare = document.getElementById('comparePeriod').value;
            // Implement comparison logic
        }

        function applyDateFilter() {
            const period = document.getElementById('reportPeriod').value;
            let fromDate, toDate;
            
            const today = new Date();
            
            switch(period) {
                case 'today':
                    fromDate = toDate = today.toISOString().split('T')[0];
                    break;
                case 'yesterday':
                    const yesterday = new Date(today);
                    yesterday.setDate(yesterday.getDate() - 1);
                    fromDate = toDate = yesterday.toISOString().split('T')[0];
                    break;
                case 'week':
                    const weekStart = new Date(today);
                    weekStart.setDate(weekStart.getDate() - weekStart.getDay());
                    fromDate = weekStart.toISOString().split('T')[0];
                    toDate = today.toISOString().split('T')[0];
                    break;
                case 'month':
                    fromDate = new Date(today.getFullYear(), today.getMonth(), 1)
                        .toISOString().split('T')[0];
                    toDate = today.toISOString().split('T')[0];
                    break;
                case 'custom':
                    fromDate = document.getElementById('fromDate').value;
                    toDate = document.getElementById('toDate').value;
                    if (!fromDate || !toDate) {
                        Swal.fire('Error', 'Please select custom date range', 'error');
                        return;
                    }
                    break;
            }
            
            // Reload page with new date range
            window.location.href = `/admin/reports?from=${fromDate}&to=${toDate}`;
        }

        function resetFilters() {
            document.getElementById('reportPeriod').value = 'month';
            document.getElementById('comparePeriod').value = '';
            document.getElementById('customDateRange').style.display = 'none';
            
            // Reload page with default filters
            window.location.href = '/admin/reports';
        }

