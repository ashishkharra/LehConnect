        // Preview custom report
        function previewCustomReport() {
            const reportType = document.getElementById('customReportType').value;
            const dateRange = document.getElementById('customDateRangeSelect').value;
            const format = document.getElementById('customOutputFormat').value;
            const reportName = document.getElementById('customReportName').value;
            
            if (!reportType || !reportName) {
                Swal.fire('Error', 'Please select report type and enter report name', 'error');
                return;
            }
            
            // Collect selected metrics
            const metrics = [];
            if (document.getElementById('metricRevenue').checked) metrics.push('revenue');
            if (document.getElementById('metricBookings').checked) metrics.push('bookings');
            if (document.getElementById('metricCustomers').checked) metrics.push('customers');
            if (document.getElementById('metricVendors').checked) metrics.push('vendors');
            if (document.getElementById('metricCommissions').checked) metrics.push('commissions');
            if (document.getElementById('metricReferrals').checked) metrics.push('referrals');
            if (document.getElementById('metricOperations').checked) metrics.push('operations');
            if (document.getElementById('metricQuality').checked) metrics.push('quality');
            
            if (metrics.length === 0) {
                Swal.fire('Error', 'Please select at least one metric', 'error');
                return;
            }
            
            // Show loading
            Swal.fire({
                title: 'Generating Preview',
                text: 'Please wait...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });
            
            fetch('/admin/reports/preview', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ 
                    reportType, 
                    dateRange, 
                    metrics,
                    includeCharts: document.getElementById('includeCharts').checked,
                    includeTrends: document.getElementById('includeTrends').checked,
                    includeComparison: document.getElementById('includeComparison').checked,
                    reportName 
                })
            })
            .then(response => response.json())
            .then(data => {
                Swal.close();
                if (data.success) {
                    document.getElementById('previewContent').innerHTML = data.html;
                    $('#previewModal').modal('show');
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            });
        }

        // Generate custom report now
        function generateCustomReportNow() {
            const reportType = document.getElementById('customReportType').value;
            const dateRange = document.getElementById('customDateRangeSelect').value;
            const format = document.getElementById('customOutputFormat').value;
            const reportName = document.getElementById('customReportName').value;
            
            if (!reportType || !reportName) {
                Swal.fire('Error', 'Please select report type and enter report name', 'error');
                return;
            }
            
            // Build download URL
            let url = `/admin/reports/generate-custom?type=${reportType}&format=${format}&name=${encodeURIComponent(reportName)}`;
            
            // Add metrics
            const metrics = [];
            if (document.getElementById('metricRevenue').checked) metrics.push('revenue');
            if (document.getElementById('metricBookings').checked) metrics.push('bookings');
            // Add other metrics...
            
            if (metrics.length > 0) {
                url += `&metrics=${metrics.join(',')}`;
            }
            
            window.open(url, '_blank');
            
            Swal.fire({
                icon: 'success',
                title: 'Report Generated!',
                text: 'Your report is being downloaded',
                timer: 2000
            });
        }

