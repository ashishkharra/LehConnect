<%- include('../shared/partials/header', { admin : admin, title: title, data: data, currentPage:currentPage }) %>

    <% const q=data.query || {}; const currentSearch=q.search || '' ; const currentStatus=q.status || 'PENDING' ; const
        currentLimit=parseInt(q.limit) || 10; %>

        <div class="page-wrapper">
            <div class="content container-fluid">
                <div class="page-header">
                    <div class="row align-items-center">
                        <div class="col">
                            <h3 class="page-title">Account Deletion Requests</h3>
                            <ul class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                                <li class="breadcrumb-item active">Deletion Requests</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="filter-section mb-4">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="search-box">
                                <i class="ti ti-search"></i>
                                <input type="text" class="form-control" id="searchRequests"
                                    placeholder="Search by Vendor Token..." value="<%= currentSearch %>">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <select class="form-control" id="statusFilter">
                                <option value="PENDING" <%=currentStatus==='PENDING' ? 'selected' : '' %>>Pending
                                </option>
                                <option value="APPROVED" <%=currentStatus==='APPROVED' ? 'selected' : '' %>>Approved
                                </option>
                                <option value="REJECTED" <%=currentStatus==='REJECTED' ? 'selected' : '' %>>Rejected
                                </option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-12">
                        <div class="card card-table">
                            <div class="card-body">
                                <div id="tableWrapper">
                                    <%- include('../shared/partials/_delete_request_table') %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="actionModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <form action="/process-delete-request" method="POST" class="modal-content">
                    <input type="hidden" id="modalAction" name="action">
                    <input type="hidden" id="modalVendorToken" name="token">

                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Action</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p id="modalBodyText" class="fw-bold"></p>
                        <div class="form-group mt-3">
                            <label>Admin Remark (Optional)</label>
                            <textarea class="form-control" name="remark" rows="3"
                                placeholder="Enter reason for approval/rejection..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Confirm & Process</button>
                    </div>
                </form>
            </div>
        </div>

        <style>
            .pagination {
                display: flex !important;
                justify-content: center !important;
            }

            .page-item.active .page-link {
                background-color: #0061ae;
                border-color: #0061ae;
            }

            .table-avatar a {
                color: #333;
                font-weight: 600;
            }

            .table-avatar span {
                display: block;
                font-size: 11px;
                color: #888;
                font-weight: 400;
            }
        </style>

        <%- include('../shared/partials/footer') %>

            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const actionModal = document.getElementById('actionModal');

                    if (actionModal) {
                        actionModal.addEventListener('show.bs.modal', function (event) {
                            const button = event.relatedTarget;

                            const action = button.getAttribute('data-action');
                            const token = button.getAttribute('data-token');

                            document.getElementById('modalAction').value = action;
                            document.getElementById('modalVendorToken').value = token;

                            const modalBodyText = document.getElementById('modalBodyText');
                            modalBodyText.innerText = `Are you sure you want to ${action.toLowerCase()} this deletion request?`;

                            const submitBtn = this.querySelector('button[type="submit"]');
                            if (action === 'APPROVE') {
                                submitBtn.className = 'btn btn-success';
                            } else {
                                submitBtn.className = 'btn btn-danger';
                            }
                        });
                    }
                });
            </script>

            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const actionModal = new bootstrap.Modal(document.getElementById('actionModal'));
                    const tableWrapper = document.getElementById('tableWrapper');
                    let debounceTimer;

                    // --- 1. THE AJAX ENGINE ---
                    async function updateTable(params = {}) {
                        const urlParams = new URLSearchParams(window.location.search);

                        // Add loading UI state
                        tableWrapper.style.opacity = '0.5';
                        tableWrapper.style.pointerEvents = 'none';

                        // Update URL params with new values
                        Object.keys(params).forEach(key => {
                            if (params[key]) urlParams.set(key, params[key]);
                            else urlParams.delete(key);
                        });

                        // Flag for backend to send only the table partial
                        urlParams.set('partial', 'true');

                        try {
                            const response = await fetch(`${window.location.pathname}?${urlParams.toString()}`);
                            const html = await response.text();

                            // Inject new content
                            tableWrapper.innerHTML = html;

                            // Update Browser URL bar without reload
                            const cleanUrl = window.location.pathname + '?' + urlParams.toString().replace('&partial=true', '');
                            window.history.pushState({ path: cleanUrl }, '', cleanUrl);
                        } catch (error) {
                            console.error('AJAX Error:', error);
                        } finally {
                            tableWrapper.style.opacity = '1';
                            tableWrapper.style.pointerEvents = 'auto';
                        }
                    }

                    // --- 2. DYNAMIC FILTERS & SEARCH ---
                    const searchInput = document.getElementById('searchRequests');
                    if (searchInput) {
                        searchInput.addEventListener('input', (e) => {
                            clearTimeout(debounceTimer);
                            debounceTimer = setTimeout(() => {
                                updateTable({ search: e.target.value.trim(), page: 1 });
                            }, 500);
                        });
                    }

                    document.getElementById('statusFilter').addEventListener('change', (e) => {
                        updateTable({ status: e.target.value, page: 1 });
                    });

                    document.getElementById('rowLimitSelect').addEventListener('change', (e) => {
                        updateTable({ limit: e.target.value, page: 1 });
                    });

                    // --- 3. EVENT DELEGATION (For Pagination & Action Buttons) ---
                    // Since AJAX replaces the HTML, we listen on the wrapper for clicks
                    tableWrapper.addEventListener('click', function (e) {
                        // Handle Pagination
                        const pageLink = e.target.closest('.page-link');
                        if (pageLink && !pageLink.parentElement.classList.contains('disabled')) {
                            e.preventDefault();
                            const url = new URL(pageLink.href, window.location.origin);
                            updateTable({ page: url.searchParams.get('page') });
                        }

                        // Handle Action Buttons (Approve/Reject)
                        const actionBtn = e.target.closest('.action-btn');
                        if (actionBtn) {
                            window.selectedId = actionBtn.dataset.id;
                            window.selectedAction = actionBtn.dataset.action;
                            document.getElementById('modalBodyText').innerText =
                                `Are you sure you want to ${window.selectedAction.toLowerCase()} this request?`;
                            actionModal.show();
                        }
                    });

                    // --- 4. MODAL CONFIRMATION LOGIC ---
                    document.getElementById('confirmActionBtn').addEventListener('click', async function () {
                        const remark = document.getElementById('adminRemark').value;
                        const btn = this;

                        btn.disabled = true;
                        btn.innerText = "Processing...";

                        try {
                            const response = await fetch('/admin/process-delete-request', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    requestId: window.selectedId,
                                    action: window.selectedAction,
                                    remark
                                })
                            });
                            const resData = await response.json();

                            if (resData.status) {
                                actionModal.hide();
                                updateTable(); // Refresh table data dynamically after success
                            } else {
                                alert(resData.message);
                            }
                        } catch (err) {
                            console.error(err);
                            alert("An error occurred");
                        } finally {
                            btn.disabled = false;
                            btn.innerText = "Process Request";
                        }
                    });
                });
            </script>