            function rejectVendor() {
                // Show rejection modal for reason
                const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
                modal.show();
            }

            function confirmRejection() {
                const reason = document.getElementById('rejectionReason').value;
                const notes = document.getElementById('rejectionNotes').value;
                const verificationNotes = document.getElementById('verificationNotes')?.value || '';

                if (!reason) {
                    showToast('warning', 'Please select a reason for rejection');
                    return;
                }

                if (!confirm('Are you sure you want to reject this vendor?')) return;

                fetch(`/admin/vendors/<%= data.id %>/verify`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        action: 'REJECT',
                        verification_status: 'REJECTED',
                        rejection_reason: reason,
                        rejection_notes: notes,
                        notes: verificationNotes
                    })
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showToast('success', 'Vendor rejected successfully!');

                            // Send socket notification if available
                            if (typeof socket !== 'undefined') {
                                socket.emit('vendor-verified', {
                                    vendorId: '<%= data.id %>',
                                    vendorName: '<%= data.first_name %> <%= data.last_name %>',
                                    status: 'REJECTED',
                                    reason: reason,
                                    message: 'Your verification request has been rejected. Please check the reason.'
                                });
                            }

                            // Hide modal and reload page
                            const modal = bootstrap.Modal.getInstance(document.getElementById('rejectModal'));
                            modal.hide();
                            setTimeout(() => location.reload(), 2000);
                        } else {
                            showToast('error', data.message || 'Failed to reject vendor');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('error', 'An error occurred while rejecting vendor');
                    });
            }

            function revokeVerification() {
                if (!confirm('Are you sure you want to revoke this vendor\'s verification?')) return;

                fetch(`/admin/vendors/<%= data.id %>/verify`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        action: 'REVOKE',
                        verification_status: 'SUBMITTED'
                    })
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showToast('success', 'Verification revoked successfully!');
                            setTimeout(() => location.reload(), 2000);
                        } else {
                            showToast('error', data.message || 'Failed to revoke verification');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('error', 'An error occurred');
                    });
            }

            function sendReminder() {
                if (!confirm('Send reminder to vendor about verification?')) return;

                fetch(`/admin/vendors/<%= data.id %>/remind`, {
                    method: 'POST'
                })
                    .then(response => response.json())
