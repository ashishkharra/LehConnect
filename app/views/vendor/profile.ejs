    <!-- Vendor Profile Custom JS -->

    <%- include('../shared/partials/footer') %>

        <script>
            $(document).ready(function () {
                // Initialize tabs
                $('.nav-tabs a').on('click', function (e) {
                    e.preventDefault();
                    $(this).tab('show');
                });

                // Initialize tooltips
                $('[data-bs-toggle="tooltip"]').tooltip();
            });

            function verifyVendor(token, status) {
                if (confirm(`Are you sure you want to ${status === 'VERIFIED' ? 'verify' : 'reject'} this vendor?`)) {
                    $.ajax({
                        url: '/admin/verify-vendor/' + token,
                        type: 'POST',
                        data: { status: status },
                        success: function (response) {
                            if (response.success) {
                                alert(response.message);
                                location.reload();
                            } else {
                                alert('Error: ' + response.message);
                            }
                        },
                        error: function () {
                            alert('Error processing request');
                        }
                    });
                }
            }

            function updateVendorStatus(token, status) {
                const action = status === 'ACTIVE' ? 'activate' : 'deactivate';
                if (confirm(`Are you sure you want to ${action} this vendor?`)) {
                    $.ajax({
                        url: '/admin/update-vendor-status/' + token,
                        type: 'POST',
                        data: { status: status },
                        success: function (response) {
                            if (response.success) {
                                alert(response.message);
                                location.reload();
                            } else {
                                alert('Error: ' + response.message);
                            }
                        },
                        error: function () {
                            alert('Error processing request');
                        }
                    });
                }
            }

            function deleteVendor(token) {
                if (confirm('Are you sure you want to delete this vendor? This action cannot be undone.')) {
                    $.ajax({
                        url: '/admin/delete-vendor/' + token,
                        type: 'DELETE',
                        success: function (response) {
                            if (response.success) {
                                alert(response.message);
                                window.location.href = '/vendors';
                            } else {
                                alert('Error: ' + response.message);
                            }
                        },
                        error: function () {
                            alert('Error processing request');
                        }
                    });
                }
            }

            function sendNotification(token) {
                const message = prompt('Enter notification message for the vendor:');
                if (message) {
                    $.ajax({
                        url: '/admin/send-vendor-notification/' + token,
                        type: 'POST',
                        data: { message: message },
                        success: function (response) {
                            if (response.success) {
                                alert('Notification sent successfully');
                            } else {
                                alert('Error: ' + response.message);
                            }
                        },
                        error: function () {
                            alert('Error sending notification');
                        }
                    });
                }
            }

            function resetPassword(token) {
                if (confirm('Are you sure you want to reset this vendor\'s password? A new password will be generated and sent to their email.')) {
                    $.ajax({
                        url: '/admin/reset-vendor-password/' + token,
                        type: 'POST',
                        success: function (response) {
                            if (response.success) {
                                alert('Password reset successfully. New password has been sent to vendor\'s email.');
                            } else {
                                alert('Error: ' + response.message);
                            }
                        },
                        error: function () {
                            alert('Error processing request');
                        }
                    });
                }
            }
        </script>