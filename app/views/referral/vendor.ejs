<%- include('../shared/partials/header', { admin : admin, title: title }) %>

    <!-- Page Content -->
    <div class="page-wrapper">
        <div class="content container-fluid">
            <!-- Page Header -->
            <div class="page-header">
                <div class="row align-items-center">
                    <div class="col-sm-6">
                        <h3 class="page-title">Vendor Referral Management</h3>

                    </div>
                    <div class="col-sm-6 text-end">
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#inviteVendorModal">
                            <i class="ti ti-mail me-2"></i>Invite Vendor
                        </button>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="row">
                <div class="col-xl-3 col-sm-6 col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="dash-widget-header">
                                <span class="dash-widget-icon bg-primary">
                                    <i class="ti ti-building-store"></i>
                                </span>
                                <div class="dash-widget-info text-end">
                                    <h3>
                                        <%= data?.stats?.vendorReferrals || 0 %>
                                    </h3>
                                    <h6 class="text-muted">Vendors Referred</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-sm-6 col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="dash-widget-header">
                                <span class="dash-widget-icon bg-success">
                                    <i class="ti ti-currency-rupee"></i>
                                </span>
                                <div class="dash-widget-info text-end">
                                    <h3>₹<%= data?.stats?.lifetimeEarnings ?
                                            stats.lifetimeEarnings.toLocaleString('en-IN') : 0 %>
                                    </h3>
                                    <h6 class="text-muted">Lifetime Earnings</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-sm-6 col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="dash-widget-header">
                                <span class="dash-widget-icon bg-warning">
                                    <i class="ti ti-chart-bar"></i>
                                </span>
                                <div class="dash-widget-info text-end">
                                    <h3>
                                        <%= data?.stats?.activeVendors || 0 %>
                                    </h3>
                                    <h6 class="text-muted">Active Referrers</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-sm-6 col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="dash-widget-header">
                                <span class="dash-widget-icon bg-info">
                                    <i class="ti ti-trending-up"></i>
                                </span>
                                <div class="dash-widget-info text-end">
                                    <h3>
                                        <%= data?.stats?.commissionRate ? stats.commissionRate + '%' : '0%' %>
                                    </h3>
                                    <h6 class="text-muted">Commission Rate</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header bg-primary-light">
                            <h5 class="card-title text-primary"><i class="ti ti-settings me-2"></i>Referral Allocation
                                Settings</h5>
                        </div>
                        <div class="card-body">
                            <form id="referralSettingsForm" action="/update-referral" method="POST">
                                <div class="row">

                                    <!-- Referrer Bonus -->
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Referrer Bonus (₹)</label>
                                            <div class="input-group">
                                                <span class="input-group-text">₹</span>
                                                <input type="number" name="referrer_bonus" class="form-control" required
                                                    min="0" value="<%= data?.settings?.referrer_bonus || 500 %>">
                                            </div>
                                            <small class="text-muted">
                                                Amount earned by the vendor who refers another vendor.
                                            </small>
                                        </div>
                                    </div>

                                    <!-- Referee Bonus -->
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Referee Bonus (₹)</label>
                                            <div class="input-group">
                                                <span class="input-group-text">₹</span>
                                                <input type="number" name="referee_bonus" class="form-control" required
                                                    min="0" value="<%= data?.settings?.referee_bonus || 250 %>">
                                            </div>
                                            <small class="text-muted">
                                                Bonus credited to the newly joined vendor.
                                            </small>
                                        </div>
                                    </div>

                                </div>

                                <div class="text-end mt-3">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="ti ti-device-floppy me-2"></i>Save Referral Settings
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-sm-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Referral History</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-center table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Referrer (Inviter)</th>
                                            <th>Referee (New Joiner)</th>
                                            <th>Referrer Earns</th>
                                            <th>Referee Gets</th>
                                            <th>Status</th>
                                            <th>Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (data.history && data.history.length> 0) { %>
                                            <% data.history.forEach(item=> { %>
                                                <tr>
                                                    <td>
                                                        <h2 class="table-avatar">
                                                            <a href="#" class="avatar avatar-sm me-2">
                                                                <img class="avatar-img rounded-circle"
                                                                    src="<%= item.Referrer?.profile_image || '/assets/img/profiles/avatar-01.jpg' %>"
                                                                    alt="User Image">
                                                            </a>
                                                            <a href="#">
                                                                <%= item.Referrer?.first_name %>
                                                                    <%= item.Referrer?.last_name %>
                                                                        <span class="d-block text-muted">
                                                                            <%= item.Referrer?.email %>
                                                                        </span>
                                                            </a>
                                                        </h2>
                                                    </td>

                                                    <td>
                                                        <h2 class="table-avatar">
                                                            <a href="#" class="avatar avatar-sm me-2">
                                                                <img class="avatar-img rounded-circle"
                                                                    src="<%= item.Referee?.profile_image || '/assets/img/profiles/avatar-02.jpg' %>"
                                                                    alt="User Image">
                                                            </a>
                                                            <a href="#">
                                                                <%= item.Referee?.first_name %>
                                                                    <%= item.Referee?.last_name %>
                                                                        <span class="d-block text-muted">
                                                                            <%= item.Referee?.email %>
                                                                        </span>
                                                            </a>
                                                        </h2>
                                                    </td>

                                                    <td class="text-success fw-bold">₹<%= item.referrer_amount %>
                                                    </td>
                                                    <td class="text-info fw-bold">₹<%= item.referee_amount %>
                                                    </td>

                                                    <td>
                                                        <% if(item.status==='PAID' ) { %>
                                                            <span class="badge bg-success">Paid</span>
                                                            <% } else { %>
                                                                <span class="badge bg-warning">Pending</span>
                                                                <% } %>
                                                    </td>

                                                    <td>
                                                        <%= new Date(item.createdAt).toLocaleDateString() %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="6" class="text-center text-muted">No referrals
                                                                recorded yet.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <% if (data.pagination && data.pagination.totalPages> 1) { %>
                <nav class="mt-3">
                    <ul class="pagination justify-content-end">

                        <!-- Prev -->
                        <li class="page-item <%= data.pagination.page === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= data.pagination.page - 1 %>">
                                Previous
                            </a>
                        </li>

                        <% for (let i=1; i <=data.pagination.totalPages; i++) { %>
                            <li class="page-item <%= i === data.pagination.page ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= i %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } %>

                                <!-- Next -->
                                <li
                                    class="page-item <%= data.pagination.page === data.pagination.totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= data.pagination.page + 1 %>">
                                        Next
                                    </a>
                                </li>

                    </ul>
                </nav>
                <% } %>


        </div>
    </div>

    <!-- Invite Vendor Modal -->
    <div class="modal fade" id="inviteVendorModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Invite Vendor to Join</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="inviteVendorForm">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Vendor Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="vendor_name" required
                                        placeholder="Business name">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Contact Person <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="contact_person" required
                                        placeholder="Contact person name">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Email Address <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control" name="email" required
                                        placeholder="vendor@example.com">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Phone Number <span class="text-danger">*</span></label>
                                    <input type="tel" class="form-control" name="phone" required
                                        placeholder="+91 9876543210">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Business Type</label>
                                    <select class="form-select" name="business_type">
                                        <option value="">Select Type</option>
                                        <option value="Taxi Service">Taxi Service</option>
                                        <option value="Hotel">Hotel</option>
                                        <option value="Travel Agency">Travel Agency</option>
                                        <option value="Restaurant">Restaurant</option>
                                        <option value="Tour Guide">Tour Guide</option>
                                        <option value="Adventure Sports">Adventure Sports</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Location</label>
                                    <input type="text" class="form-control" name="location" placeholder="City, State">
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label">Personal Message (Optional)</label>
                                    <textarea class="form-control" name="message" rows="3"
                                        placeholder="Add a personal invitation message..."></textarea>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="alert alert-info">
                                    <h6><i class="ti ti-info-circle me-2"></i>Benefits for the Vendor</h6>
                                    <ul class="mb-0 small">
                                        <li>Free listing on Leh Connect platform</li>
                                        <li>Access to thousands of customers</li>
                                        <li>Easy booking management system</li>
                                        <li>Secure payment processing</li>
                                        <li>Marketing and promotional support</li>
                                        <li>First month commission-free for referrals</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Send Invitation</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    </div>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    <%- include('../shared/partials/footer') %>