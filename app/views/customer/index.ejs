    <!-- Customer Management Custom JS -->
    <script>
        $(document).ready(function() {
            // Initialize Select2
            $('.select2').select2({
                width: '100%'
            });

            // Initialize Date Range Picker
            $('#dateRange').daterangepicker({
                opens: 'left',
                locale: {
                    format: 'YYYY-MM-DD'
                }
            });

            // Search functionality
            $('#searchInput').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('#customersTable tbody tr').filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // Filter functionality
            $('#applyFilter').on('click', function() {
                applyFilters();
            });

            // Clear filters
            $('#clearFilters').on('click', function() {
                $('#searchInput').val('');
                $('#statusFilter').val('').trigger('change');
                $('#locationFilter').val('').trigger('change');
                $('#serviceFilter').val('').trigger('change');
                $('#dateRange').val('');
                $('#customersTable tbody tr').show();
            });

            // Export functionality
            $('#exportCustomers').on('click', function() {
                alert('Exporting customer data to CSV (demo)');
            });

            // Generate report
            $('#exportReport').on('click', function() {
                alert('Generating customer analytics report (demo)');
            });

            // Bulk message modal
            $('#sendBulkMessage').on('click', function() {
                $('#bulkMessageModal').modal('show');
            });

            // Customer action buttons
            $('.btn-outline-success[title="Send Message"]').on('click', function(e) {
                e.preventDefault();
                var customerName = $(this).closest('tr').find('h6').text();
                alert('Send message to: ' + customerName + ' (demo)');
            });

            $('.btn-outline-danger[title="Block"]').on('click', function(e) {
                e.preventDefault();
                var customerName = $(this).closest('tr').find('h6').text();
                if (confirm('Block customer: ' + customerName + '?')) {
                    alert('Customer blocked (demo)');
                }
            });

            $('.btn-outline-success[title="Unblock"]').on('click', function(e) {
                e.preventDefault();
                var customerName = $(this).closest('tr').find('h6').text();
                if (confirm('Unblock customer: ' + customerName + '?')) {
                    alert('Customer unblocked (demo)');
                }
            });

            // Apply filters function
            function applyFilters() {
                var status = $('#statusFilter').val();
                var location = $('#locationFilter').val();
                var service = $('#serviceFilter').val();
                var searchTerm = $('#searchInput').val().toLowerCase();
                
                $('#customersTable tbody tr').each(function() {
                    var row = $(this);
                    var rowStatus = row.find('td:nth-child(8) .badge').first().text().toLowerCase();
                    var rowLocation = row.find('td:nth-child(4) .badge').text().toLowerCase();
                    var rowServices = row.find('td:nth-child(5)').text().toLowerCase();
                    var rowText = row.text().toLowerCase();
                    
                    var show = true;
                    
                    if (status && !rowStatus.includes(status)) {
                        show = false;
                    }
                    
                    if (location && !rowLocation.includes(location)) {
                        show = false;
                    }
                    
                    if (service && !rowServices.includes(service)) {
                        show = false;
                    }
                    
                    if (searchTerm && rowText.indexOf(searchTerm) === -1) {
                        show = false;
                    }
                    
                    if (show) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Quick filter buttons
            $('.btn-outline-primary.btn-sm').on('click', function() {
                $('.btn-outline-primary.btn-sm').removeClass('active');
                $(this).addClass('active');
                
                var filterType = $(this).text().trim();
                $('#customersTable tbody tr').each(function() {
                    var row = $(this);
                    var show = true;
                    
                    switch(filterType) {
                        case 'High Value':
                            var spend = parseFloat(row.find('td:nth-child(7) h6').text().replace('₹', '').replace(',', ''));
                            show = spend > 100000;
                            break;
                        case 'Frequent Travelers':
                            var bookings = parseInt(row.find('td:nth-child(6) h6').text());
                            show = bookings > 5;
                            break;
                        case 'New Customers':
                            var joinDate = row.find('td:nth-child(2) .text-muted.small').first().text();
                            show = joinDate.includes('2024') && (joinDate.includes('Apr') || joinDate.includes('May'));
                            break;
                        case 'VIP Customers':
                            var badges = row.find('td:nth-child(8) .badge').text();
                            show = badges.includes('VIP') || badges.includes('Premium');
                            break;
                        case 'All Customers':
                            show = true;
                            break;
                    }
                    
                    if (show) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            });
        });
    </script>
