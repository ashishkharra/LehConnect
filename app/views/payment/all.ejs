<%- include('../shared/partials/header', { admin : admin, title: title}) %>
        <!-- Page Content -->
        <div class="page-wrapper">
            <div class="content container-fluid">
                <!-- Page Header -->
                <div class="page-header">
                    <div class="row align-items-center">
                        <div class="col-sm-6">
                            <h3 class="page-title">All Payments Ledger</h3>
                        </div>
                        <div class="col-sm-6 text-end">
                            <div class="btn-group">
                                <button class="btn btn-primary" onclick="showAdvancedFilters()">
                                    <i class="ti ti-filter me-2"></i>Advanced Filters
                                </button>
                                <button class="btn btn-success" onclick="showBulkActions()">
                                    <i class="ti ti-settings me-2"></i>Bulk Actions
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Summary Cards -->
                <div class="row">
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="dash-widget-header">
                                    <span class="dash-widget-icon bg-primary">
                                        <i class="ti ti-currency-rupee"></i>
                                    </span>
                                    <div class="dash-widget-info text-end">
                                        <h3>₹<%= summary.totalAmount ? summary.totalAmount.toLocaleString('en-IN') : 0 %></h3>
                                        <h6 class="text-muted">Total Volume</h6>
                                    </div>
                                </div>
                                <div class="dash-widget-footer">
                                    <span class="text-success"><%= summary.totalCount || 0 %> transactions</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="dash-widget-header">
                                    <span class="dash-widget-icon bg-success">
                                        <i class="ti ti-trending-up"></i>
                                    </span>
                                    <div class="dash-widget-info text-end">
                                        <h3>₹<%= summary.monthlyAmount ? summary.monthlyAmount.toLocaleString('en-IN') : 0 %></h3>
                                        <h6 class="text-muted">This Month</h6>
                                    </div>
                                </div>
                                <div class="dash-widget-footer">
                                    <span class="text-success"><%= summary.monthlyCount || 0 %> transactions</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="dash-widget-header">
                                    <span class="dash-widget-icon bg-warning">
                                        <i class="ti ti-clock"></i>
                                    </span>
                                    <div class="dash-widget-info text-end">
                                        <h3>₹<%= summary.pendingAmount ? summary.pendingAmount.toLocaleString('en-IN') : 0 %></h3>
                                        <h6 class="text-muted">Pending</h6>
                                    </div>
                                </div>
                                <div class="dash-widget-footer">
                                    <span class="text-warning"><%= summary.pendingCount || 0 %> pending</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-sm-6 col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="dash-widget-header">
                                    <span class="dash-widget-icon bg-info">
                                        <i class="ti ti-refund"></i>
                                    </span>
                                    <div class="dash-widget-info text-end">
                                        <h3>₹<%= summary.refundAmount ? summary.refundAmount.toLocaleString('en-IN') : 0 %></h3>
                                        <h6 class="text-muted">Refunds</h6>
                                    </div>
                                </div>
                                <div class="dash-widget-footer">
                                    <span class="text-info"><%= summary.refundCount || 0 %> refunds</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Date Range & Quick Filters -->
                <div class="date-range-picker">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">From Date</label>
                                <input type="date" class="form-control" id="fromDate" 
                                       value="<%= defaultFromDate %>">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">To Date</label>
                                <input type="date" class="form-control" id="toDate" 
                                       value="<%= defaultToDate %>">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Quick Range</label>
                                <select class="form-select" id="quickRange" onchange="applyQuickRange(this.value)">
                                    <option value="">Custom Range</option>
                                    <option value="today">Today</option>
                                    <option value="yesterday">Yesterday</option>
                                    <option value="week">This Week</option>
                                    <option value="month">This Month</option>
                                    <option value="last_month">Last Month</option>
                                    <option value="quarter">This Quarter</option>
                                    <option value="year">This Year</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3 d-flex align-items-end" style="height: 100%;">
                                <button class="btn btn-primary w-100" onclick="applyDateFilter()">
                                    <i class="ti ti-filter me-2"></i>Apply Filter
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Advanced Filters -->
                <div class="advanced-filters" id="advancedFilters">
                    <h6 class="mb-3">Advanced Filters</h6>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Transaction Type</label>
                                <select class="form-select" id="filterTransactionType" multiple>
                                    <option value="booking_payment">Booking Payment</option>
                                    <option value="vendor_payout">Vendor Payout</option>
                                    <option value="customer_refund">Customer Refund</option>
                                    <option value="commission">Commission</option>
                                    <option value="subscription">Subscription</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Payment Method</label>
                                <select class="form-select" id="filterPaymentMethod" multiple>
                                    <option value="upi">UPI</option>
                                    <option value="credit_card">Credit Card</option>
                                    <option value="debit_card">Debit Card</option>
                                    <option value="netbanking">Net Banking</option>
                                    <option value="wallet">Wallet</option>
                                    <option value="cash">Cash</option>
                                    <option value="bank_transfer">Bank Transfer</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Status</label>
                                <select class="form-select" id="filterStatus" multiple>
                                    <option value="success">Success</option>
                                    <option value="pending">Pending</option>
                                    <option value="failed">Failed</option>
                                    <option value="refunded">Refunded</option>
                                    <option value="cancelled">Cancelled</option>
                                    <option value="disputed">Disputed</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Amount Range (₹)</label>
                                <div class="row">
                                    <div class="col-6">
                                        <input type="number" class="form-control" id="minAmount" 
                                               placeholder="Min">
                                    </div>
                                    <div class="col-6">
                                        <input type="number" class="form-control" id="maxAmount" 
                                               placeholder="Max">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">User Search</label>
                                <input type="text" class="form-control" id="userSearch" 
                                       placeholder="Search by user name, email, or phone">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Transaction ID</label>
                                <input type="text" class="form-control" id="transactionIdSearch" 
                                       placeholder="Search by transaction ID">
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex justify-content-between">
                                <button class="btn btn-secondary" onclick="clearAdvancedFilters()">
                                    <i class="ti ti-x me-2"></i>Clear All
                                </button>
                                <button class="btn btn-primary" onclick="applyAdvancedFilters()">
                                    <i class="ti ti-check me-2"></i>Apply Filters
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Left Column: Analytics & Charts -->
                    <div class="col-lg-4">
                        <!-- Income vs Expense Summary -->
                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title">Income vs Expense</h5>
                            </div>
                            <div class="card-body">
                                <div class="summary-widget income">
                                    <h4 class="text-success">₹<%= analytics.income ? analytics.income.toLocaleString('en-IN') : 0 %></h4>
                                    <p class="mb-0">Total Income</p>
                                </div>
                                <div class="summary-widget expense">
                                    <h4 class="text-danger">₹<%= analytics.expense ? analytics.expense.toLocaleString('en-IN') : 0 %></h4>
                                    <p class="mb-0">Total Expense</p>
                                </div>
                                <div class="summary-widget net">
                                    <h4 class="text-primary">₹<%= analytics.net ? analytics.net.toLocaleString('en-IN') : 0 %></h4>
                                    <p class="mb-0">Net Balance</p>
                                </div>
                            </div>
                        </div>

                        <!-- Payment Methods Distribution -->
                        <div class="card mt-4">
                            <div class="card-header">
                                <h5 class="card-title">Payment Methods</h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="paymentMethodsChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Transaction Status Overview -->
                        <div class="card mt-4">
                            <div class="card-header">
                                <h5 class="card-title">Status Overview</h5>
                            </div>
                            <div class="card-body">
                                <% if (statusOverview && statusOverview.length > 0) { %>
                                    <% statusOverview.forEach(status => { %>
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="flex-shrink-0">
                                                <span class="badge bg-<%= getStatusColor(status.status) %> me-2">
                                                    <%= status.status.charAt(0).toUpperCase() + status.status.slice(1) %>
                                                </span>
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="progress" style="height: 8px;">
                                                    <div class="progress-bar bg-<%= getStatusColor(status.status) %>" 
                                                         style="width: <%= status.percentage %>%;"></div>
                                                </div>
                                            </div>
                                            <div class="flex-shrink-0 ms-3 text-end">
                                                <h6 class="mb-0">₹<%= status.amount %></h6>
                                                <small class="text-muted"><%= status.count %> transactions</small>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="text-center py-3">
                                        <p class="text-muted">No status data available</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Quick Export Options -->
                        <div class="card mt-4">
                            <div class="card-header">
                                <h5 class="card-title">Quick Export</h5>
                            </div>
                            <div class="card-body">
                                <div class="export-buttons">
                                    <button class="btn btn-outline-success" onclick="exportCurrentView('excel')">
                                        <i class="ti ti-file-spreadsheet me-2"></i>Excel
                                    </button>
                                    <button class="btn btn-outline-primary" onclick="exportCurrentView('pdf')">
                                        <i class="ti ti-file-invoice me-2"></i>PDF
                                    </button>
                                    <button class="btn btn-outline-secondary" onclick="exportCurrentView('csv')">
                                        <i class="ti ti-file-text me-2"></i>CSV
                                    </button>
                                    <button class="btn btn-outline-info" onclick="exportCurrentView('json')">
                                        <i class="ti ti-code me-2"></i>JSON
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Transactions Table -->
                    <div class="col-lg-8">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title">All Transactions</h5>
                                <div class="card-action">
                                    <div class="input-group" style="width: 250px;">
                                        <input type="text" class="form-control" placeholder="Search..." 
                                               id="searchAllTransactions" onkeyup="searchAllTransactions()">
                                        <button class="btn btn-outline-secondary" type="button">
                                            <i class="ti ti-search"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <!-- Table Controls -->
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="showOnlyUnsettled"
                                                   onchange="toggleUnsettledView()">
                                            <label class="form-check-label" for="showOnlyUnsettled">
                                                Show only unsettled
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <select class="form-select" id="sortBy" onchange="sortTransactions()">
                                            <option value="newest">Newest First</option>
                                            <option value="oldest">Oldest First</option>
                                            <option value="amount_high">Amount (High to Low)</option>
                                            <option value="amount_low">Amount (Low to High)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <span class="text-muted">
                                            Showing <%= startIndex + 1 %>-<%= endIndex %> of <%= totalCount %> transactions
                                        </span>
                                    </div>
                                </div>

                                <!-- Transactions Table -->
                                <div class="table-responsive">
                                    <table class="table table-hover table-center mb-0" id="allTransactionsTable">
                                        <thead>
                                            <tr>
                                                <th>Date</th>
                                                <th>Transaction ID</th>
                                                <th>User</th>
                                                <th>Type</th>
                                                <th>Amount</th>
                                                <th>Method</th>
                                                <th>Status</th>
                                                <th>Settled</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (transactions && transactions.length > 0) { %>
                                                <% transactions.forEach(txn => { %>
                                                    <tr data-id="<%= txn.id %>" 
                                                        data-settled="<%= txn.settled_at ? 'true' : 'false' %>">
                                                        <td>
                                                            <strong><%= new Date(txn.created_at).toLocaleDateString() %></strong>
                                                            <br>
                                                            <small class="text-muted">
                                                                <%= new Date(txn.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                                            </small>
                                                        </td>
                                                        <td>
                                                            <code><%= txn.transaction_id %></code>
                                                            <% if (txn.gateway_transaction_id) { %>
                                                                <br>
                                                                <small class="text-muted" title="Gateway ID">
                                                                    <%= txn.gateway_transaction_id.substring(0, 10) %>...
                                                                </small>
                                                            <% } %>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex align-items-center">
                                                                <div class="avatar avatar-sm me-2">
                                                                    <img src="<%= txn.user_avatar || 'assets/img/profiles/avatar-02.jpg' %>" 
                                                                         class="rounded-circle" alt="User">
                                                                </div>
                                                                <div>
                                                                    <h6 class="mb-0"><%= txn.user_name %></h6>
                                                                    <small class="text-muted">
                                                                        <%= txn.user_type.charAt(0).toUpperCase() + txn.user_type.slice(1) %>
                                                                    </small>
                                                                    <% if (txn.user_email) { %>
                                                                        <br>
                                                                        <small class="text-muted"><%= txn.user_email %></small>
                                                                    <% } %>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-<%= getTypeColor(txn.transaction_type) %>">
                                                                <%= getTypeName(txn.transaction_type) %>
                                                            </span>
                                                            <% if (txn.booking_id) { %>
                                                                <br>
                                                                <small class="text-muted">
                                                                    Booking #<%= txn.booking_id %>
                                                                </small>
                                                            <% } %>
                                                        </td>
                                                        <td>
                                                            <h6 class="<%= txn.amount > 0 ? 'text-success' : 'text-danger' %> mb-0">
                                                                <%= txn.amount > 0 ? '+' : '' %>₹<%= Math.abs(txn.amount).toLocaleString('en-IN') %>
                                                            </h6>
                                                            <small class="text-muted"><%= txn.currency %></small>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex align-items-center">
                                                                <i class="ti <%= getMethodIcon(txn.payment_method) %> me-2"></i>
                                                                <span><%= getMethodName(txn.payment_method) %></span>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-<%= getStatusColor(txn.status) %>">
                                                                <%= txn.status.charAt(0).toUpperCase() + txn.status.slice(1) %>
                                                            </span>
                                                            <% if (txn.status === 'failed') { %>
                                                                <br>
                                                                <small class="text-danger">Retry available</small>
                                                            <% } %>
                                                        </td>
                                                        <td>
                                                            <% if (txn.settled_at) { %>
                                                                <span class="badge bg-success">
                                                                    <i class="ti ti-check me-1"></i>Settled
                                                                </span>
                                                                <br>
                                                                <small class="text-muted">
                                                                    <%= new Date(txn.settled_at).toLocaleDateString() %>
                                                                </small>
                                                            <% } else { %>
                                                                <span class="badge bg-warning">
                                                                    <i class="ti ti-clock me-1"></i>Pending
                                                                </span>
                                                                <br>
                                                                <button class="btn btn-sm btn-link p-0" 
                                                                        onclick="markAsSettled('<%= txn.id %>')">
                                                                    Mark as settled
                                                                </button>
                                                            <% } %>
                                                        </td>
                                                        <td>
                                                            <div class="actions">
                                                                <a href="javascript:void(0);" class="btn btn-sm bg-info-light me-2" 
                                                                   onclick="viewTransactionDetails('<%= txn.id %>')">
                                                                    <i class="ti ti-eye"></i>
                                                                </a>
                                                                <div class="dropdown">
                                                                    <a href="javascript:void(0);" class="btn btn-sm bg-primary-light" 
                                                                       data-bs-toggle="dropdown">
                                                                        <i class="ti ti-dots-vertical"></i>
                                                                    </a>
                                                                    <div class="dropdown-menu">
                                                                        <a class="dropdown-item" href="javascript:void(0);"
                                                                           onclick="editTransaction('<%= txn.id %>')">
                                                                            <i class="ti ti-pencil me-2"></i>Edit
                                                                        </a>
                                                                        <% if (txn.status === 'success' && !txn.settled_at) { %>
                                                                            <a class="dropdown-item" href="javascript:void(0);"
                                                                               onclick="markAsSettled('<%= txn.id %>')">
                                                                                <i class="ti ti-check me-2"></i>Mark as Settled
                                                                            </a>
                                                                        <% } %>
                                                                        <% if (txn.status === 'failed') { %>
                                                                            <a class="dropdown-item" href="javascript:void(0);"
                                                                               onclick="retryTransaction('<%= txn.id %>')">
                                                                                <i class="ti ti-refresh me-2"></i>Retry
                                                                            </a>
                                                                        <% } %>
                                                                        <% if (txn.status === 'success' && txn.transaction_type === 'booking_payment') { %>
                                                                            <a class="dropdown-item" href="javascript:void(0);"
                                                                               onclick="initiateRefund('<%= txn.id %>')">
                                                                                <i class="ti ti-refund me-2"></i>Refund
                                                                            </a>
                                                                        <% } %>
                                                                        <div class="dropdown-divider"></div>
                                                                        <a class="dropdown-item text-danger" href="javascript:void(0);"
                                                                           onclick="deleteTransaction('<%= txn.id %>')">
                                                                            <i class="ti ti-trash me-2"></i>Delete
                                                                        </a>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="9" class="text-center">
                                                        <div class="empty-state">
                                                            <i class="ti ti-receipt fs-48 text-muted mb-3"></i>
                                                            <h5>No transactions found</h5>
                                                            <p class="text-muted">Try adjusting your filters</p>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Pagination -->
                                <div class="row mt-3">
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-center">
                                            <span class="text-muted me-3">Show:</span>
                                            <select class="form-select form-select-sm" style="width: auto;" 
                                                    onchange="changePageSize(this.value)">
                                                <option value="10" <%= pageSize === 10 ? 'selected' : '' %>>10</option>
                                                <option value="25" <%= pageSize === 25 ? 'selected' : '' %>>25</option>
                                                <option value="50" <%= pageSize === 50 ? 'selected' : '' %>>50</option>
                                                <option value="100" <%= pageSize === 100 ? 'selected' : '' %>>100</option>
                                            </select>
                                            <span class="text-muted ms-3">entries per page</span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <nav aria-label="Page navigation" class="pagination-custom">
                                            <ul class="pagination justify-content-end mb-0">
                                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                                    <a class="page-link" href="?page=<%= currentPage - 1 %>&size=<%= pageSize %>">
                                                        Previous
                                                    </a>
                                                </li>
                                                
                                                <% for(let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                                        <a class="page-link" href="?page=<%= i %>&size=<%= pageSize %>">
                                                            <%= i %>
                                                        </a>
                                                    </li>
                                                <% } %>
                                                
                                                <% if (currentPage + 2 < totalPages) { %>
                                                    <li class="page-item disabled">
                                                        <span class="page-link">...</span>
                                                    </li>
                                                    <li class="page-item">
                                                        <a class="page-link" href="?page=<%= totalPages %>&size=<%= pageSize %>">
                                                            <%= totalPages %>
                                                        </a>
                                                    </li>
                                                <% } %>
                                                
                                                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                    <a class="page-link" href="?page=<%= currentPage + 1 %>&size=<%= pageSize %>">
                                                        Next
                                                    </a>
                                                </li>
                                            </ul>
                                        </nav>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Monthly Trend Chart -->
                        <div class="card mt-4">
                            <div class="card-header">
                                <h5 class="card-title">Monthly Transaction Trend</h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="monthlyTrendChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bulk Actions Modal -->
        <div class="modal fade" id="bulkActionsModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Bulk Actions</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Select Action</label>
                            <select class="form-select" id="bulkActionType">
                                <option value="">Choose action...</option>
                                <option value="export">Export Selected</option>
                                <option value="settle">Mark as Settled</option>
                                <option value="status">Change Status</option>
                                <option value="reconcile">Mark for Reconciliation</option>
                                <option value="delete">Delete Transactions</option>
                            </select>
                        </div>
                        
                        <div id="bulkActionOptions" style="display: none;">
                            <!-- Export Options -->
                            <div id="exportOptions" class="action-options">
                                <div class="mb-3">
                                    <label class="form-label">Export Format</label>
                                    <select class="form-select" id="bulkExportFormat">
                                        <option value="excel">Excel</option>
                                        <option value="csv">CSV</option>
                                        <option value="pdf">PDF</option>
                                    </select>
                                </div>
                            </div>
                            
                            <!-- Status Change Options -->
                            <div id="statusOptions" class="action-options" style="display: none;">
                                <div class="mb-3">
                                    <label class="form-label">New Status</label>
                                    <select class="form-select" id="newStatus">
                                        <option value="success">Success</option>
                                        <option value="pending">Pending</option>
                                        <option value="failed">Failed</option>
                                        <option value="refunded">Refunded</option>
                                        <option value="cancelled">Cancelled</option>
                                    </select>
                                </div>
                            </div>
                            
                            <!-- Settlement Options -->
                            <div id="settleOptions" class="action-options" style="display: none;">
                                <div class="mb-3">
                                    <label class="form-label">Settlement Date</label>
                                    <input type="date" class="form-control" id="bulkSettlementDate" 
                                           value="<%= new Date().toISOString().split('T')[0] %>">
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-info mt-3">
                            <i class="ti ti-info-circle me-2"></i>
                            This action will apply to all transactions matching current filters
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" onclick="executeBulkAction()">Execute</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        // Initialize charts
        document.addEventListener('DOMContentLoaded', function() {
            // Payment Methods Chart
            const methodsCtx = document.getElementById('paymentMethodsChart').getContext('2d');
            new Chart(methodsCtx, {
                type: 'doughnut',
                data: {
                    labels: <%= JSON.stringify(methodLabels || []) %>,
                    datasets: [{
                        data: <%= JSON.stringify(methodData || []) %>,
                        backgroundColor: [
                            '#667eea', '#28a745', '#17a2b8', '#ffc107', 
                            '#dc3545', '#6c757d', '#20c997'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

            // Monthly Trend Chart
            const trendCtx = document.getElementById('monthlyTrendChart').getContext('2d');
            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: <%= JSON.stringify(monthlyLabels || []) %>,
                    datasets: [
                        {
                            label: 'Income',
                            data: <%= JSON.stringify(monthlyIncome || []) %>,
                            borderColor: '#28a745',
                            backgroundColor: 'rgba(40, 167, 69, 0.1)',
                            tension: 0.4,
                            fill: true
                        },
                        {
                            label: 'Expense',
                            data: <%= JSON.stringify(monthlyExpense || []) %>,
                            borderColor: '#dc3545',
                            backgroundColor: 'rgba(220, 53, 69, 0.1)',
                            tension: 0.4,
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '₹' + value.toLocaleString();
                                }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ₹' + context.parsed.y.toLocaleString();
                                }
                            }
                        }
                    }
                }
            });
        });

        // Helper functions (same as today's page)
        function getMethodColor(method) { /* ... */ }
        function getMethodIcon(method) { /* ... */ }
        function getMethodName(method) { /* ... */ }
        function getStatusColor(status) { /* ... */ }
        function getTypeColor(type) { /* ... */ }
        function getTypeName(type) { /* ... */ }

        // Show/hide advanced filters
        function showAdvancedFilters() {
            const filters = document.getElementById('advancedFilters');
            filters.style.display = filters.style.display === 'none' ? 'block' : 'none';
        }

        // Apply date filter
        function applyDateFilter() {
            const fromDate = document.getElementById('fromDate').value;
            const toDate = document.getElementById('toDate').value;
            
            if (!fromDate || !toDate) {
                Swal.fire('Error', 'Please select both dates', 'error');
                return;
            }
            
            window.location.href = `?from=${fromDate}&to=${toDate}&page=1`;
        }

        // Apply quick range
        function applyQuickRange(range) {
            let fromDate, toDate;
            const today = new Date();
            
            switch(range) {
                case 'today':
                    fromDate = toDate = today.toISOString().split('T')[0];
                    break;
                case 'yesterday':
                    const yesterday = new Date(today);
                    yesterday.setDate(yesterday.getDate() - 1);
                    fromDate = toDate = yesterday.toISOString().split('T')[0];
                    break;
                case 'week':
                    const weekStart = new Date(today);
                    weekStart.setDate(weekStart.getDate() - weekStart.getDay());
                    fromDate = weekStart.toISOString().split('T')[0];
                    toDate = today.toISOString().split('T')[0];
                    break;
                case 'month':
                    fromDate = new Date(today.getFullYear(), today.getMonth(), 1)
                        .toISOString().split('T')[0];
                    toDate = today.toISOString().split('T')[0];
                    break;
                case 'last_month':
                    const lastMonth = new Date(today.getFullYear(), today.getMonth() - 1, 1);
                    fromDate = lastMonth.toISOString().split('T')[0];
                    toDate = new Date(today.getFullYear(), today.getMonth(), 0)
                        .toISOString().split('T')[0];
                    break;
                case 'quarter':
                    const quarter = Math.floor(today.getMonth() / 3);
                    fromDate = new Date(today.getFullYear(), quarter * 3, 1)
                        .toISOString().split('T')[0];
                    toDate = today.toISOString().split('T')[0];
                    break;
                case 'year':
                    fromDate = new Date(today.getFullYear(), 0, 1)
                        .toISOString().split('T')[0];
                    toDate = today.toISOString().split('T')[0];
                    break;
                default:
                    return;
            }
            
            document.getElementById('fromDate').value = fromDate;
            document.getElementById('toDate').value = toDate;
            document.getElementById('quickRange').value = range;
        }

        // Apply advanced filters
        function applyAdvancedFilters() {
            const transactionTypes = Array.from(document.getElementById('filterTransactionType').selectedOptions)
                                        .map(opt => opt.value);
            const paymentMethods = Array.from(document.getElementById('filterPaymentMethod').selectedOptions)
                                      .map(opt => opt.value);
            const statuses = Array.from(document.getElementById('filterStatus').selectedOptions)
                                .map(opt => opt.value);
            const minAmount = document.getElementById('minAmount').value;
            const maxAmount = document.getElementById('maxAmount').value;
            const userSearch = document.getElementById('userSearch').value;
            const transactionIdSearch = document.getElementById('transactionIdSearch').value;
            
            let url = '?page=1';
            
            if (transactionTypes.length > 0) url += `&types=${transactionTypes.join(',')}`;
            if (paymentMethods.length > 0) url += `&methods=${paymentMethods.join(',')}`;
            if (statuses.length > 0) url += `&statuses=${statuses.join(',')}`;
            if (minAmount) url += `&min_amount=${minAmount}`;
            if (maxAmount) url += `&max_amount=${maxAmount}`;
            if (userSearch) url += `&user=${encodeURIComponent(userSearch)}`;
            if (transactionIdSearch) url += `&transaction_id=${encodeURIComponent(transactionIdSearch)}`;
            
            window.location.href = url;
        }

        // Clear advanced filters
        function clearAdvancedFilters() {
            document.getElementById('filterTransactionType').selectedIndex = -1;
            document.getElementById('filterPaymentMethod').selectedIndex = -1;
            document.getElementById('filterStatus').selectedIndex = -1;
            document.getElementById('minAmount').value = '';
            document.getElementById('maxAmount').value = '';
            document.getElementById('userSearch').value = '';
            document.getElementById('transactionIdSearch').value = '';
        }

        // Search all transactions
        function searchAllTransactions() {
            const searchTerm = document.getElementById('searchAllTransactions').value.toLowerCase();
            const rows = document.querySelectorAll('#allTransactionsTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        }

        // Toggle unsettled view
        function toggleUnsettledView() {
            const showOnlyUnsettled = document.getElementById('showOnlyUnsettled').checked;
            const rows = document.querySelectorAll('#allTransactionsTable tbody tr');
            
            rows.forEach(row => {
                const isSettled = row.getAttribute('data-settled') === 'true';
                if (showOnlyUnsettled && isSettled) {
                    row.style.display = 'none';
                } else {
                    row.style.display = '';
                }
            });
        }

        // Sort transactions
        function sortTransactions() {
            const sortBy = document.getElementById('sortBy').value;
            let url = window.location.pathname + window.location.search;
            
            // Remove existing sort parameter if exists
            url = url.replace(/[?&]sort=[^&]*/, '');
            
            // Add new sort parameter
            const separator = url.includes('?') ? '&' : '?';
            url += `${separator}sort=${sortBy}`;
            
            window.location.href = url;
        }

        // Change page size
        function changePageSize(size) {
            let url = window.location.pathname + window.location.search;
            
            // Remove existing size parameter if exists
            url = url.replace(/[?&]size=[^&]*/, '');
            
            // Add new size parameter
            const separator = url.includes('?') ? '&' : '?';
            url += `${separator}size=${size}&page=1`;
            
            window.location.href = url;
        }

        // Mark as settled
        function markAsSettled(transactionId) {
            Swal.fire({
                title: 'Mark as Settled',
                text: 'Mark this transaction as settled?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Mark as Settled'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/admin/payments/settle/${transactionId}`, {
                        method: 'POST'
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire('Success', 'Transaction marked as settled', 'success');
                            location.reload();
                        }
                    });
                }
            });
        }

        // Show bulk actions modal
        function showBulkActions() {
            document.getElementById('bulkActionType').addEventListener('change', function() {
                const actionType = this.value;
                const optionsContainer = document.getElementById('bulkActionOptions');
                const allOptions = document.querySelectorAll('.action-options');
                
                allOptions.forEach(opt => opt.style.display = 'none');
                optionsContainer.style.display = 'none';
                
                if (actionType) {
                    optionsContainer.style.display = 'block';
                    const optionElement = document.getElementById(`${actionType}Options`);
                    if (optionElement) {
                        optionElement.style.display = 'block';
                    }
                }
            });
            
            $('#bulkActionsModal').modal('show');
        }

        // Execute bulk action
        function executeBulkAction() {
            const actionType = document.getElementById('bulkActionType').value;
            if (!actionType) {
                Swal.fire('Error', 'Please select an action', 'error');
                return;
            }
            
            const currentUrl = new URL(window.location.href);
            const params = new URLSearchParams(currentUrl.search);
            
            switch(actionType) {
                case 'export':
                    const format = document.getElementById('bulkExportFormat').value;
                    params.set('export', format);
                    window.open(`/admin/payments/export-all?${params.toString()}`, '_blank');
                    break;
                    
                case 'settle':
                    const settlementDate = document.getElementById('bulkSettlementDate').value;
                    Swal.fire({
                        title: 'Bulk Settlement',
                        text: `Mark all filtered transactions (${totalCount}) as settled?`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, mark as settled'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch('/admin/payments/bulk-settle', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({ 
                                    filters: Object.fromEntries(params),
                                    settlementDate 
                                })
                            })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire('Success', `Marked ${data.count} transactions as settled`, 'success');
                                    location.reload();
                                }
                            });
                        }
                    });
                    break;
                    
                case 'status':
                    const newStatus = document.getElementById('newStatus').value;
                    Swal.fire({
                        title: 'Change Status',
                        text: `Change status of all filtered transactions (${totalCount}) to ${newStatus}?`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, change status'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch('/admin/payments/bulk-status', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({ 
                                    filters: Object.fromEntries(params),
                                    newStatus 
                                })
                            })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire('Success', `Updated ${data.count} transactions`, 'success');
                                    location.reload();
                                }
                            });
                        }
                    });
                    break;
                    
                case 'delete':
                    Swal.fire({
                        title: 'Delete Transactions',
                        text: `Permanently delete all filtered transactions (${totalCount})? This action cannot be undone.`,
                        icon: 'error',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, delete',
                        confirmButtonColor: '#dc3545'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch('/admin/payments/bulk-delete', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({ filters: Object.fromEntries(params) })
                            })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire('Deleted!', `Deleted ${data.count} transactions`, 'success');
                                    location.reload();
                                }
                            });
                        }
                    });
                    break;
            }
            
            $('#bulkActionsModal').modal('hide');
        }

        // Export current view
        function exportCurrentView(format) {
            const currentUrl = new URL(window.location.href);
            const params = new URLSearchParams(currentUrl.search);
            params.set('export', format);
            
            window.open(`/admin/payments/export-all?${params.toString()}`, '_blank');
        }

