    <!-- Booking Management Custom JS -->
    <script>
        $(document).ready(function() {
            // Initialize Select2
            $('.select2').select2({
                width: '100%'
            });

            // Initialize Date Range Picker
            $('#dateRange').daterangepicker({
                opens: 'left',
                locale: {
                    format: 'YYYY-MM-DD'
                }
            });

            // Search functionality
            $('#searchInput').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('#bookingsTable tbody tr').filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // Filter functionality
            $('#applyFilter').on('click', function() {
                applyFilters();
            });

            // Clear filters
            $('#clearFilters').on('click', function() {
                $('#searchInput').val('');
                $('#statusFilter').val('').trigger('change');
                $('#serviceFilter').val('').trigger('change');
                $('#paymentFilter').val('').trigger('change');
                $('#dateRange').val('');
                $('#bookingsTable tbody tr').show();
            });

            // Export functionality
            $('#exportBookings').on('click', function() {
                alert('Exporting booking data to Excel (demo)');
            });

            // Quick action buttons
            $('#sendReminders').on('click', function() {
                alert('Sending reminders to upcoming bookings (demo)');
            });

            $('#generateReport').on('click', function() {
                alert('Generating booking analytics report (demo)');
            });

            $('#checkOverdue').on('click', function() {
                alert('Checking for overdue payments (demo)');
            });

            $('#viewCalendar').on('click', function() {
                alert('Opening booking calendar view (demo)');
            });

            $('#cancelBookings').on('click', function() {
                alert('Opening batch cancellation interface (demo)');
            });

            // Quick view on row click
            $('#bookingsTable tbody tr').on('click', function(e) {
                if (!$(e.target).closest('.dropdown, .dropdown-toggle, .dropdown-menu').length) {
                    $('#quickViewModal').modal('show');
                }
            });

            // Apply filters function
            function applyFilters() {
                var status = $('#statusFilter').val();
                var service = $('#serviceFilter').val();
                var payment = $('#paymentFilter').val();
                var searchTerm = $('#searchInput').val().toLowerCase();
                
                $('#bookingsTable tbody tr').each(function() {
                    var row = $(this);
                    var rowStatus = row.find('td:nth-child(7) .badge').first().text().toLowerCase();
                    var rowService = row.find('td:nth-child(2)').text().toLowerCase();
                    var rowPayment = row.find('td:nth-child(6) .badge').text().toLowerCase();
                    var rowText = row.text().toLowerCase();
                    
                    var show = true;
                    
                    if (status && !rowStatus.includes(status)) {
                        show = false;
                    }
                    
                    if (service && !rowService.includes(service)) {
                        show = false;
                    }
                    
                    if (payment && !rowPayment.includes(payment)) {
                        show = false;
                    }
                    
                    if (searchTerm && rowText.indexOf(searchTerm) === -1) {
                        show = false;
                    }
                    
                    if (show) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Quick filter buttons
            $('.btn-outline-primary.btn-sm').on('click', function() {
                $('.btn-outline-primary.btn-sm').removeClass('active');
                $(this).addClass('active');
                
                var filterType = $(this).text().trim();
                $('#bookingsTable tbody tr').each(function() {
                    var row = $(this);
                    var show = true;
                    
                    switch(filterType) {
                        case 'Today':
                            var dates = row.find('td:nth-child(4)').text();
                            show = dates.includes('May 15');
                            break;
                        case 'This Week':
                            var dates = row.find('td:nth-child(4)').text();
                            show = dates.includes('May 15') || dates.includes('May 18');
                            break;
                        case 'This Month':
                            var dates = row.find('td:nth-child(4)').text();
                            show = dates.includes('May');
                            break;
                        case 'High Value':
                            var amount = parseFloat(row.find('td:nth-child(5) h6').text().replace('₹', '').replace(',', ''));
                            show = amount > 20000;
                            break;
                        case 'Urgent':
                            var status = row.find('td:nth-child(6)').text();
                            show = status.includes('Unpaid') || status.includes('Partial');
                            break;
                        case 'All Bookings':
                            show = true;
                            break;
                    }
                    
                    if (show) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            });

            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
        });
    </script>
<%- include('../shared/partials/footer') %>