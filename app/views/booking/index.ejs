<%- include('../shared/partials/header', { admin : admin, title: title }) %>

<%
    const formatMoney = (value) => {
        const amount = Number(value || 0);
        return '₹' + amount.toLocaleString('en-IN', { maximumFractionDigits: 2 });
    };

    const formatDate = (value) => {
        if (!value) return 'N/A';
        return new Date(value).toLocaleDateString('en-IN', {
            day: '2-digit',
            month: 'short',
            year: 'numeric'
        });
    };

    const formatDateTime = (value) => {
        if (!value) return 'N/A';
        return new Date(value).toLocaleString('en-IN', {
            day: '2-digit',
            month: 'short',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    };

    const statusBadge = (status) => {
        status = String(status || '').toUpperCase();

        if (status === 'CONFIRMED') return 'bg-primary';
        if (status === 'COMPLETED') return 'bg-success';
        if (status === 'ONGOING') return 'bg-info';
        if (status === 'CANCELLED' || status === 'REJECTED' || status === 'EXPIRED') return 'bg-danger';
        return 'bg-warning';
    };

    const paymentBadge = (status) => {
        status = String(status || '').toUpperCase();

        if (status === 'PAID') return 'bg-success';
        if (status === 'PARTIAL') return 'bg-warning';
        if (status === 'FAILED') return 'bg-danger';
        if (status === 'REFUNDED') return 'bg-purple';
        return 'bg-secondary';
    };

    const buildQuery = (extra = {}) => {
        const q = Object.assign({}, filters || {}, extra);
        const params = new URLSearchParams();

        Object.keys(q).forEach((key) => {
            if (q[key] !== undefined && q[key] !== null && q[key] !== '') {
                params.set(key, q[key]);
            }
        });

        return '?' + params.toString();
    };
%>

<div class="page-wrapper">
    <div class="content container-fluid">

        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Booking Management</h3>
                </div>
                <div class="col-auto">
                    <a class="btn btn-success btn-md ms-2" href="<%= buildQuery({ export: 'excel' }) %>">
                        <i class="ti ti-download me-2"></i>Export
                    </a>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="stats-card bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-1"><%= counters.total_bookings || 0 %></h3>
                            <p class="mb-0">Total Bookings</p>
                        </div>
                        <div class="stats-icon bg-white text-primary">
                            <i class="ti ti-calendar-event"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stats-card bg-warning text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-1"><%= counters.pending || 0 %></h3>
                            <p class="mb-0">Pending</p>
                        </div>
                        <div class="stats-icon bg-white text-warning">
                            <i class="ti ti-clock"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stats-card bg-success text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-1"><%= counters.confirmed || 0 %></h3>
                            <p class="mb-0">Confirmed</p>
                        </div>
                        <div class="stats-icon bg-white text-success">
                            <i class="ti ti-check"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stats-card bg-danger text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-1"><%= formatMoney(counters.revenue) %></h3>
                            <p class="mb-0">Paid Revenue</p>
                        </div>
                        <div class="stats-icon bg-white text-danger">
                            <i class="ti ti-currency-rupee"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-2 col-sm-4">
                <div class="stats-small-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Completed</h6>
                            <h4 class="mb-0 text-success"><%= counters.completed || 0 %></h4>
                        </div>
                        <div class="icon-bg bg-success">
                            <i class="ti ti-checkbox"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-4">
                <div class="stats-small-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Cancelled</h6>
                            <h4 class="mb-0 text-danger"><%= counters.cancelled || 0 %></h4>
                        </div>
                        <div class="icon-bg bg-danger">
                            <i class="ti ti-x"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-4">
                <div class="stats-small-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Ongoing</h6>
                            <h4 class="mb-0 text-info"><%= counters.ongoing || 0 %></h4>
                        </div>
                        <div class="icon-bg bg-info">
                            <i class="ti ti-refresh"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-4">
                <div class="stats-small-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Paid</h6>
                            <h4 class="mb-0 text-success"><%= counters.paid || 0 %></h4>
                        </div>
                        <div class="icon-bg bg-success">
                            <i class="ti ti-wallet"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-4">
                <div class="stats-small-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Partial</h6>
                            <h4 class="mb-0 text-warning"><%= counters.partial || 0 %></h4>
                        </div>
                        <div class="icon-bg bg-warning">
                            <i class="ti ti-credit-card"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-4">
                <div class="stats-small-card">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Refunded</h6>
                            <h4 class="mb-0 text-purple"><%= counters.refunded || 0 %></h4>
                        </div>
                        <div class="icon-bg bg-purple">
                            <i class="ti ti-currency-rupee"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <form method="GET" action="/bookings" class="filter-section">
            <div class="row">
                <div class="col-md-3">
                    <div class="search-box">
                        <i class="ti ti-search"></i>
                        <input type="text" class="form-control" name="search" value="<%= filters.search || '' %>" placeholder="Search booking, location, contact...">
                    </div>
                </div>

                <div class="col-md-2">
                    <select class="form-control select2" name="status">
                        <option value="">All Status</option>
                        <% ['PENDING','CONFIRMED','ONGOING','COMPLETED','CANCELLED','REJECTED','EXPIRED'].forEach((s) => { %>
                            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="col-md-2">
                    <select class="form-control select2" name="payment_status">
                        <option value="">Payment Status</option>
                        <% ['PENDING','PARTIAL','PAID','FAILED','REFUNDED'].forEach((s) => { %>
                            <option value="<%= s %>" <%= filters.payment_status === s ? 'selected' : '' %>><%= s %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="col-md-2">
                    <input type="date" class="form-control" name="date_from" value="<%= filters.date_from || '' %>">
                </div>

                <div class="col-md-2">
                    <input type="date" class="form-control" name="date_to" value="<%= filters.date_to || '' %>">
                </div>

                <div class="col-md-1">
                    <button class="btn btn-primary w-100">
                        <i class="ti ti-filter"></i>
                    </button>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-3">
                    <a href="/bookings" class="btn btn-outline-secondary w-100">
                        <i class="ti ti-x me-2"></i>Clear All
                    </a>
                </div>

                <div class="col-md-9">
                    <div class="d-flex flex-wrap gap-2 justify-content-end">
                        <a class="btn btn-outline-primary btn-sm <%= !filters.quick ? 'active' : '' %>" href="/bookings">All Bookings</a>
                        <a class="btn btn-outline-primary btn-sm <%= filters.quick === 'today' ? 'active' : '' %>" href="<%= buildQuery({ quick: 'today', page: 1 }) %>">Today</a>
                        <a class="btn btn-outline-primary btn-sm <%= filters.quick === 'week' ? 'active' : '' %>" href="<%= buildQuery({ quick: 'week', page: 1 }) %>">This Week</a>
                        <a class="btn btn-outline-primary btn-sm <%= filters.quick === 'month' ? 'active' : '' %>" href="<%= buildQuery({ quick: 'month', page: 1 }) %>">This Month</a>
                        <a class="btn btn-outline-primary btn-sm <%= filters.quick === 'high_value' ? 'active' : '' %>" href="<%= buildQuery({ quick: 'high_value', page: 1 }) %>">High Value</a>
                        <a class="btn btn-outline-primary btn-sm <%= filters.quick === 'urgent' ? 'active' : '' %>" href="<%= buildQuery({ quick: 'urgent', page: 1 }) %>">Urgent</a>
                    </div>
                </div>
            </div>
        </form>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-center mb-0" id="bookingsTable">
                                <thead>
                                    <tr>
                                        <th>Booking ID</th>
                                        <th>Customer & Cab</th>
                                        <th>Trip</th>
                                        <th>Booking Date</th>
                                        <th>Amount</th>
                                        <th>Payment</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% if (bookings && bookings.length) { %>
                                        <% bookings.forEach((booking) => { %>
                                            <tr>
                                                <td>
                                                    <strong>#<%= booking.id %></strong>
                                                    <div class="text-muted small">
                                                        <%= booking.token ? booking.token.slice(0, 10) + '...' : 'N/A' %>
                                                    </div>
                                                    <div class="text-muted small">
                                                        Created: <%= formatDate(booking.create_date) %>
                                                    </div>
                                                </td>

                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="avatar avatar-sm me-3">
                                                            <img
                                                                src="<%= booking.customer_details?.image || '/assets/img/profiles/avatar-01.jpg' %>"
                                                                alt="Customer"
                                                                class="img-fluid rounded-circle"
                                                            >
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-1"><%= booking.customer_details?.name || 'Customer' %></h6>
                                                            <p class="text-muted small mb-0">
                                                                <i class="ti ti-phone me-1"></i>
                                                                <%= booking.customer_details?.contact || booking.contact || 'N/A' %>
                                                            </p>
                                                            <p class="text-muted small mb-0">
                                                                <i class="ti ti-car me-1"></i>
                                                                <%= booking.vehicle_details?.name || booking.car_type || 'Cab Booking' %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </td>

                                                <td>
                                                    <div>
                                                        <strong><%= booking.trip_type || 'N/A' %></strong>
                                                        <div class="text-muted small">
                                                            <i class="ti ti-map-pin me-1"></i>
                                                            <%= booking.from_location || 'N/A' %>
                                                            <% if (booking.to_location) { %>
                                                                → <%= booking.to_location %>
                                                            <% } %>
                                                        </div>
                                                        <div class="text-muted small">
                                                            Distance: <%= booking.total_distance || 0 %> km
                                                        </div>
                                                    </div>
                                                </td>

                                                <td>
                                                    <div class="booking-dates">
                                                        <div class="d-flex align-items-center mb-1">
                                                            <i class="ti ti-calendar-event me-2 text-primary"></i>
                                                            <span><%= formatDateTime(booking.departure_date) %></span>
                                                        </div>
                                                        <% if (booking.return_date) { %>
                                                            <div class="text-muted small">
                                                                Return: <%= formatDateTime(booking.return_date) %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                </td>

                                                <td>
                                                    <h6 class="mb-1 text-success"><%= formatMoney(booking.total_amount) %></h6>
                                                    <p class="text-muted small mb-0">
                                                        Wallet: <%= formatMoney(booking.wallet_amount_used) %>
                                                    </p>
                                                    <p class="text-muted small mb-0">
                                                        Razorpay: <%= formatMoney(booking.razorpay_amount) %>
                                                    </p>
                                                </td>

                                                <td>
                                                    <span class="badge <%= paymentBadge(booking.payment_status) %>">
                                                        <%= booking.payment_status || 'PENDING' %>
                                                    </span>
                                                    <div class="text-muted small mt-1">
                                                        <i class="ti ti-wallet me-1"></i>
                                                        <%= booking.payment_type || 'N/A' %>
                                                    </div>
                                                    <div class="text-muted small">
                                                        Wallet: <%= booking.wallet_status || 'NONE' %>
                                                    </div>
                                                </td>

                                                <td>
                                                    <span class="badge <%= statusBadge(booking.status) %>">
                                                        <%= booking.status || 'PENDING' %>
                                                    </span>
                                                </td>

                                                <td>
                                                    <div class="dropdown">
                                                        <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                            <i class="ti ti-settings"></i>
                                                        </button>
                                                        <div class="dropdown-menu dropdown-menu-end">
                                                            <a class="dropdown-item" href="/bookings/<%= booking.token %>">
                                                                <i class="ti ti-eye me-2"></i>View Details
                                                            </a>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="8" class="text-center py-5">
                                                <h5>No bookings found</h5>
                                                <p class="text-muted mb-0">Try changing your filters.</p>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <% if (pagination.total_pages > 1) { %>
            <div class="row">
                <div class="col-12">
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item <%= pagination.current_page <= 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= buildQuery({ page: pagination.current_page - 1 }) %>">
                                    <i class="ti ti-chevron-left"></i>
                                </a>
                            </li>

                            <% for (let i = 1; i <= pagination.total_pages; i++) { %>
                                <% if (i === 1 || i === pagination.total_pages || Math.abs(i - pagination.current_page) <= 2) { %>
                                    <li class="page-item <%= i === pagination.current_page ? 'active' : '' %>">
                                        <a class="page-link" href="<%= buildQuery({ page: i }) %>"><%= i %></a>
                                    </li>
                                <% } %>
                            <% } %>

                            <li class="page-item <%= pagination.current_page >= pagination.total_pages ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= buildQuery({ page: pagination.current_page + 1 }) %>">
                                    <i class="ti ti-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        <% } %>

        <div class="row mt-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Booking Insights</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="insight-item">
                                    <h6 class="mb-1">Average Booking Value</h6>
                                    <h4 class="text-success"><%= formatMoney(counters.avg_booking_value) %></h4>
                                    <p class="text-muted small">Based on all customer cab bookings</p>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="insight-item">
                                    <h6 class="mb-1">Paid Bookings</h6>
                                    <h4 class="text-primary"><%= counters.paid || 0 %></h4>
                                    <p class="text-muted small">Payment status paid</p>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="insight-item">
                                    <h6 class="mb-1">Failed Payments</h6>
                                    <h4 class="text-danger"><%= counters.failed_payments || 0 %></h4>
                                    <p class="text-muted small">Needs follow-up</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    $(document).ready(function () {
        $('.select2').select2({
            width: '100%'
        });
    });
</script>

<%- include('../shared/partials/footer') %>