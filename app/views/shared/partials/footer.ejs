<!-- <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script> -->

<script>
  // Bootstrap Toast function
  function showBootstrapToast(message, type = 'info') {
    // Create toast HTML
    const toastId = 'toast-' + Date.now();
    const toastHtml = `
        <div class="toast align-items-center text-white bg-${type === 'success' ? 'success' : type === 'error' ? 'danger' : 'primary'} border-0" 
             id="${toastId}" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    ${message}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    `;

    // Add to toast container
    $('#toastContainer').append(toastHtml);

    // Show toast
    const toastElement = document.getElementById(toastId);
    const toast = new bootstrap.Toast(toastElement, {
      delay: 3000
    });
    toast.show();

    // Remove after hidden
    toastElement.addEventListener('hidden.bs.toast', function () {
      $(this).remove();
    });
  }

  // Add this container to your HTML (anywhere in body):
</script>
<script>
    <% if (success_msg) { %>
    toastr.success("<%= success_msg %>");
    <% } %>
 
    <% if (error_msg) { %>
    toastr.error("<%= error_msg %>");
    <% } %>
</script>

