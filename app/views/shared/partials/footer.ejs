<!-- ✅ Bootstrap 5 + jQuery Modal Compatibility Shim -->
<script>
  if (window.jQuery && !jQuery.fn.modal) {
    jQuery.fn.modal = function (action) {
      return this.each(function () {
        if (!window.bootstrap || !bootstrap.Modal) return;

        let instance = bootstrap.Modal.getInstance(this);
        if (!instance) {
          instance = new bootstrap.Modal(this);
        }

        if (action === 'show') instance.show();
        if (action === 'hide') instance.hide();
        if (action === 'toggle') instance.toggle();
      });
    };
  }
</script>

