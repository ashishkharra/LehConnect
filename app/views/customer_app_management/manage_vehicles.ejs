<%- include('../shared/partials/header', { admin: admin || null, title: title || 'Manage Vehicles' , currentPage:
    currentPage || '' }) %>

    <div class="page-wrapper">
        <div class="page-content">
            <div class="container-fluid">

                <!-- Header with Add Button -->
                <div class="row my-4">
                    <div class="col-md-12">
                        <div class="d-flex justify-content-between align-items-center">
                            <h4 class="page-title mb-0">Manage Vehicles</h4>
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                                <i class="ti ti-plus"></i> Add New Vehicle
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Filters and Search -->
                <div class="row mb-4">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-body">
                                <form method="GET" action="/manage-vehicles" class="row">
                                    <div class="col-md-3 mb-2">
                                        <input type="text" name="search" class="form-control"
                                            placeholder="Search by name or type..." value="<%= filters.search %>">
                                    </div>
                                    <div class="col-md-2 mb-2">
                                        <select name="status" class="form-select">
                                            <option value="all" <%=filters.status==='all' ? 'selected' : '' %>>All
                                                Status</option>
                                            <option value="active" <%=filters.status==='active' ? 'selected' : '' %>
                                                >Active</option>
                                            <option value="inactive" <%=filters.status==='inactive' ? 'selected' : '' %>
                                                >Inactive</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2 mb-2">
                                        <select name="type" class="form-select">
                                            <option value="all" <%=filters.type==='all' ? 'selected' : '' %>>All Types</option>
                                            <option value="Sedan" <%=filters.type==='Sedan' ? 'selected' : '' %>>Sedan</option>
                                            <option value="Ertiga" <%=filters.type==='Ertiga' ? 'selected' : '' %>>Ertiga</option>
                                            <option value="Crysta" <%=filters.type==='Crysta' ? 'selected' : '' %>>Crysta</option>
                                            <option value="Innova" <%=filters.type==='Innova' ? 'selected' : '' %>>Innova</option>
                                            <option value="Carens" <%=filters.type==='Carens' ? 'selected' : '' %>>Carens</option>
                                            <option value="Compact SUV" <%=filters.type==='Compact SUV' ? 'selected' : '' %>>Compact SUV</option>
                                            <option value="Traveller" <%=filters.type==='Traveller' ? 'selected' : '' %>>Traveller</option>
                                            <option value="BUS" <%=filters.type==='BUS' ? 'selected' : '' %>>BUS</option>
                                            <option value="SUV" <%=filters.type==='SUV' ? 'selected' : '' %>>SUV</option>
                                            <option value="Hatchback" <%=filters.type==='Hatchback' ? 'selected' : '' %>>Hatchback</option>
                                            <option value="MUV" <%=filters.type==='MUV' ? 'selected' : '' %>>MUV</option>
                                            <option value="Luxury" <%=filters.type==='Luxury' ? 'selected' : '' %>>Luxury</option>
                                            <option value="Coupe" <%=filters.type==='Coupe' ? 'selected' : '' %>>Coupe</option>
                                            <option value="Convertible" <%=filters.type==='Convertible' ? 'selected' : '' %>>Convertible</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2 mb-2">
                                        <select name="limit" class="form-select">
                                            <option value="12" <%=pagination.limit===12 ? 'selected' : '' %>>12 per page
                                            </option>
                                            <option value="24" <%=pagination.limit===24 ? 'selected' : '' %>>24 per page
                                            </option>
                                            <option value="48" <%=pagination.limit===48 ? 'selected' : '' %>>48 per page
                                            </option>
                                        </select>
                                    </div>
                                    <div class="col-md-3 mb-2">
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="ti ti-search"></i> Filter
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Vehicles Grid with Image Slider -->
                <div class="row">
                    <% if (vehicles && vehicles.length> 0) { %>
                        <% vehicles.forEach((vehicle, index)=> { %>
                            <div class="col-md-6 col-lg-4 col-xl-3 mb-4">
                                <div class="card h-100 vehicle-card">
                                    <!-- Image Slider -->
                                    <div id="carousel-<%= vehicle.token %>" class="carousel slide carousel-fade"
                                        data-bs-ride="carousel">
                                        <div class="carousel-indicators">
                                            <button type="button" data-bs-target="#carousel-<%= vehicle.token %>"
                                                data-bs-slide-to="0" class="active" aria-current="true"
                                                aria-label="Slide 1"></button>
                                            <button type="button" data-bs-target="#carousel-<%= vehicle.token %>"
                                                data-bs-slide-to="1" aria-label="Slide 2"></button>
                                        </div>
                                        <div class="carousel-inner">
                                            <div class="carousel-item active">
                                                <img src="<%= vehicle.image1 || '/images/default-car.jpg' %>"
                                                    class="d-block w-100 vehicle-slider-img"
                                                    alt="<%= vehicle.name %> - Image 1"
                                                    style="height: 220px; object-fit: cover;">
                                            </div>
                                            <div class="carousel-item">
                                                <img src="<%= vehicle.image2 || '/images/default-car.jpg' %>"
                                                    class="d-block w-100 vehicle-slider-img"
                                                    alt="<%= vehicle.name %> - Image 2"
                                                    style="height: 220px; object-fit: cover;">
                                            </div>
                                        </div>
                                        <button class="carousel-control-prev" type="button"
                                            data-bs-target="#carousel-<%= vehicle.token %>" data-bs-slide="prev">
                                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                            <span class="visually-hidden">Previous</span>
                                        </button>
                                        <button class="carousel-control-next" type="button"
                                            data-bs-target="#carousel-<%= vehicle.token %>" data-bs-slide="next">
                                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                            <span class="visually-hidden">Next</span>
                                        </button>
                                    </div>

                                    <!-- Availability Badge -->
                                    <div class="availability-badge">
                                        <% if (vehicle.availability==='available' ) { %>
                                            <span class="badge bg-success">Available</span>
                                            <% } else if (vehicle.availability==='booked' ) { %>
                                                <span class="badge bg-warning">Booked</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Maintenance</span>
                                                    <% } %>
                                    </div>

                                    <div class="card-body">
                                        <h5 class="card-title mb-1">
                                            <%= vehicle.name %>
                                        </h5>
                                        <p class="card-text text-muted small mb-2">
                                            <%= vehicle.type %>
                                        </p>

                                        <!-- Vehicle Specifications -->
                                        <div class="vehicle-specs mb-3">
                                            <div class="row g-2">
                                                <div class="col-6">
                                                    <div class="spec-item">
                                                        <i class="ti ti-users"></i>
                                                        <span>
                                                            <%= vehicle.seater %> Seats
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <div class="spec-item">
                                                        <i class="ti ti-gas-station"></i>
                                                        <span>
                                                            <%= vehicle.avg_per_km %> km/l
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <div class="spec-item">
                                                        <% if (vehicle.ac) { %>
                                                            <i class="ti ti-snowflake text-success"></i>
                                                            <span class="text-success">AC</span>
                                                            <% } else { %>
                                                                <i class="ti ti-snowflake text-muted"></i>
                                                                <span class="text-muted">No AC</span>
                                                                <% } %>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <div class="spec-item">
                                                        <% if (vehicle.gps) { %>
                                                            <i class="ti ti-map text-success"></i>
                                                            <span class="text-success">GPS</span>
                                                            <% } else { %>
                                                                <i class="ti ti-map text-muted"></i>
                                                                <span class="text-muted">No GPS</span>
                                                                <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Action Buttons -->
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-warning flex-fill"
                                                onclick="editVehicle('<%= vehicle.token %>')">
                                                <i class="ti ti-edit"></i> Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger flex-fill"
                                                onclick="deleteVehicle('<%= vehicle.token %>')">
                                                <i class="ti ti-trash"></i> Delete
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="col-12">
                                        <div class="alert alert-info text-center">
                                            <i class="ti ti-car-off fs-1 d-block mb-2"></i>
                                            No vehicles found. Click "Add New Vehicle" to get started.
                                        </div>
                                    </div>
                                    <% } %>
                </div>

                <!-- Pagination -->
                <% if (pagination && pagination.totalPages> 1) { %>
                    <div class="row mt-4">
                        <div class="col-md-12">
                            <nav aria-label="Page navigation">
                                <ul class="pagination justify-content-center">
                                    <% if (pagination.hasPrevPage) { %>
                                        <li class="page-item">
                                            <a class="page-link"
                                                href="?page=<%= pagination.prevPage %>&search=<%= filters.search %>&status=<%= filters.status %>&type=<%= filters.type %>&limit=<%= pagination.limit %>">
                                                <i class="ti ti-chevron-left"></i> Previous
                                            </a>
                                        </li>
                                        <% } %>

                                            <% for (let i=1; i <=pagination.totalPages; i++) { %>
                                                <% if (i===1 || i===pagination.totalPages || (i>= pagination.currentPage
                                                    - 2 && i <= pagination.currentPage + 2)) { %>
                                                        <li
                                                            class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
                                                            <a class="page-link"
                                                                href="?page=<%= i %>&search=<%= filters.search %>&status=<%= filters.status %>&type=<%= filters.type %>&limit=<%= pagination.limit %>">
                                                                <%= i %>
                                                            </a>
                                                        </li>
                                                        <% } else if (i===pagination.currentPage - 3 ||
                                                            i===pagination.currentPage + 3) { %>
                                                            <li class="page-item disabled"><span
                                                                    class="page-link">...</span></li>
                                                            <% } %>
                                                                <% } %>

                                                                    <% if (pagination.hasNextPage) { %>
                                                                        <li class="page-item">
                                                                            <a class="page-link"
                                                                                href="?page=<%= pagination.nextPage %>&search=<%= filters.search %>&status=<%= filters.status %>&type=<%= filters.type %>&limit=<%= pagination.limit %>">
                                                                                Next <i class="ti ti-chevron-right"></i>
                                                                            </a>
                                                                        </li>
                                                                        <% } %>
                                </ul>
                            </nav>
                        </div>
                    </div>
                    <% } %>

            </div>
        </div>
    </div>

    <!-- Add Vehicle Modal -->
    <div class="modal fade" id="addVehicleModal" tabindex="-1" aria-labelledby="addVehicleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title text-white" id="addVehicleModalLabel">
                        <i class="ti ti-car"></i> Add New Vehicle
                    </h5>
                    <button type="button" class="btn-close btn-close-black" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <form id="vehicleForm" action="/add-vehicle" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <!-- Basic Information -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Name <span class="text-danger">*</span></label>
                                <input type="text" name="name" id="vehicleName" class="form-control" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Type <span class="text-danger">*</span></label>
                                <select name="type" id="vehicleType" class="form-select" required>
                                    <option value="">Select Type</option>
                                    <option value="Sedan">Sedan</option>
                                    <option value="Ertiga">Ertiga</option>
                                    <option value="Crysta">Crysta</option>
                                    <option value="Innova">Innova</option>
                                    <option value="Carens">Carens</option>
                                    <option value="Compact SUV">Compact SUV</option>
                                    <option value="Traveller">Traveller</option>
                                    <option value="BUS">BUS</option>
                                    <option value="SUV">SUV</option>
                                    <option value="Hatchback">Hatchback</option>
                                    <option value="MUV">MUV</option>
                                    <option value="Luxury">Luxury</option>
                                    <option value="Coupe">Coupe</option>
                                    <option value="Convertible">Convertible</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Seating Capacity <span class="text-danger">*</span></label>
                                <input type="number" name="seater" id="vehicleSeater" class="form-control" min="1"
                                    max="20" required>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Avg. per Kilometer (km/l) <span
                                        class="text-danger">*</span></label>
                                <input type="number" step="0.1" name="avg_per_km" id="vehicleAvgPerKm"
                                    class="form-control" required>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Availability <span class="text-danger">*</span></label>
                                <select name="availability" id="vehicleAvailability" class="form-select" required>
                                    <option value="available">Available</option>
                                    <option value="booked">Booked</option>
                                    <option value="maintenance">Maintenance</option>
                                </select>
                            </div>
                        </div>

                        <!-- Features -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="ac" id="vehicleAc"
                                        value="true">
                                    <label class="form-check-label">Air Conditioning (AC)</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="gps" id="vehicleGps"
                                        value="true">
                                    <label class="form-check-label">GPS Navigation</label>
                                </div>
                            </div>
                        </div>

                        <!-- Vehicle Images -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Image 1 (Front/Side) <span
                                        class="text-danger">*</span></label>
                                <input type="file" name="image1" id="vehicleImage1" class="form-control"
                                    accept="image/*" onchange="previewModalImage(event, 'preview1')">
                                <div class="mt-2">
                                    <img id="preview1" src="#" alt="Image 1 Preview"
                                        style="height: 100px; border-radius: 8px; display: none;">
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Image 2 (Interior/Rear) <span
                                        class="text-danger">*</span></label>
                                <input type="file" name="image2" id="vehicleImage2" class="form-control"
                                    accept="image/*" onchange="previewModalImage(event, 'preview2')">
                                <div class="mt-2">
                                    <img id="preview2" src="#" alt="Image 2 Preview"
                                        style="height: 100px; border-radius: 8px; display: none;">
                                </div>
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select name="status" id="vehicleStatus" class="form-select">
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary ms-2">
                            <i class="ti ti-device-floppy"></i> Save Vehicle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Vehicle Modal -->
    <div class="modal fade" id="editVehicleModal" tabindex="-1" aria-labelledby="editVehicleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title" id="editVehicleModalLabel">
                        <i class="ti ti-edit"></i> Edit Vehicle
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="editVehicleForm" action="/update-vehicle" method="POST" enctype="multipart/form-data">
                    <div class="modal-body">
                        <input type="hidden" name="vehicleToken" id="editVehicleToken">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Name <span class="text-danger">*</span></label>
                                <input type="text" name="name" id="editVehicleName" class="form-control" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Type <span class="text-danger">*</span></label>
                                <select name="type" id="editVehicleType" class="form-select" required>
                                    <option value="">Select Type</option>
                                    <option value="Sedan">Sedan</option>
                                    <option value="Ertiga">Ertiga</option>
                                    <option value="Crysta">Crysta</option>
                                    <option value="Innova">Innova</option>
                                    <option value="Carens">Carens</option>
                                    <option value="Compact SUV">Compact SUV</option>
                                    <option value="Traveller">Traveller</option>
                                    <option value="BUS">BUS</option>
                                    <option value="SUV">SUV</option>
                                    <option value="Hatchback">Hatchback</option>
                                    <option value="MUV">MUV</option>
                                    <option value="Luxury">Luxury</option>
                                    <option value="Coupe">Coupe</option>
                                    <option value="Convertible">Convertible</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Seating Capacity <span class="text-danger">*</span></label>
                                <input type="number" name="seater" id="editVehicleSeater" class="form-control" min="1"
                                    max="20" required>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Avg. per Kilometer (km/l) <span
                                        class="text-danger">*</span></label>
                                <input type="number" step="0.1" name="avg_per_km" id="editVehicleAvgPerKm"
                                    class="form-control" required>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Availability <span class="text-danger">*</span></label>
                                <select name="availability" id="editVehicleAvailability" class="form-select" required>
                                    <option value="available">Available</option>
                                    <option value="booked">Booked</option>
                                    <option value="maintenance">Maintenance</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="ac" id="editVehicleAc"
                                        value="true">
                                    <label class="form-check-label">Air Conditioning (AC)</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="gps" id="editVehicleGps"
                                        value="true">
                                    <label class="form-check-label">GPS Navigation</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Image 1 (Front/Side)</label>
                                <input type="file" name="image1" id="editVehicleImage1" class="form-control"
                                    accept="image/*" onchange="previewEditImage(event, 'editPreview1')">
                                <div class="mt-2">
                                    <img id="editPreview1" src="#" alt="Image 1 Preview"
                                        style="height: 100px; border-radius: 8px; display: none;">
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Image 2 (Interior/Rear)</label>
                                <input type="file" name="image2" id="editVehicleImage2" class="form-control"
                                    accept="image/*" onchange="previewEditImage(event, 'editPreview2')">
                                <div class="mt-2">
                                    <img id="editPreview2" src="#" alt="Image 2 Preview"
                                        style="height: 100px; border-radius: 8px; display: none;">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select name="status" id="editVehicleStatus" class="form-select">
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy"></i> Update Vehicle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('../shared/partials/footer') %>

        <script>
            // Preview functions for modals
            function previewModalImage(event, previewId) {
                const file = event.target.files[0];
                const preview = document.getElementById(previewId);
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        preview.src = e.target.result;
                        preview.style.display = 'block';
                    };
                    reader.readAsDataURL(file);
                } else {
                    preview.src = '#';
                    preview.style.display = 'none';
                }
            }

            function previewEditImage(event, previewId) {
                const file = event.target.files[0];
                const preview = document.getElementById(previewId);
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        preview.src = e.target.result;
                        preview.style.display = 'block';
                    };
                    reader.readAsDataURL(file);
                } else {
                    preview.src = '#';
                    preview.style.display = 'none';
                }
            }

            // Reset add modal form
            function resetAddModal() {
                document.getElementById('vehicleForm').reset();
                document.getElementById('preview1').style.display = 'none';
                document.getElementById('preview2').style.display = 'none';
                document.getElementById('preview1').src = '#';
                document.getElementById('preview2').src = '#';
                document.getElementById('vehicleImage1').required = true;
                document.getElementById('vehicleImage2').required = true;
            }

            // View vehicle details
            function viewVehicle(token) {
                window.location.href = `/vehicle-details/${token}`;
            }

            // Edit vehicle - Populate edit modal
            function editVehicle(token) {
                fetch(`/api/vehicles/${token}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.success && data.data) {
                            const vehicle = data.data;

                            document.getElementById('editVehicleToken').value = vehicle.token;
                            document.getElementById('editVehicleName').value = vehicle.name;
                            document.getElementById('editVehicleType').value = vehicle.type;
                            document.getElementById('editVehicleSeater').value = vehicle.seater;
                            document.getElementById('editVehicleAvgPerKm').value = vehicle.avg_per_km;
                            document.getElementById('editVehicleAvailability').value = vehicle.availability;
                            document.getElementById('editVehicleAc').checked = vehicle.ac === 1 || vehicle.ac === true;
                            document.getElementById('editVehicleGps').checked = vehicle.gps === 1 || vehicle.gps === true;
                            document.getElementById('editVehicleStatus').value = vehicle.status;

                            if (vehicle.image1 && vehicle.image1 !== '/images/default-car.jpg') {
                                document.getElementById('editPreview1').src = vehicle.image1;
                                document.getElementById('editPreview1').style.display = 'block';
                            }
                            if (vehicle.image2 && vehicle.image2 !== '/images/default-car.jpg') {
                                document.getElementById('editPreview2').src = vehicle.image2;
                                document.getElementById('editPreview2').style.display = 'block';
                            }

                            const editModal = new bootstrap.Modal(document.getElementById('editVehicleModal'));
                            editModal.show();
                        } else {
                            alert('Failed to load vehicle data');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error loading vehicle data');
                    });
            }

            // Delete vehicle
            function deleteVehicle(token) {
                if (confirm('Are you sure you want to delete this vehicle? This action cannot be undone.')) {
                    fetch(`/api/vehicles/${token}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                location.reload();
                            } else {
                                alert('Failed to delete vehicle: ' + (data.message || 'Unknown error'));
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            alert('Error deleting vehicle');
                        });
                }
            }

            // Handle add vehicle form submission
            document.getElementById('vehicleForm').addEventListener('submit', function (e) {
                const image1 = document.getElementById('vehicleImage1').files[0];
                const image2 = document.getElementById('vehicleImage2').files[0];

                if (!image1 || !image2) {
                    e.preventDefault();
                    alert('Please upload both vehicle images (Front/Side and Interior/Rear)');
                    return false;
                }
                return true;
            });

            // Handle edit vehicle form submission
            document.getElementById('editVehicleForm').addEventListener('submit', function (e) {
                e.preventDefault();
                const formData = new FormData(this);
                const token = document.getElementById('editVehicleToken').value;

                fetch(`/api/vehicles/${token}`, {
                    method: 'PUT',
                    body: formData
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            alert('Failed to update vehicle: ' + (data.message || 'Unknown error'));
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error updating vehicle');
                    });
            });

            // Reset add modal when opened
            document.getElementById('addVehicleModal').addEventListener('show.bs.modal', function () {
                resetAddModal();
            });
        </script>

