<%- include('../shared/partials/header', { admin : admin, title: title }) %>

<div class="page-wrapper">
    <div class="content container-fluid">

        <div class="page-header">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">Bid Bookings</h3>
                    <p class="text-muted mb-0">Manage BID type bookings and vendor bids</p>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Bid Bookings</p>
                        <h4><%= counters?.total_bid_bookings || 0 %></h4>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Total Bids</p>
                        <h4><%= counters?.total_bids || 0 %></h4>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Open / Accepted</p>
                        <h4><%= counters?.open_count || 0 %> / <%= counters?.accepted_count || 0 %></h4>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Total Value</p>
                        <h4><%= counters?.total_value || '₹0.00' %></h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-2 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">In Progress</p>
                        <h5><%= counters?.in_progress_count || 0 %></h5>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Completed</p>
                        <h5><%= counters?.completed_count || 0 %></h5>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Cancelled</p>
                        <h5><%= counters?.cancelled_count || 0 %></h5>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Expired</p>
                        <h5><%= counters?.expired_count || 0 %></h5>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Paid</p>
                        <h5><%= counters?.paid_count || 0 %></h5>
                    </div>
                </div>
            </div>

            <div class="col-md-2 col-sm-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-1">Unpaid</p>
                        <h5><%= counters?.unpaid_count || 0 %></h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Filters</h5>
            </div>

            <div class="card-body">
                <form method="GET" action="/bids">
                    <div class="row g-3">

                        <div class="col-md-3">
                            <label class="form-label">Search</label>
                            <input
                                type="text"
                                class="form-control"
                                name="search"
                                value="<%= filters?.search || '' %>"
                                placeholder="Token, vehicle, city, location"
                            />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="status">
                                <option value="">All</option>
                                <% ['OPEN','ACCEPTED','IN_PROGRESS','COMPLETED','CANCELLED','EXPIRED','REJECTED'].forEach(st => { %>
                                    <option value="<%= st %>" <%= filters?.status === st ? 'selected' : '' %>><%= st %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Payment</label>
                            <select class="form-select" name="payment_status">
                                <option value="">All</option>
                                <option value="PAID" <%= filters?.payment_status === 'PAID' ? 'selected' : '' %>>Paid</option>
                                <option value="UNPAID" <%= filters?.payment_status === 'UNPAID' ? 'selected' : '' %>>Unpaid</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Trip Type</label>
                            <select class="form-select" name="trip_type">
                                <option value="">All</option>
                                <option value="ONE_WAY" <%= filters?.trip_type === 'ONE_WAY' ? 'selected' : '' %>>One Way</option>
                                <option value="ROUND_TRIP" <%= filters?.trip_type === 'ROUND_TRIP' ? 'selected' : '' %>>Round Trip</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Per Page</label>
                            <select class="form-select" name="limit">
                                <option value="10" <%= String(filters?.limit || 10) === '10' ? 'selected' : '' %>>10</option>
                                <option value="25" <%= String(filters?.limit) === '25' ? 'selected' : '' %>>25</option>
                                <option value="50" <%= String(filters?.limit) === '50' ? 'selected' : '' %>>50</option>
                                <option value="100" <%= String(filters?.limit) === '100' ? 'selected' : '' %>>100</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Created From</label>
                            <input type="date" class="form-control" name="date_from" value="<%= filters?.date_from || '' %>">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Created To</label>
                            <input type="date" class="form-control" name="date_to" value="<%= filters?.date_to || '' %>">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Pickup From</label>
                            <input type="date" class="form-control" name="pickup_from" value="<%= filters?.pickup_from || '' %>">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Pickup To</label>
                            <input type="date" class="form-control" name="pickup_to" value="<%= filters?.pickup_to || '' %>">
                        </div>

                        <div class="col-md-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="ti ti-filter"></i> Apply Filter
                            </button>

                            <a href="/bids" class="btn btn-light">Reset</a>
                        </div>

                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="card-title">BID Booking List</h5>
                <p class="card-text mb-0">
                    Showing <%= bidBookings?.length || 0 %> of <%= pagination?.total || 0 %> bookings
                </p>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-center mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Booking Info</th>
                                <th>Vehicle</th>
                                <th>Route</th>
                                <th>Pickup</th>
                                <th>Bids</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (bidBookings && bidBookings.length > 0) { %>
                                <% bidBookings.forEach((booking) => { %>
                                    <tr>
                                        <td>
                                            <strong>#<%= booking.id %></strong>
                                        </td>

                                        <td>                                          
                                            <small class="text-muted">
                                                <%= booking.trip_type %> | <%= booking.visibility %>
                                            </small>
                                            <% if (booking.secure_booking) { %>
                                                <br><span class="badge bg-success">Secure</span>
                                            <% } %>
                                            <% if (booking.is_negotiable) { %>
                                                <span class="badge bg-warning text-dark">Negotiable</span>
                                            <% } %>
                                        </td>

                                        <td>
                                            <strong class="text-muted"><%= booking.vehicle_type %></strong>
                                        </td>

                                        <td>
                                            <div><strong>From:</strong> <%= booking.pickup_location %></div>
                                            <div><strong>To:</strong> <%= booking.drop_location %></div>
                                            <small class="text-muted"><%= booking.city %>, <%= booking.state %></small>
                                        </td>

                                        <td>
                                            <%= booking.pickup_datetime %>
                                            <% if (booking.trip_type === 'ROUND_TRIP') { %>
                                                <br>
                                                <small class="text-muted">Return: <%= booking.return_datetime %></small>
                                            <% } %>
                                        </td>

                                        <td>
                                            <span class="badge bg-primary"><%= booking.total_bids %> Bids</span>
                                            <br>
                                            <small class="text-muted">Low: <%= booking.lowest_bid %></small>
                                            <br>
                                            <small class="text-muted">High: <%= booking.highest_bid %></small>
                                            <% if (booking.accepted_bids > 0) { %>
                                                <br>
                                                <span class="badge bg-success"><%= booking.accepted_bids %> Accepted</span>
                                            <% } %>
                                        </td>

                                        <td>
                                            <% 
                                                let statusClass = 'bg-secondary';
                                                if (booking.status === 'OPEN') statusClass = 'bg-warning text-dark';
                                                if (booking.status === 'ACCEPTED') statusClass = 'bg-info';
                                                if (booking.status === 'IN_PROGRESS') statusClass = 'bg-primary';
                                                if (booking.status === 'COMPLETED') statusClass = 'bg-success';
                                                if (booking.status === 'CANCELLED' || booking.status === 'REJECTED') statusClass = 'bg-danger';
                                            %>
                                            <span class="badge <%= statusClass %>"><%= booking.status %></span>
                                        </td>

                                        <td><%= booking.created_at %></td>

                                        <td class="text-end">
                                            <a href="/bids/<%= booking.token %>" class="btn btn-sm btn-primary">
                                                <i class="ti ti-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="11" class="text-center py-5">
                                        <i class="ti ti-gavel fs-48 text-muted mb-3 d-block"></i>
                                        <h5>No BID bookings found</h5>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <% if (pagination && pagination.total_pages > 1) { %>
                    <%
                        const queryParams = new URLSearchParams();

                        if (filters?.search) queryParams.set('search', filters.search);
                        if (filters?.status) queryParams.set('status', filters.status);
                        if (filters?.payment_status) queryParams.set('payment_status', filters.payment_status);
                        if (filters?.trip_type) queryParams.set('trip_type', filters.trip_type);
                        if (filters?.date_from) queryParams.set('date_from', filters.date_from);
                        if (filters?.date_to) queryParams.set('date_to', filters.date_to);
                        if (filters?.pickup_from) queryParams.set('pickup_from', filters.pickup_from);
                        if (filters?.pickup_to) queryParams.set('pickup_to', filters.pickup_to);
                        if (filters?.limit) queryParams.set('limit', filters.limit);

                        const queryString = queryParams.toString();
                        const makePageUrl = (page) => `/bids?page=${page}${queryString ? '&' + queryString : ''}`;
                    %>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <div class="text-muted">
                            Showing
                            <%= ((pagination.current_page - 1) * pagination.per_page) + 1 %>
                            to
                            <%= Math.min(pagination.current_page * pagination.per_page, pagination.total) %>
                            of
                            <%= pagination.total %>
                            bookings
                        </div>

                        <nav>
                            <ul class="pagination mb-0">
                                <li class="page-item <%= pagination.current_page <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="<%= makePageUrl(pagination.current_page - 1) %>">Previous</a>
                                </li>

                                <% for (let i = 1; i <= pagination.total_pages; i++) { %>
                                    <li class="page-item <%= pagination.current_page === i ? 'active' : '' %>">
                                        <a class="page-link" href="<%= makePageUrl(i) %>"><%= i %></a>
                                    </li>
                                <% } %>

                                <li class="page-item <%= pagination.current_page >= pagination.total_pages ? 'disabled' : '' %>">
                                    <a class="page-link" href="<%= makePageUrl(pagination.current_page + 1) %>">Next</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</div>

<%- include('../shared/partials/footer') %>