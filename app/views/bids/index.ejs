    <!-- Bids Management Custom JS -->
    <script>
        $(document).ready(function() {
            // Initialize Select2
            $('.select2').select2({
                width: '100%'
            });

            // Initialize Date Range Picker
            $('#dateRange').daterangepicker({
                opens: 'left',
                locale: {
                    format: 'YYYY-MM-DD'
                }
            });

            // Search functionality
            $('#searchInput').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('#bidsTable tbody tr').filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // Filter functionality
            $('#applyFilter').on('click', function() {
                applyFilters();
            });

            // Clear filters
            $('#clearFilters').on('click', function() {
                $('#searchInput').val('');
                $('#statusFilter').val('').trigger('change');
                $('#serviceFilter').val('').trigger('change');
                $('#priorityFilter').val('').trigger('change');
                $('#dateRange').val('');
                $('#bidsTable tbody tr').show();
            });

            // Export functionality
            $('#exportBids').on('click', function() {
                alert('Exporting bid data to Excel (demo)');
            });

            // Quick action buttons
            $('#sendReminders').on('click', function() {
                alert('Sending reminders to vendors about open bids (demo)');
            });

            $('#generateReport').on('click', function() {
                alert('Generating bidding analytics report (demo)');
            });

            $('#evaluateBids').on('click', function() {
                $('#evaluationModal').modal('show');
            });

            $('#viewCalendar').on('click', function() {
                alert('Opening bid deadline calendar (demo)');
            });

            $('#closeExpired').on('click', function() {
                if (confirm('Close all expired bids?')) {
                    alert('Expired bids closed (demo)');
                }
            });

            // Row click for quick view
            $('#bidsTable tbody tr').on('click', function(e) {
                if (!$(e.target).closest('.dropdown, .dropdown-toggle, .dropdown-menu').length) {
                    var bidId = $(this).find('strong').text();
                    alert('Opening bid details for ' + bidId + ' (demo)');
                }
            });

            // Apply filters function
            function applyFilters() {
                var status = $('#statusFilter').val();
                var service = $('#serviceFilter').val();
                var priority = $('#priorityFilter').val();
                var searchTerm = $('#searchInput').val().toLowerCase();
                
                $('#bidsTable tbody tr').each(function() {
                    var row = $(this);
                    var rowStatus = row.find('td:nth-child(7) .badge').first().text().toLowerCase();
                    var rowService = row.find('td:nth-child(2)').text().toLowerCase();
                    var rowPriority = row.find('td:nth-child(5)').text().toLowerCase();
                    var rowText = row.text().toLowerCase();
                    
                    var show = true;
                    
                    if (status && !rowStatus.includes(status)) {
                        show = false;
                    }
                    
                    if (service && !rowService.includes(service)) {
                        show = false;
                    }
                    
                    if (priority && !rowText.includes(priority)) {
                        show = false;
                    }
                    
                    if (searchTerm && rowText.indexOf(searchTerm) === -1) {
                        show = false;
                    }
                    
                    if (show) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Quick filter buttons
            $('.btn-outline-primary.btn-sm').on('click', function() {
                $('.btn-outline-primary.btn-sm').removeClass('active');
                $(this).addClass('active');
                
                var filterType = $(this).text().trim();
                $('#bidsTable tbody tr').each(function() {
                    var row = $(this);
                    var show = true;
                    
                    switch(filterType) {
                        case 'My Bids':
                            var customer = row.find('td:nth-child(3)').text();
                            show = customer.includes('Rajesh') || customer.includes('Priya');
                            break;
                        case 'High Value':
                            var amount = parseFloat(row.find('td:nth-child(5) h6').text().replace('₹', '').replace(',', ''));
                            show = amount > 1000000;
                            break;
                        case 'Urgent':
                            var timeline = row.find('td:nth-child(6)').text();
                            show = timeline.includes('Closing in') || timeline.includes('Today');
                            break;
                        case 'Closing Soon':
                            var status = row.find('td:nth-child(7)').text();
                            show = status.includes('Open') || status.includes('Under Review');
                            break;
                        case 'All Bids':
                            show = true;
                            break;
                    }
                    
                    if (show) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            });

            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
        });
    </script>
<%- include('../shared/partials/footer') %>