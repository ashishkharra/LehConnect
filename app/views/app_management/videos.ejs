<%- include('../shared/partials/header', { admin : admin, title: title, query: query, data: data }) %>
    <% const videos=data?.docs || []; %>
        <!-- Page Wrapper -->
        <div class="page-wrapper">
            <div class="content container-fluid">
                <!-- Page Header -->
                <div class="page-header">
                    <div class="row align-items-center">
                        <div class="col">
                            <h3 class="page-title">Helping Videos Management</h3>
                            <p class="page-subtitle">Manage tutorial and guide videos for users</p>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addVideoModal">
                                <i class="ti ti-video-plus me-2"></i>Add New Video
                            </button>
                        </div>
                    </div>
                </div>
                <!-- /Page Header -->

                <!-- Statistics Cards -->
                <div class="row mb-4">
                    <!-- Total Videos -->
                    <div class="col-md-3 col-sm-6">
                        <div class="stats-card bg-primary text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h3 class="mb-1">
                                        <%= data?.results?.statusCounts?.total || 0 %>
                                    </h3>
                                    <p class="mb-0">Total Videos</p>
                                </div>
                                <div class="stats-icon bg-white text-primary">
                                    <i class="ti ti-video"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Published Videos -->
                    <div class="col-md-3 col-sm-6">
                        <div class="stats-card bg-success text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h3 class="mb-1">
                                        <%= data?.results?.statusCounts?.active || 0 %>
                                    </h3>
                                    <p class="mb-0">Published</p>
                                </div>
                                <div class="stats-icon bg-white text-success">
                                    <i class="ti ti-check"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Draft Videos -->
                    <div class="col-md-3 col-sm-6">
                        <div class="stats-card bg-warning text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h3 class="mb-1">
                                        <%= data?.results?.statusCounts?.inactive || 0 %>
                                    </h3>
                                    <p class="mb-0">Draft</p>
                                </div>
                                <div class="stats-icon bg-white text-warning">
                                    <i class="ti ti-clock"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /Statistics Cards -->

                <!-- Filter & Search Section -->
                <form method="GET" action="/videos">
                    <div class="filter-section">
                        <div class="row">

                            <!-- CATEGORY -->
                            <div class="col-md-4">
                                <select class="form-control select2" name="category">
                                    <option value="">All Categories</option>

                                    <option value="getting-started" <%=query.category==='getting-started' ? 'selected'
                                        : '' %>>
                                        Getting Started
                                    </option>

                                    <option value="vendor-guide" <%=query.category==='vendor-guide' ? 'selected' : '' %>
                                        >
                                        Vendor Guide
                                    </option>

                                    <option value="customer-guide" <%=query.category==='customer-guide' ? 'selected'
                                        : '' %>>
                                        Customer Guide
                                    </option>

                                    <option value="payment" <%=query.category==='payment' ? 'selected' : '' %>>
                                        Payment & Billing
                                    </option>

                                    <option value="troubleshooting" <%=query.category==='troubleshooting' ? 'selected'
                                        : '' %>>
                                        Troubleshooting
                                    </option>

                                    <option value="features" <%=query.category==='features' ? 'selected' : '' %>>
                                        Features Tour
                                    </option>
                                </select>
                            </div>

                            <!-- STATUS -->
                            <div class="col-md-3">
                                <select class="form-control select2" name="status">
                                    <option value="">All Status</option>

                                    <option value="active" <%=query.status==='active' ? true : false %>>
                                        Active
                                    </option>

                                    <option value="inactive" <%=query.status==='inactive' ? false : true %>>
                                        Inactive
                                    </option>
                                </select>
                            </div>

                            <!-- APPLY -->
                            <div class="col-md-3 text-end">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="ti ti-filter me-2"></i>Filter
                                </button>
                            </div>

                            <!-- CLEAR -->
                            <div class="col-md-2 text-end">
                                <a href="/videos" class="btn btn-outline-secondary w-100">
                                    <i class="ti ti-x me-1"></i>Clear
                                </a>
                            </div>

                        </div>
                    </div>
                </form>

                <!-- /Filter & Search Section -->

                <!-- Videos Grid -->
                <div class="row" id="videosGrid">
                    <% if (data?.results?.docs?.length) { %>
                        <% data.results.docs.forEach(video=> { %>
                            <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                                <div class="card video-card">
                                    <div class="card-body">

                                        <!-- Video Thumbnail -->
                                        <div class="video-thumbnail-container mb-3">
                                            <div class="video-thumbnail preview-video-btn"
                                                data-token="<%= video.token %>"
                                                style="background-image: url('<%= video.thumbnail %>');">

                                                <div class="play-button">
                                                    <i class="ti ti-player-play"></i>
                                                </div>

                                                <div class="video-badges">
                                                    <span
                                                        class="badge <%= video.status ? 'bg-success' : 'bg-warning' %>">
                                                        <%= video.status ? 'Published' : 'Unpublished' %>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Video Info -->
                                        <div class="video-info">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h5 class="mb-0">
                                                    <%= video.title %>
                                                </h5>

                                                <div class="dropdown">
                                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                                        type="button" data-bs-toggle="dropdown">
                                                        <i class="ti ti-dots-vertical"></i>
                                                    </button>
                                                    <ul class="dropdown-menu">

                                                        <!-- EDIT -->
                                                        <li>
                                                            <a class="dropdown-item edit-video-btn" href="#"
                                                                data-token="<%= video.token %>" data-bs-toggle="modal"
                                                                data-bs-target="#addVideoModal">
                                                                <i class="ti ti-edit me-2"></i>Edit
                                                            </a>
                                                        </li>

                                                        <!-- STATUS TOGGLE -->
                                                        <li>
                                                            <form action="/manage/video/toggle-status" method="post">
                                                                <input type="hidden" name="token"
                                                                    value="<%= video.token %>">
                                                                <input type="hidden" name="status"
                                                                    value="<%=  video.status %>">
                                                                <button class="dropdown-item toggle-status-btn"
                                                                    type="submit">
                                                                    <i
                                                                        class="ti ti-toggle-<%= video.status ? 'right' : 'left' %> me-2"></i>
                                                                    <%= video.status ? 'Unpublish' : 'Publish' %>
                                                                </button>
                                                            </form>
                                                        </li>

                                                        <li>
                                                            <hr class="dropdown-divider">
                                                        </li>

                                                        <!-- DELETE -->
                                                        <li>
                                                            <a class="dropdown-item text-danger delete-video-btn"
                                                                href="#" data-token="<%= video.token %>">
                                                                <i class="ti ti-trash me-2"></i>Delete
                                                            </a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>

                                            <!-- DESCRIPTION -->
                                            <p class="text-muted small mb-3">
                                                <%= video.description.length> 100
                                                    ? video.description.substring(0, 100) + '...'
                                                    : video.description %>
                                            </p>

                                            <!-- META -->
                                            <div class="video-meta d-flex justify-content-between mb-3">
                                                <span class="badge bg-light text-dark">
                                                    <i class="ti ti-category me-1"></i>
                                                    <%= video.category %>
                                                </span>

                                                <div class="text-muted small">
                                                    <i class="ti ti-calendar me-1"></i>
                                                    <%= new Date(video.created_at).toLocaleDateString() %>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>

                                    <!-- EMPTY STATE -->
                                    <div class="col-12">
                                        <div class="card">
                                            <div class="card-body text-center py-5">
                                                <i class="ti ti-video mb-3" style="font-size: 3rem; color: #ccc;"></i>
                                                <h5 class="text-muted">No videos found</h5>
                                                <p class="text-muted mb-4">Add your first helping video to get started
                                                </p>
                                                <button class="btn btn-primary" data-bs-toggle="modal"
                                                    data-bs-target="#addVideoModal">
                                                    <i class="ti ti-video-plus me-2"></i>Add New Video
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <% } %>
                </div>

                <!-- /Videos Grid -->

                <!-- Pagination -->
                <% if (data?.results?.totalPages> 0) { %>
                    <div class="row">
                        <div class="col-12">
                            <nav aria-label="Page navigation">
                                <ul class="pagination justify-content-center">

                                    <!-- PREVIOUS -->
                                    <li class="page-item <%= data?.results?.page <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link"
                                            href="?page=<%= data?.results?.page - 1 %>&category=<%= query.category || '' %>&status=<%= query.status || '' %>&search=<%= query.search || '' %>">
                                            <i class="ti ti-chevron-left"></i>
                                        </a>
                                    </li>

                                    <!-- PAGE NUMBERS -->
                                    <% for (let i=1; i <=data?.results?.totalPages; i++) { %>
                                        <li class="page-item <%= data?.results?.page === i ? 'active' : '' %>">
                                            <a class="page-link"
                                                href="?page=<%= i %>&category=<%= query.category || '' %>&status=<%= query.status || '' %>&search=<%= query.search || '' %>">
                                                <%= i %>
                                            </a>
                                        </li>
                                        <% } %>

                                            <!-- NEXT -->
                                            <li
                                                class="page-item <%= data?.results?.page >= data?.results?.totalPages ? 'disabled' : '' %>">
                                                <a class="page-link"
                                                    href="?page=<%= data?.results?.page + 1 %>&category=<%= query.category || '' %>&status=<%= query.status || '' %>&search=<%= query.search || '' %>">
                                                    <i class="ti ti-chevron-right"></i>
                                                </a>
                                            </li>

                                </ul>
                            </nav>
                        </div>
                    </div>
                    <% } %>
                        <!-- /Pagination -->

                        <!-- Summary -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="text-center">
                                                    <h5 class="mb-1">Showing <%= data?.results?.totalDocs || 0 %> videos
                                                    </h5>
                                                    <p class="text-muted mb-0">Total: <%=
                                                            data?.results?.statusCounts?.total || 0 %>
                                                            videos
                                                            in
                                                            library</p>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-end">
                                                <button class="btn btn-success" id="exportVideos">
                                                    <i class="ti ti-download me-2"></i>Export CSV
                                                </button>
                                                <button class="btn btn-info" id="bulkActions">
                                                    <i class="ti ti-checkbox me-2"></i>Bulk Actions
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /Summary -->
            </div>
        </div>
        <!-- /Page Wrapper -->

        <!-- Add/Edit Video Modal (Advanced) -->
        <div class="modal fade" id="addVideoModal" tabindex="-1" aria-labelledby="addVideoModalLabel"
            aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addVideoModalLabel">Add New Video</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form action="/upload/video" id="videoForm" method="POST" enctype="multipart/form-data">
                            <input type="hidden" id="videoId" name="id" value="">

                            <!-- Video Source Type -->
                            <div class="mb-4">
                                <label class="form-label mb-3">Video Source</label>
                                <div class="btn-group w-100" role="group" id="videoSourceType">
                                    <input type="radio" class="btn-check" name="source_type" id="sourceYoutube"
                                        value="youtube" autocomplete="off" checked>
                                    <label class="btn btn-outline-primary" for="sourceYoutube">
                                        <i class="ti ti-brand-youtube me-2"></i>YouTube
                                    </label>

                                    <input type="radio" class="btn-check" name="source_type" id="sourceUpload"
                                        value="upload" autocomplete="off">
                                    <label class="btn btn-outline-primary" for="sourceUpload">
                                        <i class="ti ti-upload me-2"></i>Upload
                                    </label>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-12">
                                    <!-- Video URL Section (for YouTube, Vimeo, Direct) -->
                                    <div id="urlSection" class="mb-3">
                                        <div class="mb-3">
                                            <label for="videoUrl" class="form-label">Video URL <span
                                                    class="text-danger">*</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text">
                                                    <i class="ti ti-link"></i>
                                                </span>
                                                <input type="url" class="form-control" id="videoUrl" name="video_url"
                                                    placeholder="https://youtube.com/watch?v=..." required>
                                                <button type="button" class="btn btn-outline-secondary"
                                                    id="testVideoUrl">
                                                    <i class="ti ti-player-play"></i> Test
                                                </button>
                                            </div>
                                            <small class="text-muted" id="urlHelpText">
                                                Enter YouTube, Vimeo, or direct video URL
                                            </small>
                                        </div>
                                    </div>

                                    <!-- Video Upload Section -->
                                    <div id="uploadSection" class="mb-3" style="display: none;">
                                        <div class="mb-3">
                                            <label for="videoFile" class="form-label">Upload Video File <span
                                                    class="text-danger">*</span></label>
                                            <div class="file-upload-area">
                                                <div class="file-drop-zone" id="fileDropZone">
                                                    <i class="ti ti-cloud-upload"
                                                        style="font-size: 2rem; color: #6366f1;"></i>
                                                    <p class="mt-2 mb-1">Drag & drop video file here</p>
                                                    <p class="text-muted small mb-3">or click to browse</p>
                                                    <button type="button"
                                                        class="btn btn-outline-primary btn-sm browse-file-btn">
                                                        <i class="ti ti-folder me-2"></i>Browse Files
                                                    </button>
                                                    <input type="file" class="d-none" id="videoFile" name="video_file"
                                                        accept="video/*">
                                                </div>
                                                <div class="file-info mt-2" id="fileInfo" style="display: none;">
                                                    <div class="d-flex align-items-center justify-content-between">
                                                        <div>
                                                            <i class="ti ti-file me-2"></i>
                                                            <span id="fileName">video.mp4</span>
                                                            <small class="text-muted ms-2" id="fileSize">0 MB</small>
                                                        </div>
                                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                            id="removeFile">
                                                            <i class="ti ti-trash"></i>
                                                        </button>
                                                    </div>
                                                    <div class="progress mt-2" style="height: 5px;">
                                                        <div class="progress-bar" id="uploadProgress" style="width: 0%">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <small class="text-muted">
                                                Supported formats: MP4, WebM, MOV, AVI • Max size: 100MB
                                            </small>
                                        </div>
                                    </div>

                                    <!-- Auto-detected Info -->
                                    <div class="mb-3" id="videoInfoSection" style="display: none;">
                                        <div class="alert alert-info">
                                            <div class="d-flex align-items-center">
                                                <i class="ti ti-info-circle me-3" style="font-size: 1.2rem;"></i>
                                                <div>
                                                    <p class="mb-1" id="detectedTitle">Video detected: Getting Started
                                                        Tutorial</p>
                                                    <p class="mb-0 small" id="detectedDuration">Duration: 5:30 • Views:
                                                        1,250</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="videoTitle" class="form-label">Video Title <span
                                                class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="videoTitle" name="title"
                                            placeholder="Enter video title" required>
                                        <small class="text-muted">Clear, descriptive title that explains what the video
                                            is
                                            about</small>
                                    </div>

                                    <div class="mb-3">
                                        <label for="videoDescription" class="form-label">Description <span
                                                class="text-danger">*</span></label>
                                        <textarea class="form-control" id="videoDescription" name="description" rows="3"
                                            placeholder="Describe what users will learn from this video..."
                                            required></textarea>
                                        <small class="text-muted">Provide detailed information about the video
                                            content</small>
                                    </div>

                                    <!-- Video Thumbnail -->
                                    <div class="mb-3">
                                        <label for="videoThumbnail" class="form-label">
                                            Video Thumbnail <span class="text-danger">*</span>
                                        </label>

                                        <div class="d-flex align-items-center gap-3">
                                            <!-- Preview -->
                                            <div class="border rounded p-1" style="width:140px;height:80px;">
                                                <img id="thumbnailPreview"
                                                    src="/assets/img/video/thumbnail-placeholder.jpg"
                                                    alt="Thumbnail Preview"
                                                    style="width:100%;height:100%;object-fit:cover;border-radius:4px;">
                                            </div>

                                            <!-- File Input -->
                                            <div class="flex-grow-1">
                                                <input type="file" class="form-control" id="videoThumbnail"
                                                    name="thumbnail" accept="image/png,image/jpeg,image/webp" required>
                                                <small class="text-muted">
                                                    JPG / PNG / WebP • Recommended 1280×720 • Max 1MB
                                                </small>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-12">
                                            <div class="mb-3">
                                                <label for="videoCategory" class="form-label">Category <span
                                                        class="text-danger">*</span></label>
                                                <select class="form-control select2" id="videoCategory" name="category"
                                                    required>
                                                    <option value="">Select Category</option>
                                                    <option value="getting-started">Getting Started</option>
                                                    <option value="vendor-guide">Vendor Guide</option>
                                                    <option value="customer-guide">Customer Guide</option>
                                                    <option value="payment">Payment & Billing</option>
                                                    <option value="troubleshooting">Troubleshooting</option>
                                                    <option value="features">Features Tour</option>
                                                    <option value="announcements">Announcements</option>
                                                    <option value="updates">Updates & News</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                    <i class="ti ti-x me-2"></i>Cancel
                                </button>
                                <button type="submit" class="btn btn-primary" id="saveVideoBtn">
                                    <i class="ti ti-device-floppy me-2"></i>Save Video
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Video Preview Modal -->
        <div class="modal fade" id="videoPreviewModal" tabindex="-1" aria-labelledby="videoPreviewModalLabel"
            aria-hidden="true">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="videoPreviewModalLabel">Video Preview</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="ratio ratio-16x9" id="videoPreviewContainer">
                            <div class="text-center py-5 text-muted">
                                <i class="ti ti-loader"></i> Loading video...
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Delete Confirmation Modal -->
        <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel"
            aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteConfirmModalLabel">Confirm Delete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete this video? This action cannot be undone.</p>
                        <p class="text-muted small">All views, likes, and comments associated with this video will also
                            be
                            removed.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete Video</button>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .file-drop-zone {
                border: 2px dashed #ced4da;
                padding: 30px;
                border-radius: 8px;
                cursor: pointer;
                transition: all 0.2s ease;
            }

            .file-drop-zone.border-primary {
                background-color: #f8f9ff;
                border-color: #6366f1;
            }
        </style>

        <%- include('../shared/partials/footer') %>

            <script>
                document.getElementById("videoThumbnail").addEventListener("change", function (e) {
                    const file = e.target.files[0];
                    if (!file) return;

                    const reader = new FileReader();
                    reader.onload = () => {
                        document.getElementById("thumbnailPreview").src = reader.result;
                    };
                    reader.readAsDataURL(file);
                });
            </script>

            <script>
                document.addEventListener('DOMContentLoaded', function () {

                    const sourceYoutube = document.getElementById('sourceYoutube');
                    const sourceUpload = document.getElementById('sourceUpload');

                    const urlSection = document.getElementById('urlSection');
                    const uploadSection = document.getElementById('uploadSection');

                    const dropZone = document.getElementById('fileDropZone');
                    const fileInput = document.getElementById('videoFile');
                    const browseBtn = document.querySelector('.browse-file-btn');

                    const fileInfo = document.getElementById('fileInfo');
                    const fileName = document.getElementById('fileName');
                    const fileSize = document.getElementById('fileSize');
                    const removeFileBtn = document.getElementById('removeFile');

                    sourceYoutube.addEventListener('change', () => {
                        urlSection.style.display = 'block';
                        uploadSection.style.display = 'none';
                        fileInput.value = '';
                        fileInfo.style.display = 'none';
                    });

                    sourceUpload.addEventListener('change', () => {
                        urlSection.style.display = 'none';
                        uploadSection.style.display = 'block';
                    });

                    browseBtn.addEventListener('click', function (e) {
                        e.stopPropagation();
                        fileInput.click();
                    });

                    dropZone.addEventListener('click', function (e) {
                        if (e.target.closest('.browse-file-btn')) return;
                        fileInput.click();
                    });

                    fileInput.addEventListener('change', function () {
                        if (this.files && this.files[0]) {
                            showFileInfo(this.files[0]);
                        }
                    });

                    dropZone.addEventListener('dragover', function (e) {
                        e.preventDefault();
                        dropZone.classList.add('border-primary');
                    });

                    dropZone.addEventListener('dragleave', function () {
                        dropZone.classList.remove('border-primary');
                    });

                    dropZone.addEventListener('drop', function (e) {
                        e.preventDefault();
                        dropZone.classList.remove('border-primary');

                        const file = e.dataTransfer.files[0];
                        if (!file) return;

                        fileInput.files = e.dataTransfer.files;
                        showFileInfo(file);
                    });

                    removeFileBtn.addEventListener('click', function () {
                        fileInput.value = '';
                        fileInfo.style.display = 'none';
                    });

                    function showFileInfo(file) {
                        fileName.textContent = file.name;
                        fileSize.textContent = (file.size / (1024 * 1024)).toFixed(2) + ' MB';
                        fileInfo.style.display = 'block';
                    }

                });
            </script>


            <script>
                document.addEventListener('DOMContentLoaded', function () {

                    const urlSection = document.getElementById('urlSection');
                    const uploadSection = document.getElementById('uploadSection');
                    const videoUrl = document.getElementById('videoUrl');
                    const videoFile = document.getElementById('videoFile');

                    function toggleSource() {
                        const selected = document.querySelector('input[name="source_type"]:checked')?.value;

                        if (selected === 'upload') {
                            urlSection.style.display = 'none';
                            uploadSection.style.display = 'block';

                            videoUrl.removeAttribute('required');
                            videoFile.setAttribute('required', 'required');
                        } else {
                            urlSection.style.display = 'block';
                            uploadSection.style.display = 'none';

                            videoFile.removeAttribute('required');
                            videoUrl.setAttribute('required', 'required');
                        }
                    }

                    // Attach change listeners
                    document.querySelectorAll('input[name="source_type"]').forEach(radio => {
                        radio.addEventListener('change', toggleSource);
                    });

                    // Run once on load
                    toggleSource();
                });
            </script>

            <script>
                $(document).ready(function () {

                    function toggleVideoSourceUI(source) {
                        if (source === 'upload') {
                            $('#urlSection').hide();
                            $('#uploadSection').show();

                            // URL not required for upload
                            $('#videoUrl').prop('required', false);
                            $('#videoFile').prop('required', true);
                        } else {
                            $('#uploadSection').hide();
                            $('#urlSection').show();

                            // URL required for non-upload
                            $('#videoFile').prop('required', false);
                            $('#videoUrl').prop('required', true);
                        }
                    }

                    // Initial state on modal open
                    const initialSource = $('input[name="source_type"]:checked').val();
                    toggleVideoSourceUI(initialSource);

                    // Change event
                    $('input[name="source_type"]').on('change', function () {
                        toggleVideoSourceUI($(this).val());
                    });

                    // Optional: reset when modal closes
                    $('#addVideoModal').on('hidden.bs.modal', function () {
                        $('#videoForm')[0].reset();
                        toggleVideoSourceUI('youtube');
                    });

                });
            </script>

            <script>
                document.addEventListener('click', function (e) {
                    const btn = e.target.closest('.preview-video-btn');
                    if (!btn) return;

                    const token = btn.dataset.token;
                    if (!token) return;

                    const container = document.getElementById('videoPreviewContainer');

                    container.innerHTML = `
        <video controls autoplay style="width:100%;height:100%;">
            <source src="/video/stream/${token}" type="video/mp4">
            Your browser does not support video playback.
        </video>
    `;

                    const modal = new bootstrap.Modal(
                        document.getElementById('videoPreviewModal')
                    );
                    modal.show();
                });

                // Stop video when modal closes
                document.getElementById('videoPreviewModal')
                    .addEventListener('hidden.bs.modal', () => {
                        document.getElementById('videoPreviewContainer').innerHTML = '';
                    });
            </script>



