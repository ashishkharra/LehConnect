<%- include('../shared/partials/header', { admin : admin, title: title, data: data, currentPage: currentPage }) %>

    <% const q=typeof query !=='undefined' ? query : {}; const limit=Number(data.limit) || 10; const
        currentSearch=q.search || '' ; const currentStatus=q.status || '' ; %>

        <div class="page-wrapper">
            <div class="content container-fluid">

                <div class="page-header">
                    <div class="row align-items-center">
                        <div class="col">
                            <h3 class="page-title">Service Management</h3>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-primary" onclick="openAddModal()">
                                <i class="ti ti-plus me-1"></i> Add Service
                            </button>
                        </div>
                    </div>
                </div>

                <div class="filter-section mb-4">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="search-box">
                                <i class="ti ti-search"></i>
                                <input type="text" class="form-control" id="searchServices"
                                    placeholder="Search services..." value="<%= currentSearch %>">
                            </div>
                        </div>

                        <div class="col-md-2">
                            <select class="form-control select2" id="statusFilter">
                                <option value="">All Status</option>
                                <option value="active" <%=currentStatus==='active' ? 'selected' : '' %>>Active</option>
                                <option value="inactive" <%=currentStatus==='inactive' ? 'selected' : '' %>>Inactive
                                </option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Service Name</th>
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (data && data.docs && data.docs.length> 0) { %>
                                    <% data.docs.forEach((service, index)=> { %>
                                        <tr>
                                            <td>
                                                <%= (data.currentPage - 1) * limit + (index + 1) %>
                                            </td>
                                            <td>
                                                <strong>
                                                    <%= service.name %>
                                                </strong>
                                            </td>
                                            <td>
                                                <code><%= service.code %></code>
                                            </td>
                                            <td>
                                                <%= service.description || '—' %>
                                            </td>
                                            <td>
                                                <span
                                                    class="badge <%= service.status === 'active' ? 'bg-success' : 'bg-danger' %>">
                                                    <%= service.status %>
                                                </span>
                                            </td>
                                            <td>
                                                <%= new Date(service.create_date).toLocaleDateString() %>
                                            </td>
                                            <td class="d-flex justify-content-end gap-1">
                                                <button class="btn btn-sm btn-outline-primary edit-service-btn"
                                                    data-service='<%- JSON.stringify(service) %>'>
                                                    <i class="ti ti-edit"></i>
                                                </button>

                                                <form action="/manage/status/<%= service.token %>" method="POST">
                                                    <button type="submit"
                                                        class="btn btn-sm <%= service.status === 'active' ? 'btn-outline-danger' : 'btn-outline-success' %>"
                                                        title="<%= service.status === 'active' ? 'Deactivate' : 'Activate' %>">
                                                        <i class="ti ti-power"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="text-center text-muted py-4">
                                                        <i class="ti ti-ghost fs-2 mb-2 d-block"></i>
                                                        No services found matching your criteria.
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <% if (data.totalPages> 1) { %>
                    <div class="row mt-3">
                        <div class="col-12">
                            <nav>
                                <ul class="pagination justify-content-center">
                                    <li class="page-item <%= data.currentPage <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link"
                                            href="?page=<%= data.currentPage - 1 %>&limit=<%= limit %>&search=<%= currentSearch %>&status=<%= currentStatus %>">
                                            <i class="ti ti-chevron-left"></i>
                                        </a>
                                    </li>

                                    <% for (let i=1; i <=data.totalPages; i++) { %>
                                        <li class="page-item <%= i === data.currentPage ? 'active' : '' %>">
                                            <a class="page-link"
                                                href="?page=<%= i %>&limit=<%= limit %>&search=<%= currentSearch %>&status=<%= currentStatus %>">
                                                <%= i %>
                                            </a>
                                        </li>
                                        <% } %>

                                            <li
                                                class="page-item <%= data.currentPage >= data.totalPages ? 'disabled' : '' %>">
                                                <a class="page-link"
                                                    href="?page=<%= data.currentPage + 1 %>&limit=<%= limit %>&search=<%= currentSearch %>&status=<%= currentStatus %>">
                                                    <i class="ti ti-chevron-right"></i>
                                                </a>
                                            </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                    <% } %>

            </div>
        </div>

        <div class="modal fade" id="addServiceModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <form action="/add-services" method="POST" class="modal-content" id="serviceForm">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalTitle">Add Service</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" name="token" id="serviceToken">

                        <div class="mb-3">
                            <label class="form-label">Service Name</label>
                            <input type="text" class="form-control" name="name" required
                                placeholder="e.g. Web Development">
                        </div>

                        <div class="mb-3" id="codeFieldContainer" style="display:none;">
                            <label class="form-label">Service Code</label>
                            <input type="text" class="form-control bg-light" name="code" readonly>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="description" rows="3"
                                placeholder="Enter service details..."></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            // Helper to grab URL Params safely
            const getParams = () => new URLSearchParams(window.location.search);

            // 1. Search Logic (Debounced or On Change)
            document.getElementById('searchServices')?.addEventListener('change', function (e) {
                const params = getParams();
                const value = e.target.value.trim();
                value ? params.set('search', value) : params.delete('search');
                params.delete('page'); // Reset to page 1 on search
                window.location.search = params.toString();
            });

            // 2. Status Filter Logic
            document.getElementById('statusFilter')?.addEventListener('change', function (e) {
                const params = getParams();
                const value = e.target.value;
                value ? params.set('status', value) : params.delete('status');
                params.delete('page');
                window.location.search = params.toString();
            });

            // 3. Open Modal for "Add New"
            window.openAddModal = function () {
                document.getElementById('serviceForm').reset();
                document.getElementById('serviceToken').value = '';
                document.getElementById('modalTitle').innerText = 'Add Service';
                document.getElementById('codeFieldContainer').style.display = 'none'; // Hide code on Add
                new bootstrap.Modal(document.getElementById('addServiceModal')).show();
            }

            // 4. Open Modal for "Edit"
            document.querySelectorAll('.edit-service-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const service = JSON.parse(btn.dataset.service);

                    // Populate Fields
                    document.getElementById('serviceToken').value = service.token;
                    document.querySelector('[name="name"]').value = service.name;
                    document.querySelector('[name="description"]').value = service.description || '';

                    // Handle Code Field (Show and Populate)
                    const codeInput = document.querySelector('[name="code"]');
                    if (codeInput) {
                        codeInput.value = service.code;
                        document.getElementById('codeFieldContainer').style.display = 'block';
                    }

                    // Update Title
                    document.getElementById('modalTitle').innerText = 'Edit Service';

                    new bootstrap.Modal(document.getElementById('addServiceModal')).show();
                });
            });
        </script>

        <%- include('../shared/partials/footer') %>