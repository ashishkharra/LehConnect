<%- include('../shared/partials/header', { admin : admin, title: title, query: query, data: data }) %>

    <% 
        const customerReviews=data?.customerReviewsData 
        const vendorReviews=data?.vendorReviewsData
        const stats = data?.stats
    %>
    <!-- Page Wrapper -->
    <div class="page-wrapper">
        <div class="content container-fluid">
            <!-- Page Header -->
            <div class="page-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h3 class="page-title">Reviews & Feedback Management</h3>
                        <p class="page-subtitle">Manage customer and vendor reviews, ratings, and feedback</p>
                    </div>

                    <div class="col-auto ms-auto">
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addReviewModal">
                            <i class="ti ti-plus me-2"></i>Add Review
                        </button>
                    </div>
                </div>
            </div>
            <!-- /Page Header -->

            <!-- Reviews Navigation Tabs -->
            <div class="row mb-4">
                <div class="col-12">
                    <ul class="nav nav-tabs nav-tabs-bottom" id="reviewsTab">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#customerReviews">
                                <i class="ti ti-users me-2"></i> Customer Reviews
                                <span class="badge bg-primary ms-2">
                                    <%= customerReviews?.docs.length || 0 %>
                                </span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#vendorReviews">
                                <i class="ti ti-building-store me-2"></i> Vendor Reviews
                                <span class="badge bg-success ms-2">
                                    <%= vendorReviews?.docs.length || 0 %>
                                </span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#reviewSettings">
                                <i class="ti ti-settings me-2"></i> Settings
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Reviews Content -->
            <div class="tab-content" id="reviewsTabContent">
                <!-- Customer Reviews Tab -->
                <div class="tab-pane fade show active" id="customerReviews">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Customer Reviews</h5>
                                    <p class="card-subtitle">Reviews submitted by customers about vendors, services,
                                        and
                                        experiences</p>
                                </div>
                                <div class="card-body">
                                    <!-- Filter Bar -->
                                    <div class="row mb-4">
                                        <div class="col-md-3">
                                            <select class="form-select" id="customerStatusFilter">
                                                <option value="all" <%=query.customer_status==='all' ? 'selected' : ''
                                                    %>>All Status</option>
                                                <option value="pending" <%=query.customer_status==='pending'
                                                    ? 'selected' : '' %>>Pending</option>
                                                <option value="approved" <%=query.customer_status==='approved'
                                                    ? 'selected' : '' %>>Approved</option>
                                                <option value="rejected" <%=query.customer_status==='rejected'
                                                    ? 'selected' : '' %>>Rejected</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <select class="form-select" id="customerRatingFilter">
                                                <option value="all" <%=query.customer_rating==='all' ? 'selected' : ''
                                                    %>>All Ratings</option>
                                                <% [5,4,3,2,1].forEach(r=> { %>
                                                    <option value="<%= r %>" <%=Number(query.customer_rating)===r
                                                        ? 'selected' : '' %>><%= r %> Stars</option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="input-group">
                                                <input type="text" class="form-control"
                                                    placeholder="Search customer reviews..." id="customerSearch"
                                                    value="<%= query.customer_search || '' %>">
                                                <button class="btn btn-primary" type="button">
                                                    <i class="ti ti-search"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Customer Reviews List -->
                                    <div class="table-responsive">
                                        <%- include('../shared/partials/customerReviewRows', { customerReviews, query })
                                            %>
                                    </div>

                                    <!-- Pagination -->
                                    <% if (customerReviews && customerReviews.totalPages> 1) { %>
                                        <div class="row mt-4">
                                            <div class="col-12">
                                                <nav>
                                                    <ul class="pagination justify-content-center">
                                                        <li
                                                            class="page-item <%= customerReviews.page === 1 ? 'disabled' : '' %>">
                                                            <a class="page-link"
                                                                href="?customer_page=<%= customerReviews.page - 1 %>">Previous</a>
                                                        </li>

                                                        <% for(let p=1; p <=customerReviews.totalPages; p++) { %>
                                                            <li
                                                                class="page-item <%= customerReviews.page === p ? 'active' : '' %>">
                                                                <a class="page-link" href="?customer_page=<%= p %>">
                                                                    <%= p %>
                                                                </a>
                                                            </li>
                                                            <% } %>

                                                                <li
                                                                    class="page-item <%= customerReviews.page === customerReviews.totalPages ? 'disabled' : '' %>">
                                                                    <a class="page-link"
                                                                        href="?customer_page=<%= customerReviews.page + 1 %>">Next</a>
                                                                </li>
                                                    </ul>
                                                </nav>
                                            </div>
                                        </div>
                                        <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Vendor Reviews Tab -->
                <div class="tab-pane fade" id="vendorReviews">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Vendor Reviews</h5>
                                    <p class="card-subtitle">Reviews submitted by vendors about platform, services,
                                        and
                                        customer experiences</p>
                                </div>
                                <div class="card-body">
                                    <!-- Filter Bar -->
                                    <div class="row mb-4">
                                        <div class="col-md-3">
                                            <select class="form-select" id="vendorStatusFilter">
                                                <option value="all" <%=query.vendor_status==='all' ? 'selected' : '' %>
                                                    >All Status</option>
                                                <option value="PENDING" <%=query.vendor_status==='pending' ? 'selected'
                                                    : '' %>>Pending</option>
                                                <option value="APPROVED" <%=query.vendor_status==='approved'
                                                    ? 'selected' : '' %>>Approved</option>
                                                <option value="REJECTED" <%=query.vendor_status==='rejected'
                                                    ? 'selected' : '' %>>Rejected</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <select class="form-select" id="vendorRatingFilter">
                                                <option value="all" <%=query.vendor_rating==='all' ? 'selected' : '' %>
                                                    >All Ratings</option>
                                                <% [5,4,3,2,1].forEach(r=> { %>
                                                    <option value="<%= r %>" <%=Number(query.vendor_rating)===r
                                                        ? 'selected' : '' %>><%= r %> Stars</option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="input-group">
                                                <input type="text" class="form-control"
                                                    placeholder="Search vendor reviews..." id="vendorSearch"
                                                    value="<%= query.vendor_search || '' %>">
                                                <button class="btn btn-primary" type="button">
                                                    <i class="ti ti-search"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Vendor Reviews List -->
                                    <div class="table-responsive">
                                        <%- include('../shared/partials/vendorReviewRows', { vendorReviews, query }) %>
                                    </div>

                                    <!-- Pagination -->
                                    <% if (vendorReviews.totalPages> 1) { %>
                                        <div class="row mt-4">
                                            <div class="col-12">
                                                <nav>
                                                    <ul class="pagination justify-content-center">
                                                        <li
                                                            class="page-item <%= vendorReviews.page === 1 ? 'disabled' : '' %>">
                                                            <a class="page-link"
                                                                href="?vendor_page=<%= vendorReviews.page - 1 %>">Previous</a>
                                                        </li>

                                                        <% for(let p=1; p <=vendorReviews.totalPages; p++) { %>
                                                            <li
                                                                class="page-item <%= vendorReviews.page === p ? 'active' : '' %>">
                                                                <a class="page-link" href="?vendor_page=<%= p %>">
                                                                    <%= p %>
                                                                </a>
                                                            </li>
                                                            <% } %>

                                                                <li
                                                                    class="page-item <%= vendorReviews.page === vendorReviews.totalPages ? 'disabled' : '' %>">
                                                                    <a class="page-link"
                                                                        href="?vendor_page=<%= vendorReviews.page + 1 %>">Next</a>
                                                                </li>
                                                    </ul>
                                                </nav>
                                            </div>
                                        </div>
                                        <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Settings Tab -->
                <div class="tab-pane fade" id="reviewSettings">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Review Settings</h5>
                                </div>
                                <div class="card-body">
                                    <form action="/admin/reviews/settings" method="POST">
                                        <div class="mb-3">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="autoApprove"
                                                    name="auto_approve" <%=settings.auto_approve ? 'checked' : '' %>>
                                                <label class="form-check-label" for="autoApprove">
                                                    Auto-approve reviews
                                                </label>
                                                <small class="text-muted d-block">Automatically approve new reviews
                                                    without manual intervention</small>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="emailNotifications"
                                                    name="email_notifications" <%=settings.email_notifications
                                                    ? 'checked' : '' %>>
                                                <label class="form-check-label" for="emailNotifications">
                                                    Email notifications for new reviews
                                                </label>
                                                <small class="text-muted d-block">Receive email alerts when new
                                                    reviews are submitted</small>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="requireApproval"
                                                    name="require_approval" <%=settings.require_approval ? 'checked'
                                                    : '' %>>
                                                <label class="form-check-label" for="requireApproval">
                                                    Require approval for all reviews
                                                </label>
                                                <small class="text-muted d-block">All reviews must be approved
                                                    before appearing publicly</small>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="allowEditing"
                                                    name="allow_editing" <%=settings.allow_editing ? 'checked' : '' %>>
                                                <label class="form-check-label" for="allowEditing">
                                                    Allow users to edit their reviews
                                                </label>
                                                <small class="text-muted d-block">Users can edit their reviews
                                                    within 24 hours of submission</small>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label for="minReviewLength" class="form-label">Minimum Review
                                                Length</label>
                                            <input type="number" class="form-control" id="minReviewLength"
                                                name="min_review_length" value="<%= settings.min_review_length || 10 %>"
                                                min="0">
                                            <small class="text-muted">Minimum number of characters required for a
                                                review</small>
                                        </div>

                                        <div class="mb-3">
                                            <label for="maxReviewLength" class="form-label">Maximum Review
                                                Length</label>
                                            <input type="number" class="form-control" id="maxReviewLength"
                                                name="max_review_length"
                                                value="<%= settings.max_review_length || 500 %>" min="0">
                                            <small class="text-muted">Maximum number of characters allowed for a
                                                review</small>
                                        </div>

                                        <div class="text-end">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="ti ti-device-floppy me-2"></i>Save Settings
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Review Statistics</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row text-center">
                                        <div class="col-6 mb-4">
                                            <div class="stat-card">
                                                <i class="ti ti-users text-primary mb-2" style="font-size: 2rem;"></i>
                                                <h3>
                                                    <%= stats.total_customer_reviews || 0 %>
                                                </h3>
                                                <p class="text-muted mb-0">Customer Reviews</p>
                                            </div>
                                        </div>
                                        <div class="col-6 mb-4">
                                            <div class="stat-card">
                                                <i class="ti ti-building-store text-success mb-2"
                                                    style="font-size: 2rem;"></i>
                                                <h3>
                                                    <%= stats.total_vendor_reviews || 0 %>
                                                </h3>
                                                <p class="text-muted mb-0">Vendor Reviews</p>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="stat-card">
                                                <i class="ti ti-star text-warning mb-2" style="font-size: 2rem;"></i>
                                                <h3>
                                                    <%= stats.average_rating || 0 %>
                                                </h3>
                                                <p class="text-muted mb-0">Average Rating</p>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="stat-card">
                                                <i class="ti ti-clock text-info mb-2" style="font-size: 2rem;"></i>
                                                <h3>
                                                    <%= stats.pending_reviews || 0 %>
                                                </h3>
                                                <p class="text-muted mb-0">Pending Reviews</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card mt-4">
                                <div class="card-header">
                                    <h5 class="card-title">Recent Activity</h5>
                                </div>
                                <div class="card-body">
                                    <div class="activity-timeline">
                                        <!-- <%# if (recentActivity && recentActivity.length> 0) { %>
                                            <%# recentActivity.forEach(activity=> { %>
                                                <div class="activity-item">
                                                    <div class="activity-icon bg-<%#= 
                                                activity.type === 'approve' ? 'success' : 
                                                activity.type === 'reject' ? 'danger' : 'info' 
                                            %>">
                                                        <i class="ti ti-<%#= 
                                                    activity.type === 'approve' ? 'check' : 
                                                    activity.type === 'reject' ? 'x' : 'eye' 
                                                %>"></i>
                                                    </div>
                                                    <div class="activity-content">
                                                        <h6>
                                                            <%#= activity.description %>
                                                        </h6>
                                                        <small class="text-muted">
                                                            <%#= activity.timestamp %>
                                                        </small>
                                                    </div>
                                                </div>
                                                <%# }); %>
                                                    <%# } else { %>
                                                        <p class="text-muted text-center">No recent activity</p>
                                                        <%# } %> -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- /Page Wrapper -->

    <!-- Review Modal (for viewing details) -->
    <div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Review Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="reviewModalBody">
                    <!-- Content will be loaded via AJAX -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addReviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="ti ti-edit me-2"></i>Add Review (Admin Entry)
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form action="/review/create" method="POST">
                    <div class="modal-body">

                        <!-- Name -->
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" name="name" class="form-control" placeholder="Enter name" required>
                        </div>

                        <!-- Review By -->
                        <div class="mb-3">
                            <label class="form-label">Review By</label>
                            <select name="review_by" class="form-select" required>
                                <option value="CUSTOMER">Customer</option>
                                <option value="VENDOR">Vendor</option>
                            </select>
                        </div>

                        <!-- Review For -->
                        <div class="mb-3">
                            <label class="form-label">Review For</label>
                            <select name="review_for" class="form-select" required>
                                <option value="VENDOR">Vendor</option>
                                <option value="CUSTOMER">Customer</option>
                                <option value="PLATFORM">Platform</option>
                            </select>
                        </div>

                        <!-- Rating -->
                        <div class="mb-3">
                            <label class="form-label">Rating</label>
                            <div class="d-flex gap-3">
                                <% for (let i=1; i <=5; i++) { %>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="rating"
                                            id="ratingModal<%= i %>" value="<%= i %>" <%=i===5 ? 'checked' : '' %>>
                                        <label class="form-check-label" for="ratingModal<%= i %>">
                                            <i class="ti ti-star text-warning"></i>
                                            <%= i %>
                                        </label>
                                    </div>
                                    <% } %>
                            </div>
                        </div>

                        <!-- Comment -->
                        <div class="mb-3">
                            <label class="form-label">Review Comment</label>
                            <textarea name="comment" rows="4" class="form-control" placeholder="Write the review..."
                                required></textarea>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-2"></i>Submit Review
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>


    <%- include('../shared/partials/footer') %>
        <script>
            function debounce(func, delay) {
                let timeout;
                return function (...args) {
                    clearTimeout(timeout);
                    timeout = setTimeout(() => func.apply(this, args), delay);
                }
            }

            // Function to fetch vendor reviews via AJAX
            async function fetchVendorReviews() {
                const status = document.getElementById('vendorStatusFilter').value;
                const rating = document.getElementById('vendorRatingFilter').value;
                const search = document.getElementById('vendorSearch').value;

                const params = new URLSearchParams({
                    vendor_status: status,
                    vendor_rating: rating,
                    vendor_search: search
                });

                try {
                    const res = await fetch(`/feedback/vendor-table?${params.toString()}`);
                    const html = await res.text();
                    document.getElementById('vendorReviewsTable').innerHTML = html;
                } catch (err) {
                    console.error('Failed to fetch vendor reviews:', err);
                }
            }

            // Function to fetch customer reviews via AJAX
            async function fetchCustomerReviews() {
                const status = document.getElementById('customerStatusFilter').value;
                const rating = document.getElementById('customerRatingFilter').value;
                const search = document.getElementById('customerSearch').value;

                const params = new URLSearchParams({
                    customer_status: status,
                    customer_rating: rating,
                    customer_search: search
                });

                try {
                    const res = await fetch(`/feedback/customer-table?${params.toString()}`);
                    const html = await res.text();
                    document.getElementById('customerReviewsTable').innerHTML = html;
                } catch (err) {
                    console.error('Failed to fetch customer reviews:', err);
                }
            }

            // Attach event listeners with debounce
            function attachReviewFilters() {
                // Vendor
                const vendorStatus = document.getElementById('vendorStatusFilter');
                const vendorRating = document.getElementById('vendorRatingFilter');
                const vendorSearch = document.getElementById('vendorSearch');
                const debouncedVendorFetch = debounce(fetchVendorReviews, 500);

                vendorStatus?.addEventListener('change', debouncedVendorFetch);
                vendorRating?.addEventListener('change', debouncedVendorFetch);
                vendorSearch?.addEventListener('input', debouncedVendorFetch);

                // Customer
                const customerStatus = document.getElementById('customerStatusFilter');
                const customerRating = document.getElementById('customerRatingFilter');
                const customerSearch = document.getElementById('customerSearch');
                const debouncedCustomerFetch = debounce(fetchCustomerReviews, 500);

                customerStatus?.addEventListener('change', debouncedCustomerFetch);
                customerRating?.addEventListener('change', debouncedCustomerFetch);
                customerSearch?.addEventListener('input', debouncedCustomerFetch);
            }

            // Initial call
            document.addEventListener('DOMContentLoaded', () => {
                attachReviewFilters();
            });
        </script>