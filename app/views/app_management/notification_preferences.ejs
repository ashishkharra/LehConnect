<%- include('../shared/partials/header', { admin : admin , title: title || 'LehConnect || Notification Management', currentPage: currentPage || ''}) %>

<%
const settings = data?.settings || {};
const cities = data?.cities || [];
%>

        <div class="page-wrapper">
            <div class="content container-fluid">

                <!-- Page Header -->
                <div class="page-header">
                    <div class="row align-items-center">
                        <div class="col">
                            <h3 class="page-title">Notification Management</h3>
                            <p class="page-subtitle">Control how booking notifications are distributed across cities</p>
                        </div>
                        <div class="col-auto">
                            <button type="submit" form="notificationForm" class="btn btn-primary">
                                <i class="ti ti-device-floppy me-2"></i>Save Changes
                            </button>
                        </div>
                    </div>
                </div>
                <!-- /Page Header -->

                <!-- Notification Settings Form -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title">Booking Notification Settings</h5>
                                <p class="card-subtitle">Define which cities should receive booking notifications</p>
                            </div>
                            <div class="card-body">

                                <form id="notificationForm" action="/toggle-booking-notification-preferences" method="POST">
                                    <input type="hidden" name="bulk_update" value="true">

                                    <!-- Distribution Mode -->
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-check form-switch mb-3">
                                                <input class="form-check-input" type="checkbox" id="sendToAllCities"
                                                    name="send_to_all_cities" <%=data?.settings?.send_to_all_cities ? 'checked'
                                                    : '' %>>
                                                <label class="form-check-label" for="sendToAllCities">
                                                    Send Notifications to All Cities
                                                </label>
                                                <small class="text-muted d-block">
                                                    If enabled, booking notifications will be sent to vendors in all
                                                    cities.
                                                </small>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="form-check form-switch mb-3">
                                                <input class="form-check-input" type="checkbox" id="cityFilterEnabled"
                                                    name="city_filter_enabled" <%=data?.settings?.city_filter_enabled
                                                    ? 'checked' : '' %>>
                                                <label class="form-check-label" for="cityFilterEnabled">
                                                    Enable City-Based Filtering
                                                </label>
                                                <small class="text-muted d-block">
                                                    Toggle this OFF if you want maximum reach during low traffic.
                                                </small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- City Selection -->
                                    <!-- <div class="row mt-3">
                                        <div class="col-12">
                                            <h6 class="mb-3">Select Cities for Notifications</h6>
                                        </div>

                                        <div class="col-md-12">
                                            <div class="mb-3">
                                                <label class="form-label">Choose Cities</label>
                                                <select class="form-select" name="selected_cities[]" multiple size="6">
                                                <%# cities.forEach(city => { %>
                                                    <option value="<%#= city.name %>"
                                                        <%#= (settings.selected_cities || []).includes(String(city.id)) ? 'selected' : '' %>>
                                                        <%#= city.name %>
                                                    </option>
                                                <%# }) %>
                                                </select>
                                                <small class="text-muted">
                                                    Hold CTRL (Windows) or CMD (Mac) to select multiple cities.
                                                </small>
                                            </div>
                                        </div>
                                    </div> -->

                                    <!-- Notification Type -->
                                    <!-- <div class="row mt-4">
                                        <div class="col-12">
                                            <h6 class="mb-3">Notification Type</h6>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">Notification Trigger</label>
                                                <select class="form-select" name="notification_type">
                                                    <option value="booking" <%=settings.notification_type==='booking'
                                                        ? 'selected' : '' %>>
                                                        New Booking Notification
                                                    </option>
                                                    <option value="cancellation"
                                                        <%=settings.notification_type==='cancellation' ? 'selected' : ''
                                                        %>>
                                                        Booking Cancellation
                                                    </option>
                                                    <option value="promotion"
                                                        <%=settings.notification_type==='promotion' ? 'selected' : '' %>
                                                        >
                                                        Promotional Notification
                                                    </option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="form-check form-switch mt-4">
                                                <input class="form-check-input" type="checkbox" id="instantDispatch"
                                                    name="instant_dispatch" <%=settings.instant_dispatch ? 'checked'
                                                    : '' %>>
                                                <label class="form-check-label" for="instantDispatch">
                                                    Send Instantly
                                                </label>
                                                <small class="text-muted d-block">
                                                    Disable to queue notifications manually.
                                                </small>
                                            </div>
                                        </div>
                                    </div> -->

                                    <!-- Hidden Keys -->
                                    <input type="hidden" name="setting_keys[]" value="send_to_all_cities">
                                    <input type="hidden" name="setting_keys[]" value="city_filter_enabled">
                                    <input type="hidden" name="setting_keys[]" value="selected_cities">
                                    <input type="hidden" name="setting_keys[]" value="notification_type">
                                    <input type="hidden" name="setting_keys[]" value="instant_dispatch">

                                    <!-- Actions -->
                                    <div class="row mt-4">
                                        <div class="col-12">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="ti ti-device-floppy me-2"></i>Save Changes
                                                </button>
                                                <button type="reset" class="btn btn-outline-secondary">
                                                    <i class="ti ti-refresh me-2"></i>Reset
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Live Preview -->
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title"><i class="ti ti-eye me-2"></i>Live Preview</h5>
                                <p class="card-subtitle">How notifications will be distributed</p>
                            </div>
                            <div class="card-body">
                                <div class="preview-counter bg-primary text-white p-4 rounded">
                                    <h5>Distribution Mode:</h5>
                                    <p>
                                        <% if(settings.send_to_all_cities){ %>
                                            Notifications will be sent to <strong>ALL cities</strong>.
                                            <% } else if(settings.city_filter_enabled){ %>
                                                Notifications limited to <strong>selected cities only</strong>.
                                                <% } else { %>
                                                    City filtering disabled — notifications broadcast globally.
                                                    <% } %>
                                    </p>

                                    <h6>Notification Type:</h6>
                                    <p>
                                        <%= settings.notification_type || 'Booking' %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Usage Guidelines -->
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title"><i class="ti ti-help me-2"></i>Usage Guidelines</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="instruction-item">
                                            <div class="instruction-icon bg-primary">
                                                <i class="ti ti-map-pin"></i>
                                            </div>
                                            <h6>City Filtering</h6>
                                            <p class="text-muted small">
                                                Use city filtering when traffic is high to reduce notification overload.
                                            </p>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="instruction-item">
                                            <div class="instruction-icon bg-success">
                                                <i class="ti ti-broadcast"></i>
                                            </div>
                                            <h6>Low Traffic Mode</h6>
                                            <p class="text-muted small">
                                                Disable filtering to ensure all vendors receive booking alerts.
                                            </p>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="instruction-item">
                                            <div class="instruction-icon bg-info">
                                                <i class="ti ti-bell"></i>
                                            </div>
                                            <h6>Smart Dispatch</h6>
                                            <p class="text-muted small">
                                                Enable instant dispatch for real-time booking updates.
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>