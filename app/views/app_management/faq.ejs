<%- include('../shared/partials/header', {
    admin: admin,
    title: title,
    currentPage: currentPage
}) %>

    <div class="page-wrapper">
        <div class="content container-fluid">

            <!-- Page Header -->
            <div class="page-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h3 class="page-title">Manage FAQs</h3>
                    </div>
                </div>
            </div>
            <!-- /Page Header -->

            <!-- Add FAQ -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5>Add New FAQ</h5>
                </div>
                <div class="card-body">
                    <form action="/add-faq" method="POST">

                        <div class="mb-3">
                            <label class="form-label">Question</label>
                            <input type="text" name="question" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Answer</label>
                            <textarea name="answer" rows="4" class="form-control" required></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Status</label>
                                <select name="status" class="form-select">
                                    <option value="active">Active</option>
                                    <option value="inactive">Inactive</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Position</label>
                                <input type="number" name="position" class="form-control" value="0">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-plus"></i> Add FAQ
                        </button>

                    </form>
                </div>
            </div>

            <!-- FAQ List -->
            <div class="card">
                <div class="card-header">
                    <h5>FAQ List</h5>
                </div>

                <div class="card-body table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Question</th>
                                <th>Status</th>
                                <th>Position</th>
                                <th width="160">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (data && data.length> 0) { %>
                                <% data.forEach((faq, index)=> { %>
                                    <tr>
                                        <td>
                                            <%= ((pagination.page - 1) * pagination.limit) + index + 1 %>
                                        </td>

                                        <td>
                                            <%= faq.question %>
                                        </td>

                                        <td>
                                            <span
                                                class="badge <%= faq.status === 'active' ? 'bg-success' : 'bg-danger' %>">
                                                <%= faq.status %>
                                            </span>
                                        </td>

                                        <td>
                                            <%= faq.position || 0 %>
                                        </td>

                                        <td>
                                            <a href="/edit-faq/<%= faq.token %>" class="btn btn-sm btn-warning">
                                                <i class="ti ti-edit"></i>
                                            </a>

                                            <form action="/delete-faq/<%= faq.token %>" method="POST"
                                                style="display:inline;"
                                                onsubmit="return confirm('Are you sure you want to delete this FAQ?')">

                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="ti ti-trash"></i>
                                                </button>
                                            </form>
                                        </td>

                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center text-muted">
                                                    No FAQs found
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            <% if (pagination.totalPages> 1) { %>
                <div class="row mt-4">
                    <div class="col-12">
                        <nav>
                            <ul class="pagination justify-content-center">

                                <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= pagination.page - 1 %>">
                                        <i class="ti ti-chevron-left"></i>
                                    </a>
                                </li>

                                <% for (let i=1; i <=pagination.totalPages; i++) { %>
                                    <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>

                                        <li
                                            class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
                                            <a class="page-link" href="?page=<%= pagination.page + 1 %>">
                                                <i class="ti ti-chevron-right"></i>
                                            </a>
                                        </li>

                            </ul>
                        </nav>
                    </div>
                </div>
                <% } %>

        </div>
    </div>

    <%- include('../shared/partials/footer') %>